//----------------------------------------------------------------------
// Top (subsystem) base test — builds the top env config, populates each child
// block's env config (agent cfgs + virtual interfaces from the config DB), and
// hands each child env its config so the composed tree self-configures.
//----------------------------------------------------------------------

class {{ dut.name }}_base_test extends uvm_test;
  `uvm_component_utils({{ dut.name }}_base_test)

  {{ dut.name }}_env e;
  {{ dut.name }}_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    env_cfg = {{ dut.name }}_env_cfg::type_id::create("env_cfg");
{% for sv in subenvs %}

    // Block: {{ sv.name }} ({{ sv.block }})
    env_cfg.{{ sv.cfg_field }} = {{ sv.env_cfg_class }}::type_id::create("{{ sv.cfg_field }}");
{% for agent in sv.agents %}
{% set acfg %}env_cfg.{{ sv.cfg_field }}.{{ agent.name }}_cfg{% endset %}
{% set vkey %}{{ sv.name }}_{{ agent.interface }}_vif{% endset %}
    {{ acfg }} = {{ agent.name }}_cfg::type_id::create("{{ agent.name }}_cfg");
    {{ acfg }}.is_active = UVM_{{ "ACTIVE" if agent.active else "PASSIVE" }};
    if (!uvm_config_db#(virtual {{ agent.interface }})::get(
          this, "", "{{ vkey }}", {{ acfg }}.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface '{{ vkey }}' in config DB (see tb_top.sv)")
{% endfor %}
    uvm_config_db#({{ sv.env_cfg_class }})::set(this, "e.{{ sv.inst }}", "env_cfg", env_cfg.{{ sv.cfg_field }});
{% endfor %}

    uvm_config_db#({{ dut.name }}_env_cfg)::set(this, "e", "env_cfg", env_cfg);
    e = {{ dut.name }}_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    `uvm_info("TB", "{{ dut.name }}_base_test: end_of_elaboration", UVM_FULL)
  endfunction

