class rd_sequencer extends uvm_sequencer #(rd_item);
  `uvm_component_utils(rd_sequencer)

  // Reactive agent: the monitor's request port feeds this FIFO. For the PIPELINED shape it
  // is a genuine BACKLOG buffer — the responder's accept thread drains it into per-ID
  // queues so N requests can be outstanding at once.
  uvm_analysis_export #(rd_item) request_export;
  uvm_tlm_analysis_fifo #(rd_item) request_fifo;

  // LIVENESS for the pipelined responder — the analog of the driver's DEAD_RESPONDER, and
  // deliberately NOT in a pragma. DEAD_RESPONDER catches "answered NOTHING"; it is blind to
  // a STRAND — answering some of a burst and leaving the tail queued. The responder
  // sequence bumps these; check_phase fails if the backlog was not fully drained.
  int unsigned m_accepted;    // requests buffered by the accept thread
  int unsigned m_answered;    // responses handed to the driver

  function new (string name, uvm_component parent);
    super.new(name, parent);
    request_export = new("request_export", this);
    request_fifo   = new("request_fifo", this);
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    request_export.connect(request_fifo.analysis_export);
  endfunction

  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (m_accepted != m_answered)
      `uvm_error("STRANDED_REQUESTS",
                 $sformatf({"pipelined responder accepted %0d request(s) but answered ",
                            "only %0d — the tail of a burst was STRANDED. The drive thread ",
                            "must drain the per-ID backlog; a loop that answers one per ",
                            "incoming request cannot (docs/t6_axi_outstanding_assessment.md)."},
                           m_accepted, m_answered))
  endfunction

endclass
