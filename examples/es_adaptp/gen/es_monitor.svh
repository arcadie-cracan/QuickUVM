class es_monitor extends uvm_monitor;
  `uvm_component_utils(es_monitor)

  virtual es_if vif;

  uvm_analysis_port #(es_item) ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    es_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      // Publish only valid/qualified transactions (emit_when: valid).
      if (tr.valid) ap.write(tr);
    end
  endtask

  task sample_dut (output es_item tr);
    es_item t;
    t = es_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------
    t.sample = vif.sample;
    t.valid = vif.valid;

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.window_done = vif.cb1.window_done;
    t.ones_cnt = vif.cb1.ones_cnt;
    t.test_fail = vif.cb1.test_fail;
    t.alert = vif.cb1.alert;

    // pragma quickuvm custom sample_dut_additional begin
    // `sample` is a TB-driven INPUT captured at posedge N, but the health-test OUTPUTS
    // (window_done/ones_cnt/test_fail) are sampled one edge later and reflect the DUT
    // having consumed the sample of THIS cycle. Re-sample `sample` at the output edge so
    // the transaction's (sample, verdict) describe the same cycle — otherwise the
    // predictor's independently-accumulated window lags the DUT's by one sample and every
    // boundary mismatches (the same input/output split-edge skew cdc_fifo fixes).
    t.sample = vif.sample;
    // `valid` is the emit_when qualifier and is likewise a driven INPUT: the generated
    // monitor sampled it at posedge N (a cycle before the outputs), so on a GAPPED valid
    // stream the emit gate would decide on the previous cycle's valid while carrying this
    // cycle's sample+verdict. Re-sample it here at the output edge too, so (valid, sample,
    // verdict) all describe the same cycle and emit_when holds under intermittent valid.
    t.valid = vif.valid;
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
