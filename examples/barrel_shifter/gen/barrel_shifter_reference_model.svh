function bs_seq_item barrel_shifter_predictor::predict(bs_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  bs_seq_item extr = bs_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Golden model (combinational): data_out = shift(data_in, amt, op).  W=32.
  case (t.op)
    3'd0: extr.data_out = t.data_in << t.amt;                          // SLL
    3'd1: extr.data_out = t.data_in >> t.amt;                          // SRL
    3'd2: extr.data_out = $signed(t.data_in) >>> t.amt;               // SRA
    3'd3: extr.data_out = (t.amt == '0) ? t.data_in
                          : (t.data_in << t.amt) | (t.data_in >> (32 - t.amt));  // ROL
    3'd4: extr.data_out = (t.amt == '0) ? t.data_in
                          : (t.data_in >> t.amt) | (t.data_in << (32 - t.amt));  // ROR
    default: extr.data_out = t.data_in;
  endcase
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
