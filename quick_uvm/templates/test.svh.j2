    fork
{% for inst in instances %}
      begin
        {{ inst.agent.name }}_seq{{ inst.pav }} {{ inst.name }}_seq;
        {{ inst.name }}_seq = {{ inst.agent.name }}_seq{{ inst.pav }}::type_id::create("{{ inst.name }}_seq");
        {{ inst.name }}_seq.start(e.{{ inst.handle }}.sqr);
      end
{% endfor %}
