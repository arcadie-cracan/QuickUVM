//----------------------------------------------------------------------
// The predictor:
//   - subscribes to the monitor's analysis port
//   - ignores sampled DUT outputs
//   - calls predict() to predict the expected output
//   - writes the predicted transaction to results_ap
//----------------------------------------------------------------------

class memslave_zs_predictor extends uvm_subscriber #(mem_seq_item);
  `uvm_component_utils(memslave_zs_predictor)

  uvm_analysis_port #(mem_seq_item) results_ap;

  // pragma quickuvm custom class_item_additional begin
  // Expected data is computed from the REQUEST ADDRESS by our own memory model — NOT from
  // the rdata observed on the bus. Deriving it from the observed value would be a
  // tautology: it could never fail for a responder that answers WRONG.
  bit [31:0] m_last;
  int        m_grants;      // requests the responder actually granted
  int        m_fetched;     // the DUT's completed-transfer count

  function bit [31:0] mem_model(bit [7:0] a);
    return {24'h0, a} ^ 32'hA5A5_A5A5;
  endfunction

  // LIVENESS, independent of the driver's own generated DEAD_RESPONDER check. A responder
  // that is merely TOO LATE is alive (it drives every cycle) but useless: the DUT captures
  // nothing. `missed` is the DUT's own count of grants that arrived after it had moved on
  // — the thing that makes the zero-slack failure VISIBLE rather than silent.
  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (m_grants == 0)
      `uvm_error("DEAD_RESPONDER",
                 "the responder never granted a single request — the device is dead")
    if (m_fetched == 0)
      `uvm_error("NO_PROGRESS",
                 "the DUT completed ZERO transfers — every response arrived TOO LATE. \
This is what a sequencer-mediated response looks like against a DUT that will not wait.")
  endfunction
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write(mem_seq_item t);
    mem_seq_item exp_tr;
    exp_tr = predict(t);
    results_ap.write(exp_tr);
  endfunction

  extern function mem_seq_item predict(mem_seq_item t);

endclass
