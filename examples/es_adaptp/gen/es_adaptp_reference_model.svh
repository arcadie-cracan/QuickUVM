//----------------------------------------------------------------------
// Implement es_adaptp_predictor::predict() here.
// This function receives the sampled transaction (inputs + outputs as
// driven to/from DUT) and must return a NEW transaction with the
// EXPECTED output values filled in.
//
// Edit the "prediction_logic" user section below.
//----------------------------------------------------------------------
// WINDOWED single-stream scoreboard: predict() accumulates a window of samples and emits
// ONE verdict per window, keyed off the DUT's `window_done` strobe. The
// generator carries the sample counter, the boundary keying, the copy-through cadence,
// and the DUAL window-length liveness (a boundary at the wrong count AND a window that
// never closes both fail — the strobe is not a guard trusting only itself). You fill only
// the domain accumulate + verdict below. See docs/es_adaptp_assessment.md.
function es_item es_adaptp_predictor::predict(es_item t);
  es_item extr = es_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy-through: on every NON-boundary cycle expected == actual (a trivial pass); the
  // verdict override on the boundary cycle is the only meaningful compare per window.
  extr.copy(t);

  // pragma quickuvm custom window_accumulate begin
  // ADAPTP: add this symbol's 1-bit count to the running window total. Pin the latched
  // alert into extr so its held level is verified on every (non-boundary) cycle too.
  for (int i = 0; i < SYMW; i++) m_osum += t.sample[i];
  extr.alert = m_alert;
  // pragma quickuvm custom window_accumulate end

  m_wcount++;   // samples seen in this window
  if (t.window_done) begin
    // The DUT closed a window. Independent length check: a boundary at the wrong sample
    // count is an error, not a silent pass.
    if (m_wcount != 8)
      `uvm_error("SB_WINDOW", $sformatf(
        "window closed after %0d samples, expected 8", m_wcount))
    // pragma quickuvm custom window_verdict begin
    // ADAPTP verdict (strict, like the RTL): the window fails if its 1-bit count is out
    // of [LO, HI]. Cross-window: a fail extends the run and latches the alert at ALERTN;
    // a pass resets the run (m_alert stays latched). Override the verdict outputs, reset
    // the per-window accumulator.
    begin
      bit fail_now;
      int eff_run;
      fail_now = (m_osum > HI) || (m_osum < LO);
      eff_run  = fail_now ? m_failrun + 1 : 0;
      if (eff_run >= ALERTN) m_alert = 1'b1;
      extr.ones_cnt  = 16'(m_osum);
      extr.test_fail = fail_now;
      extr.alert     = m_alert;
      m_failrun = fail_now ? m_failrun + 1 : 0;
      m_osum    = 0;
    end
    // pragma quickuvm custom window_verdict end
    m_wcount = 0;
    m_windows++;   // a window closed (see the predictor's check_phase)
  end
  else begin
    // No boundary this cycle. Independent liveness: a window that never closes (a stuck
    // strobe) must fail HERE — the check the boundary guard above cannot make — so a
    // never-strobing DUT is caught, not silently copy-through forever.
    if (m_wcount > 8)
      `uvm_error("SB_WINDOW", $sformatf(
        "no boundary after %0d samples (expected every 8)", m_wcount))
  end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
