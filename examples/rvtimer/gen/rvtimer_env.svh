class rvtimer_env extends uvm_env;
  `uvm_component_utils(rvtimer_env)

  // Agent handles
  host_agent  host_agnt;
  irq_agent  irq_agnt;

  // Scoreboards
  rvtimer_scoreboard reg_sb;

  // Functional coverage (per agent)
  host_cov host_cov_h;

  // Environment configuration
  rvtimer_env_cfg env_cfg;

  // Register model front-door adapter + predictor
  reg_adapter bus_adapter;
  uvm_reg_predictor #(host_seq_item) reg_predictor;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(rvtimer_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No rvtimer_env_cfg set for: ", get_full_name()})
    uvm_config_db#(host_cfg)::set(this, "host_agnt", "cfg", env_cfg.host_cfg);
    host_agnt = host_agent::type_id::create("host_agnt", this);
    uvm_config_db#(irq_cfg)::set(this, "irq_agnt", "cfg", env_cfg.irq_cfg);
    irq_agnt = irq_agent::type_id::create("irq_agnt", this);
    reg_sb = rvtimer_scoreboard::type_id::create("reg_sb", this);
    host_cov_h = host_cov::type_id::create("host_cov_h", this);
    bus_adapter = reg_adapter::type_id::create("bus_adapter");
    reg_predictor = uvm_reg_predictor#(host_seq_item)::type_id::create("reg_predictor", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Declared analysis connectivity (per analysis: block)
    host_agnt.ap.connect(reg_sb.axp);
    host_agnt.ap.connect(host_cov_h.analysis_export);
    // Register model front-door: bind the map to the bus agent's sequencer
    env_cfg.reg_model.default_map.set_sequencer(host_agnt.sqr, bus_adapter);
    reg_predictor.map     = env_cfg.reg_model.default_map;
    reg_predictor.adapter = bus_adapter;
    host_agnt.ap.connect(reg_predictor.bus_in);
    env_cfg.reg_model.default_map.set_auto_predict(0);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
