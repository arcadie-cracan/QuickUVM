class dbl_env extends uvm_env;
  `uvm_component_utils(dbl_env)

  // Agent handles
  d_agent  d_agnt;

  // Scoreboard (wired to primary agent: d)
  dbl_scoreboard sbd;

  // Functional coverage (wired to primary agent: d)
  d_cov cov;

  // Environment configuration
  dbl_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(dbl_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No dbl_env_cfg set for: ", get_full_name()})
    uvm_config_db#(d_cfg)::set(this, "d_agnt", "cfg", env_cfg.d_cfg);
    d_agnt = d_agent::type_id::create("d_agnt", this);
    sbd  = dbl_scoreboard::type_id::create("sbd",  this);
    cov  = d_cov::type_id::create("cov",  this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Primary agent → scoreboard + coverage
    d_agnt.ap.connect(sbd.axp);
    d_agnt.ap.connect(cov.analysis_export);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
