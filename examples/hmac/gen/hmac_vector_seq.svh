// S2 library sequence — kind 'directed' for agent 'host'.

class hmac_vector_seq extends uvm_sequence #(host_seq_item);
  `uvm_object_utils(hmac_vector_seq)

  // pragma quickuvm custom class_item_additional begin
  // One register-bus transaction.
  task automatic do_reg(bit [11:0] a, bit w, bit [31:0] d);
    host_seq_item tr = host_seq_item::type_id::create("tr");
    start_item(tr);
    tr.addr  = a;
    tr.wr    = w;
    tr.req   = 1'b1;
    tr.wdata = d;
    finish_item(tr);
  endtask
  // pragma quickuvm custom class_item_additional end

  function new (string name = "hmac_vector_seq");
    super.new(name);
  endfunction

  // Item count — a test may override it via `sequence: {... count: N}` (S2).
  int unsigned count = 100;

  // 'directed' sequence — write the body below. The default skeleton
  // drives `count` randomized item(s); replace it with the
  // directed stimulus.
  task body;
    host_seq_item tr = host_seq_item::type_id::create("tr");
    `uvm_info("body", "hmac_vector_seq (directed): starting", UVM_FULL)
    // pragma quickuvm custom body begin
    // RFC 4231 Test Case 1 driven end to end through the generated agent.
    //   key = 0x0b x20, msg = "Hi There"
    //   HMAC-SHA-256 = b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7
    // Nothing here checks the digest — the GENERATED scoreboard does, against the C
    // golden model in the predictor. That is the experiment.
    begin
      // CFG: hmac_en=1, sha_en=1, digest_size=SHA2_256, key_length=Key_256
      do_reg(12'h000, 1'b1, (32'h1 << 0) | (32'h1 << 1) | (32'h1 << 5) | (32'h2 << 9));

      // KEY_0..4 = 0x0b0b0b0b (20 key bytes), KEY_5..7 = 0
      for (int i = 0; i < 5; i++) do_reg(12'h020 + 12'(4*i), 1'b1, 32'h0b0b0b0b);
      for (int i = 5; i < 8; i++) do_reg(12'h020 + 12'(4*i), 1'b1, 32'h0);

      do_reg(12'h004, 1'b1, 32'h1);            // CMD.hash_start

      do_reg(12'h100, 1'b1, 32'h5420_6948);    // MSG_FIFO <- "Hi T"
      do_reg(12'h100, 1'b1, 32'h6572_6568);    // MSG_FIFO <- "here"

      do_reg(12'h004, 1'b1, 32'h2);            // CMD.hash_process  (the TRIGGER)

      // Let the engine finish, then read the digest back. Each DIGEST read is a
      // transaction the scoreboard checks against the golden model.
      //
      // HMAC-SHA-256 runs an INNER and an OUTER hash (several 64-round blocks), so this
      // takes hundreds of cycles. Reading DIGEST too early returns the SHA-256 initial
      // constants (6a09e667, bb67ae85, ...) — a very recognisable "you read it mid-flight"
      // signature. One bus transaction per cycle, so spin well past the worst case.
      repeat (600) do_reg(12'h008, 1'b0, 32'h0);         // poll STATUS (idle spin)
      for (int i = 0; i < 8; i++) do_reg(12'h0a0 + 12'(4*i), 1'b0, 32'h0);  // DIGEST_i
    end
    // pragma quickuvm custom body end
  endtask

endclass
