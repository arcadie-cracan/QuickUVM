    super.build_phase(phase);
    if (!uvm_config_db#(b_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", {"No b_cfg set for: ", get_full_name()})
    is_active = cfg.is_active;
    vif       = cfg.vif;
    if (is_active == UVM_ACTIVE) begin
      drv = b_driver::type_id::create("drv", this);
      sqr = b_sequencer::type_id::create("sqr", this);
    end
    mon = b_monitor::type_id::create("mon", this);
    ap  = new("ap", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

