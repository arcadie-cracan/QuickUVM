class alu_cov extends uvm_subscriber #(alu_seq_item);
  `uvm_component_utils(alu_cov)

  alu_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    option.goal         = 90;
    op_cp : coverpoint tr.op {
      ignore_bins slt_wip = {7};
    }
    a_cp : coverpoint tr.a {
      bins zero = {0};
      bins max = {255};
      bins mid = {[1:254]};
    }
    b_cp : coverpoint tr.b {
      bins zero = {0};
      bins max = {255};
      bins mid = {[1:254]};
    }
    carry_cp : coverpoint tr.carry {
      bins lo = {0};
      bins hi = {1};
      bins rise = (0 => 1);
      bins fall = (1 => 0);
    }
    op_x_a : cross op_cp, a_cp;
    op_x_b : cross op_cp, b_cp;
    add_corners : cross op_cp, a_cp {
      bins add_at_corner = binsof(op_cp) intersect {ADD} && !binsof(a_cp.mid);
      ignore_bins skip_mid = binsof(a_cp.mid);
    }

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (alu_seq_item t);
    tr = t;
    `uvm_info("alu_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
