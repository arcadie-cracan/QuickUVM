class dsoc_vseq extends dsoc_base_vseq;
  `uvm_object_utils(dsoc_vseq)

  function new (string name = "dsoc_vseq");
    super.new(name);
  endfunction

  task body;
    left_lane_vseq left_seq;
    right_lane_vseq right_seq;

    left_seq = left_lane_vseq::type_id::create("left_seq");
    right_seq = right_lane_vseq::type_id::create("right_seq");
    // pragma quickuvm custom vseq_body_pre begin
    // pragma quickuvm custom vseq_body_pre end
    // Run every block's stimulus concurrently
    fork
      left_seq.start(p_sequencer.left_vsqr);
      right_seq.start(p_sequencer.right_vsqr);
    join
    // pragma quickuvm custom vseq_body_post begin
    // pragma quickuvm custom vseq_body_post end
  endtask

endclass
