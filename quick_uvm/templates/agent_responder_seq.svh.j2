//----------------------------------------------------------------------
// The FOREVER responder sequence for reactive agent '{{ agent.name }}'.
//
// This is where the reactivity lives — NOT in the driver. The flow per transfer:
//
//   DUT drives a request
//     -> the monitor decodes it and writes it to `request_ap`
//     -> the sequencer's TLM FIFO buffers it
//     -> THIS sequence's blocking get() unblocks
//     -> it computes a response
//     -> start_item/finish_item hand that response to the driver
//     -> the driver drives the response pins
//
// Keeping the decode in the MONITOR (which must already decode the protocol for passive
// mode) is why the driver does not have to. The tempting alternative — a driver that
// decodes the request itself — duplicates that logic and is rejected; see
// docs/reactive_agent_investigation.md.
//
// It runs in main_phase as the sequencer's default_sequence and must NEVER raise an
// objection: it is a service, not stimulus. A responder that ends leaves the DUT hanging.
//----------------------------------------------------------------------

class {{ agent.responder_seq_name }}{{ agent.param_decl }} extends uvm_sequence #({{ agent.sequence_item }}{{ agent.param_args }});
  `uvm_object_{{ 'param_' if agent.parameters else '' }}utils({{ agent.responder_seq_name }}{{ agent.param_args }})

  `uvm_declare_p_sequencer({{ agent.name }}_sequencer{{ agent.param_args }})

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name = "{{ agent.responder_seq_name }}");
    super.new(name);
  endfunction

  task body;
    {{ agent.sequence_item }}{{ agent.param_args }} req;
    {{ agent.sequence_item }}{{ agent.param_args }} rsp;

{% if agent.is_prefetch %}
    forever begin
      // PREFETCH: we do NOT wait for a request. A full-duplex device drives its response
      // on the same edge it samples the request, so the response cannot depend on the
      // request it accompanies — the driver must already hold an item when the first edge
      // arrives. This sequence runs AHEAD of the bus, keeping one queued.
      //
      // The response is a function of PREVIOUS transfers, not the current one. Keep that
      // state here (or in the driver — it is a class too).
      rsp = {{ agent.sequence_item }}{{ agent.param_args }}::type_id::create("rsp");

      // THE USER SEAM. Fill in what this device will send on the NEXT transfer.
      // pragma quickuvm custom prefetch_response begin
      // pragma quickuvm custom prefetch_response end

      start_item(rsp);
      finish_item(rsp);
    end
  endtask

endclass
{% elif agent.is_pipelined %}
    {{ agent.sequence_item }}{{ agent.param_args }} in_req;

    // PIPELINED: many requests OUTSTANDING, answered OUT OF ORDER by `{{ agent.reorder_by }}`.
    //
    // Two threads, because the `on_request` loop (get -> respond -> get) drives exactly
    // ONE response per incoming request and STRANDS a burst: after draining the backlog
    // it blocks on a NEW request that never comes (docs/t6_axi_outstanding_assessment.md).
    // Here the ACCEPT thread buffers every request the instant the monitor publishes it;
    // the DRIVE thread empties the buffer WITHOUT waiting on the bus, so it can answer a
    // backlog N deep. This is axi_rand_slave's accept/serve split.
    //
    // Ordering: same-ID responses stay in arrival order (`pop_front`); cross-ID is free to
    // reorder — the AXI rule. `outstanding` counts total buffered, so `outstanding > 0`
    // means some queue is non-empty.
    {{ agent.sequence_item }}{{ agent.param_args }} id_q[int][$];  // per-ID request queues
    int outstanding;
{% if agent.reorder_policy == "round_robin" %}
    int m_last_id = -1;   // round-robin cursor: the id served last (-1 => below every id)
{% endif %}

    fork
      // ACCEPT. Never blocks the drive side — the backlog grows to whatever the DUT floats.
      forever begin
        p_sequencer.request_fifo.get(in_req);
        id_q[int'(in_req.{{ agent.reorder_by }})].push_back(in_req);
        outstanding++;
        p_sequencer.m_accepted++;   // liveness: the sequencer checks accepted == answered
      end
      // DRIVE. Answers the backlog; does NOT block on a new request. THIS is the loop the
      // on_request shape could not express.
      forever begin
        int ready[$];
        int pick;
        wait (outstanding > 0);
        foreach (id_q[i]) if (id_q[i].size() > 0) ready.push_back(i);
{% if agent.reorder_policy == "round_robin" %}
        // Cross-ID reorder policy (reorder_policy: round_robin): the next ready id after
        // the one served last, wrapping — a fair rotation, so no id can starve.
        pick = -1;
        foreach (ready[i])
          if (ready[i] > m_last_id && (pick == -1 || ready[i] < pick)) pick = ready[i];
        if (pick == -1) begin  // nothing above the cursor -> wrap to the lowest ready id
          pick = ready[0];
          foreach (ready[i]) if (ready[i] < pick) pick = ready[i];
        end
        m_last_id = pick;
{% elif agent.reorder_policy == "random" %}
        // Cross-ID reorder policy (reorder_policy: random): any ready id, uniformly —
        // the unpredictable slave (matches PULP's axi_rand_slave).
        pick = ready[$urandom_range(0, ready.size() - 1)];
{% else %}
        // Cross-ID reorder policy (reorder_policy: priority): lowest ready id first.
        pick = ready[0];
        foreach (ready[i]) if (ready[i] < pick) pick = ready[i];
{% endif %}
        req = id_q[pick].pop_front();
        outstanding--;

        rsp = {{ agent.sequence_item }}{{ agent.param_args }}::type_id::create("rsp");
        rsp.copy(req);   // seed the response from the request (id/addr/tag preserved)

        // THE USER SEAM — identical to `on_request`: build the response from `req`. A
        // memory model, a protocol response, an error policy. The default echo is almost
        // never right. No generator emits protocol logic; switching on_request<->pipelined
        // preserves whatever you write here.
        // pragma quickuvm custom response_logic begin
        // pragma quickuvm custom response_logic end

        start_item(rsp);
        finish_item(rsp);
        p_sequencer.m_answered++;   // liveness: counted once the driver has taken it
      end
    join
  endtask

endclass
{% else %}
    forever begin
      // Blocks until the DUT issues a request (qualified by `{{ agent.request_valid }}`).
      p_sequencer.request_fifo.get(req);

      rsp = {{ agent.sequence_item }}{{ agent.param_args }}::type_id::create("rsp");
      rsp.copy(req);   // seed the response from the request (addr/tag/etc. preserved)

      // THE USER SEAM. Compute the response from `req` — this is where a memory model, a
      // protocol response, or an error-injection policy goes. The default below is an
      // echo: it drives back whatever the request carried, which is almost certainly not
      // what your protocol wants.
      //
      // Nothing here is generatable: no generator emits protocol logic (OpenTitan's own
      // uvmdvgen ships an EMPTY get_and_drive()). The scaffold is ours; the response is yours.
      // pragma quickuvm custom response_logic begin
      // pragma quickuvm custom response_logic end

      start_item(rsp);
      finish_item(rsp);
    end
  endtask

endclass
{% endif %}
