{% if test.sequence and test.sequence.count %}
    seq.count = {{ test.sequence.count }};   // per-test count override (S2)
{% endif %}
    //----------------------------------------------------
    phase.raise_objection(this);
    `uvm_info("{{ test.name }}", "about to start seq", UVM_FULL)
    seq.start({{ seq_start }});
    // pragma quickuvm custom run_phase_additional begin
    // pragma quickuvm custom run_phase_additional end
