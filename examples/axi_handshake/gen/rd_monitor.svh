class rd_monitor extends uvm_monitor;
  `uvm_component_utils(rd_monitor)

  virtual rd_if vif;

  uvm_analysis_port #(rd_item) ap;
  // Reactive agent: publish the DUT's REQUEST as soon as it is decoded, on a SECOND
  // port. The responder sequence blocks on this (via the sequencer's TLM FIFO) and
  // computes the response. The monitor already decodes the protocol for passive mode,
  // so this duplicates nothing — which is exactly why the driver does NOT decode it.
  uvm_analysis_port #(rd_item) request_ap;

  // pragma quickuvm custom class_item_additional begin
  // UVM-side HANDSHAKE ORACLE (the automated verdict is UVM-severity based, so the DUT's own
  // $error is invisible to it). Count the AR and R transfers INDEPENDENTLY of the request-
  // publish: if the request-capture ever loses a back-to-back transfer, fewer responses are
  // driven than requests accepted, and m_r_xfer < m_ar_xfer at end of test.
  int m_ar_xfer;   // AR handshakes observed (arvalid && arready)
  int m_r_xfer;    // R  handshakes observed (rvalid  && rready)

  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (m_ar_xfer == 0)
      `uvm_error("HS_CHK", "no AR handshake observed — vacuous test")
    if (m_r_xfer != m_ar_xfer)
      `uvm_error("HS_CHK", $sformatf(
        "R transfers (%0d) != AR transfers (%0d): the request handshake lost transfers",
        m_r_xfer, m_ar_xfer))
  endfunction
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
    request_ap = new("request_ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    rd_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      // The DUT issued a request -> hand it to the responder sequence.
      // HANDSHAKE capture: `arvalid` is HELD until `arready`,
      // and EACH cycle both are high is a DISTINCT transfer (back-to-back requests under a held
      // valid). So publish on the LEVEL of valid && ready, once per handshake cycle — an
      // edge-detect would see only the first of a back-to-back burst. (valid & ready are
      // co-observed at one edge: sample_dut re-samples a driven ready with the outputs.)
      if (tr.arvalid && tr.arready) request_ap.write(tr);
      ap.write(tr);
    end
  endtask

  task sample_dut (output rd_item tr);
    rd_item t;
    t = rd_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------
    t.rvalid = vif.rvalid;
    t.rid = vif.rid;
    t.rdata = vif.rdata;
    t.arready = vif.arready;

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.arvalid = vif.cb1.arvalid;
    t.arid = vif.cb1.arid;
    t.araddr = vif.cb1.araddr;
    t.rready = vif.cb1.rready;
    // request_ready is a line WE drive (a slave's own ready), but the handshake capture ANDs
    // it with the DUT-output request_valid. Re-sample it HERE (raw net, with the outputs) so
    // both qualifiers are co-observed at THIS edge — otherwise the split sampling reads it a
    // cycle early and a back-to-back transfer is dropped.
    t.arready = vif.arready;

    // pragma quickuvm custom sample_dut_additional begin
    // The AR handshake qualifiers are already co-observed: request_valid (arvalid) with the
    // outputs, and the driven request_ready (arready) re-sampled alongside them above. The R
    // handshake needs the same: rready is cb1-sampled but rvalid is DRIVEN, so re-sample rvalid
    // raw here to co-observe both at this posedge.
    t.rvalid = vif.rvalid;
    // UVM oracle counts (see class_item_additional), all qualifiers aligned at this posedge.
    if (t.arvalid && t.arready) m_ar_xfer++;
    if (t.rvalid && t.rready) m_r_xfer++;
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
