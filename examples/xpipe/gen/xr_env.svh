class xr_env extends uvm_env;
  `uvm_component_utils(xr_env)

  // Agent handles
  x_agent  x_agnt;

  // Scoreboard (wired to primary agent: x)
  xr_scoreboard sbd;

  // Functional coverage (wired to primary agent: x)
  x_cov cov;

  // Environment configuration
  xr_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
