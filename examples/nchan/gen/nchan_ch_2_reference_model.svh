function ch_item nchan_ch_2_predictor::predict(ch_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  ch_item extr = ch_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Per-channel latch: q holds the last d captured on v. This is ONE of N identical
  // per-channel scoreboards (the `count` replicas share this reference-model logic); each
  // checks its own slice of the DUT's vectored ports. d/v/q are mutually consistent within
  // a transaction (all reflect the same driven cycle), so no re-sample is needed.
  if (t.v) m_last = t.d;
  extr.q = m_last;
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
