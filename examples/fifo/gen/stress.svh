class stress extends test_base;
  `uvm_component_utils(stress)

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
    super.build_phase(phase);
  endfunction

  task run_phase(uvm_phase phase);
    stress_vseq seq;
    seq = stress_vseq::type_id::create("seq");
    //----------------------------------------------------
    phase.raise_objection(this);
    `uvm_info("stress", "about to start seq", UVM_FULL)
    seq.start(e.vsqr);
    // pragma quickuvm custom run_phase_additional begin
    // Concurrent write/read soak: writes and reads interleave per cycle, so a
    // strict in-order reconstruction would need a cycle-aligned multi-stream
    // scoreboard (roadmap A2). Here we soak-check: the run completed and no read
    // returned X while the FIFO was non-empty.
    begin
      wr_seq_item wt;
      rd_seq_item rt;
      int unsigned nwr = 0, nrd = 0, nx = 0;
      #200;
      while (e.wr_fifo.try_get(wt)) if (wt.wr_en) nwr++;
      while (e.rd_fifo.try_get(rt))
        if (rt.rd_en && rt.empty === 1'b0 && $isunknown(rt.rd_data)) nx++;
        else if (rt.rd_en) nrd++;
      `uvm_info("FIFO_SB",
        $sformatf("stress soak: %0d writes, %0d reads, %0d bad-X reads", nwr, nrd, nx),
        UVM_LOW)
      if (nx > 0) `uvm_error("FIFO_SB", "rd_data X while FIFO not empty")
    end
    // pragma quickuvm custom run_phase_additional end
    phase.drop_objection(this);
  endtask

endclass
