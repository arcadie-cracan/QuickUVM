class sndr_sequencer extends uvm_sequencer #(sndr_item);
  `uvm_component_utils(sndr_sequencer)

  // Reactive agent: the monitor's request port feeds this FIFO, which exists ONLY to give
  // the responder sequence a BLOCKING get. It is a rendezvous, not a backlog buffer.
  uvm_analysis_export #(sndr_item) request_export;
  uvm_tlm_analysis_fifo #(sndr_item) request_fifo;

  function new (string name, uvm_component parent);
    super.new(name, parent);
    request_export = new("request_export", this);
    request_fifo   = new("request_fifo", this);
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    request_export.connect(request_fifo.analysis_export);
  endfunction

  // HYBRID responder liveness — deliberately NOT in a pragma, and NOT the driver's
  // DEAD_RESPONDER. This agent also drives PROACTIVE stimulus, so the driver's drive count
  // is inflated: a dead responder would still look like it "drove something". The request
  // FIFO, though, is fed only by observed requests and drained only by the responder
  // sequence — proactive stimulus never touches it. So an unanswered request always shows:
  // fail if any request the monitor observed was never drained.
  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (request_fifo.used() != 0)
      `uvm_error("DEAD_RESPONDER",
                 $sformatf({"%0d observed request(s) were never answered — the responder ",
                            "is dead or lagging. A hybrid's liveness is the request-FIFO ",
                            "drain, not the driver's drive count (proactive stimulus ",
                            "inflates that)."},
                           request_fifo.used()))
  endfunction

endclass
