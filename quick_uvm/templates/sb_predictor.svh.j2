{% set pa = agents[0] %}

class sb_predictor extends uvm_subscriber #({{ pa.transaction }});
  `uvm_component_utils(sb_predictor)

  uvm_analysis_port #({{ pa.transaction }}) results_ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write({{ pa.transaction }} t);
    {{ pa.transaction }} exp_tr;
    exp_tr = sb_calc_exp(t);
    results_ap.write(exp_tr);
  endfunction

  extern function {{ pa.transaction }} sb_calc_exp({{ pa.transaction }} t);

endclass
