class wr_agent extends uvm_agent;
  `uvm_component_utils(wr_agent)

  // is_active is inherited from uvm_agent; set from cfg in build_phase
  wr_cfg  cfg;
  virtual wr_if vif;

  uvm_analysis_port #(wr_item) ap;
  wr_driver     drv;
  wr_monitor    mon;
  wr_sequencer  sqr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  virtual function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(wr_cfg)::get(this, "", "cfg", cfg))
      `uvm_fatal("NOCFG", {"No wr_cfg set for: ", get_full_name()})
    is_active = cfg.is_active;
    vif       = cfg.vif;
    if (is_active == UVM_ACTIVE) begin
      drv = wr_driver::type_id::create("drv", this);
      sqr = wr_sequencer::type_id::create("sqr", this);
    end
    mon = wr_monitor::type_id::create("mon", this);
    ap  = new("ap", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  // The agent OWNS its responder. Forked here rather than set as a phase
  // `default_sequence`, because a phase sequence is KILLED when its phase ends — and a
  // responder must raise no objection (it is a service, not stimulus), so it would be
  // torn down instantly unless something else happened to keep that phase alive. Forking
  // it from the agent removes the phase/objection coupling entirely: the device answers
  // for as long as the simulation runs, with no test-side code.
  //
  // Created through the factory, so an error-injecting or delaying responder can still be
  // swapped in with a type override.
  task run_phase(uvm_phase phase);
    wr_responder_seq responder;
    if (is_active == UVM_ACTIVE) begin
      // Created WITH CONTEXT (get_full_name()), or a per-instance factory override would
      // silently no-op and the swap-in-an-error-injector story would be a lie.
      responder = wr_responder_seq::type_id::create(
          "responder", null, get_full_name());
      responder.start(sqr);
    end
  endtask

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    if (is_active == UVM_ACTIVE) begin
      drv.seq_item_port.connect(sqr.seq_item_export);
      drv.vif = vif;
      // Reactive: the request travels monitor -> sequencer FIFO -> responder sequence.
      // Gated on is_active, so a PASSIVE responder is just a monitor (the analysis ports
      // tolerate zero subscribers).
      mon.request_ap.connect(sqr.request_export);
    end
    mon.ap.connect(ap);
    mon.vif = vif;
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
