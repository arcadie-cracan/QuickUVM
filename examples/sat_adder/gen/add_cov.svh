class add_cov extends uvm_subscriber #(add_seq_item);
  `uvm_component_utils(add_cov)

  add_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    sum_cp : coverpoint tr.sum {bins sum_bins[8] = {[0:$]};}
    ovf_cp : coverpoint tr.ovf {bins ovf_bins[8] = {[0:$]};}
    a_cp : coverpoint tr.a {bins a_bins[8] = {[0:$]};}
    b_cp : coverpoint tr.b {bins b_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (add_seq_item t);
    tr = t;
    `uvm_info("add_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
