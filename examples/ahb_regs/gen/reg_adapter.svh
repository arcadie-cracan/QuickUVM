  // Bus transaction -> register operation
  virtual function void bus2reg(uvm_sequence_item bus_item, ref uvm_reg_bus_op rw);
    ahb_seq_item tr;
    if (!$cast(tr, bus_item)) begin
      `uvm_fatal("REG_ADAPTER", "bus2reg: unexpected bus item type")
      return;
    end
    // pragma quickuvm custom bus2reg begin
    rw.kind   = tr.HWRITE ? UVM_WRITE : UVM_READ;
    rw.addr   = tr.HADDR;
    rw.data   = tr.HWRITE ? tr.HWDATA : tr.HRDATA;   // a read returns the captured HRDATA
    rw.status = tr.HRESP ? UVM_NOT_OK : UVM_IS_OK;
    // pragma quickuvm custom bus2reg end
  endfunction

