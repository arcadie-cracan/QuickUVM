class pe_cover extends uvm_subscriber #(pe_seq_item);
  `uvm_component_utils(pe_cover)

  pe_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    idx_cp : coverpoint tr.idx {bins idx_bins[8] = {[0:$]};}
    valid_cp : coverpoint tr.valid {bins valid_bins[8] = {[0:$]};}
    req_cp : coverpoint tr.req {bins req_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (pe_seq_item t);
    tr = t;
    `uvm_info("pe_cover", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
