class spi_cov extends uvm_subscriber #(spi_item);
  `uvm_component_utils(spi_cov)

  spi_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    csb_cp : coverpoint tr.csb {bins csb_bins[8] = {[0:$]};}
    mosi_cp : coverpoint tr.mosi {bins mosi_bins[8] = {[0:$]};}
    rx_byte_cp : coverpoint tr.rx_byte {bins rx_byte_bins[8] = {[0:$]};}
    frame_cnt_cp : coverpoint tr.frame_cnt {bins frame_cnt_bins[8] = {[0:$]};}
    miso_cp : coverpoint tr.miso {bins miso_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (spi_item t);
    tr = t;
    `uvm_info("spi_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
