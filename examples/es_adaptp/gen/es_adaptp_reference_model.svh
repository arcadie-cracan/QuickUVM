// Implement es_adaptp_predictor::predict() here.
// This function receives the sampled transaction (inputs + outputs as
// driven to/from DUT) and must return a NEW transaction with the
// EXPECTED output values filled in.
//
// Edit the "prediction_logic" user section below.
//----------------------------------------------------------------------

function es_item es_adaptp_predictor::predict(es_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  es_item extr = es_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // ---- the WINDOWED ADAPTP golden model ---------------------------------------
  // `extr` is already a copy of the observed transaction, so on every NON-boundary
  // cycle expected == actual and the compare is a trivial pass. On the BOUNDARY cycle
  // we override the verdict fields with the independently-accumulated golden values, so
  // the check bites exactly once per window. State persists across calls (predictor
  // members); this is the N:1 windowed statistic folded into the 1:1 predict() seam.
  //
  // Reset is not a transaction field here (nothing samples rst_n), and these tests hold
  // no mid-test reset — with emit_when:valid, the first item the predictor sees is the
  // first live sample after reset, so the members (default 0) are already in lockstep
  // with the DUT's cleared counters.
  // The window BOUNDARY is taken from the DUT's own window_done strobe (which delimits the
  // windows in the emitted stream); the STATISTIC and verdict are computed INDEPENDENTLY
  // from the accumulated samples, so a broken threshold/counter still fails the compare.
  // window_done is NOT a guard trusting only itself: an independent length check catches a
  // boundary that lands at the wrong sample count (a moved boundary), AND a separate check
  // in the non-boundary branch catches a window that never closes (a stuck-low strobe) —
  // so both "wrong boundary" and "no boundary" fail, not just silently copy-through.
  if (t.valid) begin
    int pc;
    pc = 0;
    for (int i = 0; i < SYMW; i++) pc += t.sample[i];   // 1-bits in this symbol
    m_osum   = m_osum + pc;
    m_scount = m_scount + 1;
    if (t.window_done) begin
      bit fail_now;
      int eff_run;
      if (m_scount != WINDOW)                            // boundary at the wrong count
        `uvm_error("ADAPTP_WIN", $sformatf(
          "window closed after %0d samples, expected %0d", m_scount, WINDOW))
      fail_now = (m_osum > HI) || (m_osum < LO);         // strict, like the RTL
      eff_run  = fail_now ? m_failrun + 1 : 0;
      if (eff_run >= ALERTN) m_alert = 1'b1;             // latch, stays until reset
      extr.ones_cnt  = 16'(m_osum);                      // the INDEPENDENT statistic
      extr.test_fail = fail_now;
      extr.alert     = m_alert;
      m_failrun = fail_now ? m_failrun + 1 : 0;
      m_scount = 0;
      m_osum   = 0;
    end else begin
      // mid-window: pin the latched alert level so it is still verified; the other
      // outputs copy-through (trivial pass — nothing to check until the window closes).
      // Liveness: a boundary must arrive every WINDOW samples. If none has come after
      // WINDOW+1 (one sample of startup slack), the DUT's window_done is stuck/dropped —
      // fail here instead of accumulating forever (this is the check the boundary guard
      // above cannot make, so a never-strobing DUT is caught, not silently passed).
      extr.alert = m_alert;
      if (m_scount > WINDOW + 1)
        `uvm_error("ADAPTP_WIN", $sformatf(
          "no window boundary after %0d samples (expected every %0d)", m_scount, WINDOW))
    end
  end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
