    uvm_config_db#(b0_env_cfg)::set(this, "e.cB.pb", "env_cfg", env_cfg.cB_cfg.pb_cfg);

    // Block: qb (b1)
    env_cfg.cB_cfg.qb_cfg = b1_env_cfg::type_id::create("qb_cfg");
    env_cfg.cB_cfg.qb_cfg.gb1_cfg = gb1_cfg::type_id::create("gb1_cfg");
    env_cfg.cB_cfg.qb_cfg.gb1_cfg.is_active = UVM_ACTIVE;
