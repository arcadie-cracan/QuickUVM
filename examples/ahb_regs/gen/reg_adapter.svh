  // Register operation -> bus transaction
  virtual function uvm_sequence_item reg2bus(const ref uvm_reg_bus_op rw);
    ahb_seq_item tr = ahb_seq_item::type_id::create("reg2bus_tr");
    // pragma quickuvm custom reg2bus begin
    tr.HADDR  = rw.addr;
    tr.HWRITE = (rw.kind == UVM_WRITE);
    tr.HWDATA = rw.data;
    tr.HTRANS = 2'b10;   // NONSEQ — a single non-sequential transfer
    // pragma quickuvm custom reg2bus end
