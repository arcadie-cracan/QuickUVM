class alu_cover extends uvm_subscriber #(alu_seq_item);
  `uvm_component_utils(alu_cover)

  alu_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    op_cp : coverpoint tr.op;
    a_cp : coverpoint tr.a {
      bins zero = {0};
      bins max = {255};
      bins mid = {[1:254]};
    }
    b_cp : coverpoint tr.b {
      bins zero = {0};
      bins max = {255};
      bins mid = {[1:254]};
    }
    carry_cp : coverpoint tr.carry;
    op_x_a : cross op_cp, a_cp;
    op_x_b : cross op_cp, b_cp;

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (alu_seq_item t);
    tr = t;
    `uvm_info("alu_cover", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
