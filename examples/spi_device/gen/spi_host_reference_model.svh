function spi_item spi_host_predictor::predict(spi_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  spi_item extr = spi_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // The host has completed `frame_cnt` frames. Frame N carried device_byte(N), so once
  // frame N has completed, rx_byte must hold it.
  if (extr.frame_cnt > 8'(m_frames)) begin
    m_frames = int'(extr.frame_cnt);
    m_expect = device_byte(m_frames - 1);
  end
  extr.rx_byte = m_expect;

  // Not modelled (echoed): csb/mosi/frame_cnt — the host's own program, not ours.
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
