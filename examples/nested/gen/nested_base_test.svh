      `uvm_fatal("NOVIF",
                 "No virtual interface 'cA_pa_ga0_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(a0_env_cfg)::set(this, "e.cA.pa", "env_cfg", env_cfg.cA_cfg.pa_cfg);

    // Block: qa (a1)
