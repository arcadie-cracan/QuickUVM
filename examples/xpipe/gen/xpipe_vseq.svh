// Top (subsystem) virtual sequence — fires each composed block's default
// sequence on that block's sequencer, all concurrently. Edit the body to
// coordinate cross-block scenarios.
//----------------------------------------------------------------------

class xpipe_vseq extends xpipe_base_vseq;
  `uvm_object_utils(xpipe_vseq)

  function new (string name = "xpipe_vseq");
    super.new(name);
  endfunction

  task body;
    stg1_vseq stg1_seq;
    stg2_vseq stg2_seq;

    stg1_seq = stg1_vseq::type_id::create("stg1_seq");
    stg2_seq = stg2_vseq::type_id::create("stg2_seq");
    // pragma quickuvm custom vseq_body_pre begin
    // pragma quickuvm custom vseq_body_pre end
    // Run every block's stimulus concurrently
    fork
      stg1_seq.start(p_sequencer.stg1_vsqr);
      stg2_seq.start(p_sequencer.stg2_vsqr);
    join
    // pragma quickuvm custom vseq_body_post begin
    // pragma quickuvm custom vseq_body_post end
  endtask

endclass
