                 "No virtual interface 'stg1_add_a_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(add_env_cfg)::set(this, "e.stg1.add", "env_cfg", env_cfg.stg1_cfg.add_cfg);

