class wr_cov extends uvm_subscriber #(wr_item);
  `uvm_component_utils(wr_cov)

  wr_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    awvalid_cp : coverpoint tr.awvalid {bins awvalid_bins[8] = {[0:$]};}
    awid_cp : coverpoint tr.awid {bins awid_bins[8] = {[0:$]};}
    awaddr_cp : coverpoint tr.awaddr {bins awaddr_bins[8] = {[0:$]};}
    wvalid_cp : coverpoint tr.wvalid {bins wvalid_bins[8] = {[0:$]};}
    wdata_cp : coverpoint tr.wdata {bins wdata_bins[8] = {[0:$]};}
    wlast_cp : coverpoint tr.wlast {bins wlast_bins[8] = {[0:$]};}
    bvalid_cp : coverpoint tr.bvalid {bins bvalid_bins[8] = {[0:$]};}
    bid_cp : coverpoint tr.bid {bins bid_bins[8] = {[0:$]};}
    bresp_cp : coverpoint tr.bresp {bins bresp_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (wr_item t);
    tr = t;
    `uvm_info("wr_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
