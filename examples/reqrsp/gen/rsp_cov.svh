class rsp_cov extends uvm_subscriber #(rsp_seq_item);
  `uvm_component_utils(rsp_cov)

  rsp_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    rsp_valid_cp : coverpoint tr.rsp_valid {bins rsp_valid_bins[8] = {[0:$]};}
    rsp_id_cp : coverpoint tr.rsp_id {bins rsp_id_bins[8] = {[0:$]};}
    rsp_data_cp : coverpoint tr.rsp_data {bins rsp_data_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (rsp_seq_item t);
    tr = t;
    `uvm_info("rsp_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
