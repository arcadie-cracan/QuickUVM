class fast_cov extends uvm_subscriber #(fast_item);
  `uvm_component_utils(fast_cov)

  fast_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    fast_dout_cp : coverpoint tr.fast_dout {bins fast_dout_bins[8] = {[0:$]};}
    fast_din_cp : coverpoint tr.fast_din {bins fast_din_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (fast_item t);
    tr = t;
    `uvm_info("fast_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
