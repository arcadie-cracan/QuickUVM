// S2 library sequence — kind 'directed' for agent 'es'.

class adaptp_vector_seq extends uvm_sequence #(es_item);
  `uvm_object_utils(adaptp_vector_seq)

  // pragma quickuvm custom class_item_additional begin
  localparam int WINDOW = 8;   // must match rtl/es_adaptp.sv

  // Drive one entropy symbol.
  task automatic do_sym(bit [3:0] s);
    es_item tr = es_item::type_id::create("tr");
    start_item(tr);
    tr.sample = s;
    tr.valid  = 1'b1;
    finish_item(tr);
  endtask

  // Drive a whole window of the same symbol (so its 1-bit count is deterministic).
  task automatic do_win(bit [3:0] s);
    repeat (WINDOW) do_sym(s);
  endtask
  // pragma quickuvm custom class_item_additional end

  function new (string name = "adaptp_vector_seq");
    super.new(name);
  endfunction

  // Item count — a test may override it via `sequence: {... count: N}` (S2).
  int unsigned count = 100;

  // 'directed' sequence — write the body below. The default skeleton
  // drives `count` randomized item(s); replace it with the
  // directed stimulus.
  task body;
    es_item tr = es_item::type_id::create("tr");
    `uvm_info("body", "adaptp_vector_seq (directed): starting", UVM_FULL)
    // pragma quickuvm custom body begin
    // Each window is 8 symbols of one value, so its 1-bit count (per-symbol popcount x8)
    // is exact. Thresholds are LO=8, HI=24, ALERT_THRESH=2 consecutive fails.
    `uvm_info("body", "adaptp directed windows starting", UVM_LOW)
    do_win(4'h5);   // 2 ones x8 = 16 -> PASS
    do_win(4'h0);   // 0 ones x8 =  0 -> FAIL_LO   (run=1)
    do_win(4'h0);   // 0 ones x8 =  0 -> FAIL_LO   (run=2 -> ALERT latches)
    do_win(4'h5);   // 2 ones x8 = 16 -> PASS      (run resets; alert stays latched)
    do_win(4'hF);   // 4 ones x8 = 32 -> FAIL_HI   (run=1)
    do_win(4'h7);   // 3 ones x8 = 24 -> PASS      (== HI; strict > so pass) HI-edge
    do_win(4'h1);   // 1 one  x8 =  8 -> PASS      (== LO; strict < so pass) LO-edge
    // pragma quickuvm custom body end
  endtask

endclass
