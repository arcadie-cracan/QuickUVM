  `uvm_object_utils(wr_push)

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name = "wr_push");
    super.new(name);
  endfunction

  // Item count — a test may override it via `sequence: {... count: N}` (S2).
  int unsigned count = 16;

  task body;
    wr_seq_item tr = wr_seq_item::type_id::create("tr");
    `uvm_info("body", "wr_push (incrementing wr_data): starting", UVM_FULL)
