class b1_env extends uvm_env;
  `uvm_component_utils(b1_env)

  // Agent handles
  gb1_agent  gb1_agnt;

  // Scoreboard (wired to primary agent: gb1)
  b1_scoreboard sbd;

  // Functional coverage (wired to primary agent: gb1)
  gb1_cov cov;

  // Environment configuration
  b1_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
