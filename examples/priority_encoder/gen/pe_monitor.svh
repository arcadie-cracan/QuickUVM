class pe_monitor extends uvm_monitor;
  `uvm_component_utils(pe_monitor)

  virtual pe_if vif;

  uvm_analysis_port #(pe_seq_item) ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    pe_seq_item tr;
    forever begin
      sample_dut(tr);
      ap.write(tr);
    end
  endtask

  task sample_dut (output pe_seq_item tr);
    pe_seq_item t;
    t = pe_seq_item::type_id::create("t");
    //---------------------------------------------
    // Combinational DUT (0-cycle latency): one race-free snapshot of inputs AND
    // outputs taken together through the monitor clocking block.
    //---------------------------------------------
    @vif.mon_cb;
    t.idx = vif.mon_cb.idx;
    t.valid = vif.mon_cb.valid;
    t.req = vif.mon_cb.req;

    // pragma quickuvm custom sample_dut_additional begin
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
