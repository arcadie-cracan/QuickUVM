class rd_sequencer extends uvm_sequencer #(rd_item);
  `uvm_component_utils(rd_sequencer)

  // Reactive agent: the monitor's request port feeds this FIFO, which exists ONLY to give
  // the responder sequence a BLOCKING get. It is a rendezvous, not a backlog buffer.
  uvm_analysis_export #(rd_item) request_export;
  uvm_tlm_analysis_fifo #(rd_item) request_fifo;

  function new (string name, uvm_component parent);
    super.new(name, parent);
    request_export = new("request_export", this);
    request_fifo   = new("request_fifo", this);
  endfunction

  virtual function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    request_export.connect(request_fifo.analysis_export);
  endfunction

endclass
