class smoke extends test_base;
  `uvm_component_utils(smoke)

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
    super.build_phase(phase);
  endfunction

  task run_phase(uvm_phase phase);
    smoke_vseq seq;
    seq = smoke_vseq::type_id::create("seq");
    //----------------------------------------------------
    phase.raise_objection(this);
    `uvm_info("smoke", "about to start seq", UVM_FULL)
    seq.start(e.vsqr);
    // pragma quickuvm custom run_phase_additional begin
    // Strict data-integrity check. wr_push wrote 0,1,..,15 in order, then rd_pop
    // read them, so the k-th read must return k (FIFO order). Writes and reads are
    // temporally separated, so draining the read stream in order is exact.
    begin
      wr_seq_item wt;
      rd_seq_item rt;
      int unsigned nwr = 0, nrd = 0, errors = 0;
      #200;   // let the monitors flush the last (registered) samples
      while (e.wr_fifo.try_get(wt)) if (wt.wr_en) nwr++;
      while (e.rd_fifo.try_get(rt)) if (rt.rd_en) begin
        if (rt.rd_data !== nrd[7:0]) errors++;
        nrd++;
      end
      `uvm_info("FIFO_SB",
        $sformatf("smoke: %0d writes, %0d reads, %0d errors", nwr, nrd, errors), UVM_LOW)
      if (errors > 0) `uvm_error("FIFO_SB", "FIFO data mismatch (expected in-order 0..N)")
      else if (nrd > 0) `uvm_info("FIFO_SB", "*** FIFO DATA INTEGRITY PASS ***", UVM_LOW)
    end
    // pragma quickuvm custom run_phase_additional end
    phase.drop_objection(this);
  endtask

endclass
