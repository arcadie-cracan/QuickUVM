//----------------------------------------------------------------------
// Top (subsystem) base test — builds the top env config, populates each child
// block's env config (agent cfgs + virtual interfaces from the config DB), and
// hands each child env its config so the composed tree self-configures.
//----------------------------------------------------------------------

class csoc_base_test extends uvm_test;
  `uvm_component_utils(csoc_base_test)

  csoc_env e;
  csoc_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    env_cfg = csoc_env_cfg::type_id::create("env_cfg");

    // Block: acc (acc)
    env_cfg.acc_cfg = acc_env_cfg::type_id::create("acc_cfg");
    env_cfg.acc_cfg.a_cfg = a_cfg::type_id::create("a_cfg");
    env_cfg.acc_cfg.a_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual a_if)::get(
          this, "", "acc_a_if_vif", env_cfg.acc_cfg.a_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'acc_a_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(acc_env_cfg)::set(this, "e.acc", "env_cfg", env_cfg.acc_cfg);

    // Block: mul (mul)
    env_cfg.mul_cfg = mul_env_cfg::type_id::create("mul_cfg");
    env_cfg.mul_cfg.m_cfg = m_cfg::type_id::create("m_cfg");
    env_cfg.mul_cfg.m_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual m_if)::get(
          this, "", "mul_m_if_vif", env_cfg.mul_cfg.m_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'mul_m_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(mul_env_cfg)::set(this, "e.mul", "env_cfg", env_cfg.mul_cfg);

    uvm_config_db#(csoc_env_cfg)::set(this, "e", "env_cfg", env_cfg);
    e = csoc_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    `uvm_info("TB", "csoc_base_test: end_of_elaboration", UVM_FULL)
  endfunction

endclass
