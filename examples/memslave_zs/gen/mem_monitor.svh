class mem_monitor extends uvm_monitor;
  `uvm_component_utils(mem_monitor)

  virtual mem_if vif;

  uvm_analysis_port #(mem_seq_item) ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    mem_seq_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      ap.write(tr);
    end
  endtask

  task sample_dut (output mem_seq_item tr);
    mem_seq_item t;
    t = mem_seq_item::type_id::create("t");
    //---------------------------------------------
    // ZERO-SLACK responder: the request and the response happen in the SAME cycle, so
    // they must be sampled in the SAME snapshot. The default two-phase sample (driven
    // inputs now, DUT outputs one edge later) encodes the opposite assumption — the TB
    // drives at edge N and the DUT reacts at N+1 — and would pair our grant with an
    // address from a different cycle.
    //---------------------------------------------
    @vif.mon_cb;
    t.req = vif.mon_cb.req;
    t.addr = vif.mon_cb.addr;
    t.last_data = vif.mon_cb.last_data;
    t.fetched = vif.mon_cb.fetched;
    t.missed = vif.mon_cb.missed;
    t.gnt = vif.mon_cb.gnt;
    t.rdata = vif.mon_cb.rdata;

    // pragma quickuvm custom sample_dut_additional begin
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
