class wr_monitor extends uvm_monitor;
  `uvm_component_utils(wr_monitor)

  virtual wr_if vif;

  uvm_analysis_port #(wr_item) ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    wr_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.wrst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      // Publish only valid/qualified transactions (emit_when: wxfer).
      if (tr.wxfer) ap.write(tr);
    end
  endtask

  task sample_dut (output wr_item tr);
    wr_item t;
    t = wr_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------
    t.wvalid = vif.wvalid;
    t.wdata = vif.wdata;

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.wready = vif.cb1.wready;
    t.wxfer = vif.cb1.wxfer;

    // pragma quickuvm custom sample_dut_additional begin
    // The pushed DATA (wdata) is a TB-driven INPUT, but the transfer QUALIFIER (wxfer) is
    // a DUT OUTPUT sampled one edge later (the default split-edge sampling). Re-sample
    // wdata at the SAME edge as wxfer so the captured (wdata, wxfer) describe the same
    // push — otherwise the source stream lags its qualifier by one word (regfile does the
    // mirror of this for a combinational read).
    t.wdata = vif.wdata;
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
