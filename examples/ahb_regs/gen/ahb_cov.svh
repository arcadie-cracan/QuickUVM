class ahb_cov extends uvm_subscriber #(ahb_seq_item);
  `uvm_component_utils(ahb_cov)

  ahb_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    HRDATA_cp : coverpoint tr.HRDATA {bins HRDATA_bins[8] = {[0:$]};}
    HREADY_cp : coverpoint tr.HREADY {bins HREADY_bins[8] = {[0:$]};}
    HRESP_cp : coverpoint tr.HRESP {bins HRESP_bins[8] = {[0:$]};}
    HADDR_cp : coverpoint tr.HADDR {bins HADDR_bins[8] = {[0:$]};}
    HWRITE_cp : coverpoint tr.HWRITE {bins HWRITE_bins[8] = {[0:$]};}
    HTRANS_cp : coverpoint tr.HTRANS {bins HTRANS_bins[8] = {[0:$]};}
    HWDATA_cp : coverpoint tr.HWDATA {bins HWDATA_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (ahb_seq_item t);
    tr = t;
    `uvm_info("ahb_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
