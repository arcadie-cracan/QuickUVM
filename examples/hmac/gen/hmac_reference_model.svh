//----------------------------------------------------------------------
// Implement hmac_predictor::predict() here.
// This function receives the sampled transaction (inputs + outputs as
// driven to/from DUT) and must return a NEW transaction with the
// EXPECTED output values filled in.
//
// Edit the "prediction_logic" user section below.
//----------------------------------------------------------------------

function host_seq_item hmac_predictor::predict(host_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  host_seq_item extr = host_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // ---- the streaming HMAC-SHA-256 golden model --------------------------------
  // Every HMAC event IS a transaction on this one register bus:
  //   * message words  -> writes to the MSG_FIFO window
  //   * the trigger    -> a write to CMD.hash_process
  //   * the result     -> reads of DIGEST_0..7
  // so a STATEFUL predictor can reconstruct the stream. State lives in the predictor
  // class (see its class_item_additional region).
  //
  // The golden model is OpenTitan's vendored `cryptoc` C library, called over DPI. Its
  // signature (open-array byte streams in, an 8-word array out) is NOT expressible in
  // K0's generated DPI-C bridge (<=64-bit scalars by value), so we import it ourselves
  // and stay on `language: sv`. That is the real, narrow K0 finding.
  begin
    bit [7:0]    key_b[];
    bit [7:0]    msg_b[];
    int unsigned dg[8];
    int          idx;

    if (extr.req) begin
      // ---- WRITES: accumulate the stream -------------------------------------
      if (extr.wr) begin
        if (extr.addr == 12'h000) m_cfg = extr.wdata;                       // CFG

        if (extr.addr >= 12'h020 && extr.addr < 12'h0a0) begin              // KEY_i
          idx = (extr.addr - 12'h020) >> 2;
          if (idx < 8) m_key[idx] = extr.wdata;
        end

        if (extr.addr >= 12'h100) begin                                     // MSG_FIFO
          // The DUT byte-reverses each word into the SHA engine, so wdata[7:0] is the
          // FIRST message byte.
          m_msg.push_back(extr.wdata[7:0]);
          m_msg.push_back(extr.wdata[15:8]);
          m_msg.push_back(extr.wdata[23:16]);
          m_msg.push_back(extr.wdata[31:24]);
        end

        if (extr.addr == 12'h004) begin                                     // CMD
          if (extr.wdata[0]) begin                     // hash_start -> new message
            m_msg.delete();
            m_valid = 1'b0;
          end
          if (extr.wdata[1]) begin                     // hash_process -> TRIGGER
            key_b = new[32];
            foreach (m_key[i]) begin                   // key bytes are MSB-first per word
              key_b[4*i+0] = m_key[i][31:24];
              key_b[4*i+1] = m_key[i][23:16];
              key_b[4*i+2] = m_key[i][15:8];
              key_b[4*i+3] = m_key[i][7:0];
            end
            msg_b = new[m_msg.size()];
            foreach (m_msg[i]) msg_b[i] = m_msg[i];

            if (m_cfg[0]) c_dpi_HMAC_SHA256(key_b, 32, msg_b, m_msg.size(), dg);
            else          c_dpi_SHA256_hash(msg_b, m_msg.size(), dg);

            // cryptoc returns each word byte-swapped vs the DUT's DIGEST_i.
            foreach (m_dgst[i]) m_dgst[i] = {<<8{dg[i]}};
            m_valid = 1'b1;
          end
        end
      end

      // ---- READS: serve the modelled registers -------------------------------
      else begin
        if (extr.addr >= 12'h0a0 && extr.addr < 12'h0e0) begin              // DIGEST_i
          idx = (extr.addr - 12'h0a0) >> 2;
          if (idx < 8 && m_valid) extr.rdata = m_dgst[idx];
          // not yet computed -> echo (nothing to check)
        end
        else if (extr.addr == 12'h000) extr.rdata = m_cfg;                  // CFG
        else if (extr.addr >= 12'h020 && extr.addr < 12'h0a0) begin         // KEY_i
          idx = (extr.addr - 12'h020) >> 2;
          if (idx < 8) extr.rdata = m_key[idx];
        end
        // STATUS / MSG_LENGTH / unmapped: echo the observed value (not modelled here).
      end
    end

    // hmac_done / hmac_idle are DUT status, not modelled -> echo (not checked).
  end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
