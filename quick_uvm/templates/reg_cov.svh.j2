// V2 — register functional coverage FROM THE RAL. A uvm_reg_cbs on every field fires on
// each PREDICTED access with the exact register + read/write kind (no address decode), so
// this works with ANY external uvm_reg_block — coverage-built or not. Two things are
// measured, both driven off the RAL's OWN register list at run time:
//   * a per-register covergroup (was this register READ and WRITTEN?), for the coverage DB;
//   * a read/written tally, reported at end of test — "N/M read, N/M written" — with every
//     un-exercised register named so a gap is actionable (this is what a CSR `rw` test is
//     supposed to drive to 100%).
//----------------------------------------------------------------------

// Per-register access covergroup, wrapped so it can be instantiated once per register.
class {{ dut.name }}_reg_cg;
  covergroup cg(string rname) with function sample(bit is_read);
    option.per_instance = 1;
    option.name         = rname;
    access: coverpoint is_read { bins wrote = {0}; bins read = {1}; }
  endgroup
  function new(string rname);
    cg = new(rname);
  endfunction
  function void sample(bit is_read);
    cg.sample(is_read);
  endfunction
endclass

// The callback: installed on every field; forwards each predicted access to the collector.
typedef class {{ dut.name }}_reg_cov;   // forward declaration (the collector is defined below)
class {{ dut.name }}_reg_cb extends uvm_reg_cbs;
  {{ dut.name }}_reg_cov m_cov;
  function new(string name = "{{ dut.name }}_reg_cb");
    super.new(name);
  endfunction
  virtual function void post_predict(input uvm_reg_field  fld,
                                     input uvm_reg_data_t previous,
                                     inout uvm_reg_data_t value,
                                     input uvm_predict_e  kind,
                                     input uvm_path_e     path,
                                     input uvm_reg_map    map);
    if (m_cov != null && (kind == UVM_PREDICT_READ || kind == UVM_PREDICT_WRITE))
      m_cov.sample(fld.get_parent(), kind);
  endfunction
endclass

class {{ dut.name }}_reg_cov extends uvm_component;
  `uvm_component_utils({{ dut.name }}_reg_cov)

  {{ register_model.block }}   reg_model;
  bit                          m_read    [uvm_reg];
  bit                          m_written [uvm_reg];
  {{ dut.name }}_reg_cg        m_cg      [uvm_reg];

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  // Install a callback + a covergroup on every field/register of `model`. Call after the
  // reg model is built (env connect_phase), so its registers exist.
  function void install({{ register_model.block }} model);
    uvm_reg regs[$];
    reg_model = model;
    reg_model.get_registers(regs);
    foreach (regs[i]) begin
      uvm_reg_field flds[$];
      m_cg[regs[i]] = new(regs[i].get_name());
      regs[i].get_fields(flds);
      foreach (flds[j]) begin
        {{ dut.name }}_reg_cb cb = new();
        cb.m_cov = this;
        uvm_reg_field_cb::add(flds[j], cb);
      end
    end
  endfunction

  function void sample(uvm_reg rg, uvm_predict_e kind);
    bit is_read = (kind == UVM_PREDICT_READ);
    if (is_read) m_read[rg] = 1; else m_written[rg] = 1;
    if (m_cg.exists(rg)) m_cg[rg].sample(is_read);
  endfunction

  function void report_phase(uvm_phase phase);
    uvm_reg regs[$];
    int     nrd_tot, nrd, nwr_tot, nwr;
    super.report_phase(phase);
    if (reg_model == null) return;
    reg_model.get_registers(regs);
    // Access-aware: a READ-ONLY register is not expected to be written (and vice versa),
    // so it is excluded from the write total instead of reported as an untested gap. So
    // 100% is reachable, and a `never written`/`never read` line is a REAL hole.
    foreach (regs[i]) begin
      string rights = regs[i].get_rights();   // "RW" / "RO" / "WO"
      if (rights != "WO") begin
        nrd_tot++;
        if (m_read.exists(regs[i]))    nrd++;
      end
      if (rights != "RO") begin
        nwr_tot++;
        if (m_written.exists(regs[i])) nwr++;
      end
    end
    `uvm_info("REG_COV", $sformatf(
      "register access coverage: %0d/%0d read, %0d/%0d written", nrd, nrd_tot, nwr, nwr_tot),
      UVM_LOW)
    foreach (regs[i]) begin
      string rights = regs[i].get_rights();
      if ((rights != "WO") && !m_read.exists(regs[i]))
        `uvm_info("REG_COV", {"never read:    ", regs[i].get_full_name()}, UVM_MEDIUM)
      if ((rights != "RO") && !m_written.exists(regs[i]))
        `uvm_info("REG_COV", {"never written: ", regs[i].get_full_name()}, UVM_MEDIUM)
    end
  endfunction
endclass
