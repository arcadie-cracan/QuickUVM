class bs_seq extends uvm_sequence #(bs_seq_item);
  `uvm_object_utils(bs_seq)

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name = "bs_seq");
    super.new(name);
  endfunction

  task body;
    bs_seq_item tr = bs_seq_item::type_id::create("tr");
    `uvm_info("body", "bs_seq: about to start do_item loop", UVM_FULL)
    repeat(500) do_item(tr);
  endtask

  task do_item (bs_seq_item tr);
    `uvm_info("do_item", "executing", UVM_FULL)
    start_item(tr);
    if (!(tr.randomize() with {

      // pragma quickuvm custom do_item_constraints begin
      tr.op inside {[3'd0:3'd4]};   // SLL,SRL,SRA,ROL,ROR
      // pragma quickuvm custom do_item_constraints end
    })) `uvm_fatal("BS_SEQ", "bs_seq randomization failed")
    `uvm_info("do_item", tr.input2string(), UVM_FULL)
    finish_item(tr);
  endtask

endclass
