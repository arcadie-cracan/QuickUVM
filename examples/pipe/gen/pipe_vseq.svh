class pipe_vseq extends pipe_base_vseq;
  `uvm_object_utils(pipe_vseq)

  function new (string name = "pipe_vseq");
    super.new(name);
  endfunction

  task body;
    a_seq add_a_seq;

    add_a_seq = a_seq::type_id::create("add_a_seq");
    // pragma quickuvm custom vseq_body_pre begin
    // pragma quickuvm custom vseq_body_pre end
    // Run every block's stimulus concurrently
    fork
      add_a_seq.start(p_sequencer.add_a_sqr);
    join
    // pragma quickuvm custom vseq_body_post begin
    // pragma quickuvm custom vseq_body_post end
  endtask

endclass
