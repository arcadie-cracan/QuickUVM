//----------------------------------------------------------------------
// Top (subsystem) base test — builds the top env config, populates each child
// block's env config (agent cfgs + virtual interfaces from the config DB), and
// hands each child env its config so the composed tree self-configures.
//----------------------------------------------------------------------

class soc_base_test extends uvm_test;
  `uvm_component_utils(soc_base_test)

  soc_env e;
  soc_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    env_cfg = soc_env_cfg::type_id::create("env_cfg");

    // Block: adder (adder)
    env_cfg.adder_cfg = adder_env_cfg::type_id::create("adder_cfg");
    env_cfg.adder_cfg.a_cfg = a_cfg::type_id::create("a_cfg");
    env_cfg.adder_cfg.a_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual a_if)::get(
          this, "", "adder_a_if_vif", env_cfg.adder_cfg.a_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'adder_a_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(adder_env_cfg)::set(this, "e.adder", "env_cfg", env_cfg.adder_cfg);

    // Block: inverter (inverter)
    env_cfg.inverter_cfg = inverter_env_cfg::type_id::create("inverter_cfg");
    env_cfg.inverter_cfg.b_cfg = b_cfg::type_id::create("b_cfg");
    env_cfg.inverter_cfg.b_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual b_if)::get(
          this, "", "inverter_b_if_vif", env_cfg.inverter_cfg.b_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'inverter_b_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(inverter_env_cfg)::set(this, "e.inverter", "env_cfg", env_cfg.inverter_cfg);

    uvm_config_db#(soc_env_cfg)::set(this, "e", "env_cfg", env_cfg);
    e = soc_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    `uvm_info("TB", "soc_base_test: end_of_elaboration", UVM_FULL)
  endfunction

endclass
