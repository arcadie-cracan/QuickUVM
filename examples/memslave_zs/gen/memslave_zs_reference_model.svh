//----------------------------------------------------------------------
// Implement memslave_zs_predictor::predict() here.
// This function receives the sampled transaction (inputs + outputs as
// driven to/from DUT) and must return a NEW transaction with the
// EXPECTED output values filled in.
//
// Edit the "prediction_logic" user section below.
//----------------------------------------------------------------------

function mem_seq_item memslave_zs_predictor::predict(mem_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  mem_seq_item extr = mem_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // THE CHECK: the DUT must capture exactly what the memory model says lives at the
  // address it asked for — expected derived from `addr`, INDEPENDENTLY of the `rdata` we
  // observed. Deriving it from the observed value would be a TAUTOLOGY: it could never
  // fail for a responder that answers the wrong data, or too late.
  // The snapshot catches gnt and addr in the SAME cycle — before the DUT has captured.
  // So the data the DUT is holding right now is the PREVIOUS grant's: predict m_last
  // FIRST, then update it. (memslave does the opposite, because its two-phase monitor
  // sample already applies that one-cycle skew for it.)
  extr.last_data = m_last;
  if (extr.gnt && extr.req) begin
    m_grants++;
    m_last = mem_model(extr.addr);
  end

  if (extr.fetched > m_fetched) m_fetched = extr.fetched;

  // A grant that arrives too late is the failure this example exists to catch: the DUT
  // records it in `missed` and captures nothing. Predict zero — any miss is an error.
  extr.missed = 8'd0;
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
