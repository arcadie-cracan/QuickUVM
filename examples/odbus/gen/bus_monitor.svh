class bus_monitor extends uvm_monitor;
  `uvm_component_utils(bus_monitor)

  virtual bus_if vif;

  uvm_analysis_port #(bus_seq_item) ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    bus_seq_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      ap.write(tr);
    end
  endtask

  task sample_dut (output bus_seq_item tr);
    bus_seq_item t;
    t = bus_seq_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.dut_low = vif.cb1.dut_low;
    // A shared line and BOTH drivers' states must be observed at the SAME INSTANT, or a
    // model of the bus resolution compares the line from one cycle against a driver's
    // state from the next. So these are sampled HERE, with the DUT outputs — not with the
    // TB-driven inputs, even though <n>_o/<n>_oe are things we drive.
    t.sda    = vif.cb1.sda;   // the RESOLVED line
    t.sda_o  = vif.sda_o;     // what we were driving at that instant
    t.sda_oe = vif.sda_oe;

    // pragma quickuvm custom sample_dut_additional begin
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
