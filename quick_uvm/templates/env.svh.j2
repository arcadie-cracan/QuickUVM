{% set pa = agents[0] %}

class {{ dut.name }}_env extends uvm_env;
  `uvm_component_utils({{ dut.name }}_env)

  // Agent handles
{% if has_instances %}
{% for inst in instances %}
  {{ inst.agent.name }}_agent{{ inst.pav }}  {{ inst.handle }};
{% endfor %}
{% else %}
{% for agent in agents %}
  {{ agent.name }}_agent{{ agent.param_args_values }}  {{ agent.name }}_agnt;
{% endfor %}
{% endif %}
{% if virtual_sequences %}

  // Virtual sequencer (C2) — collects the active agents' sequencers
  {{ dut.name }}_virtual_sequencer vsqr;
{% endif %}

{% if has_instances %}
  // Scoreboards (one concrete set per instance)
{% for inst in instances %}
  {{ dut.name }}_{{ inst.name }}_scoreboard  {{ inst.sb_handle }};
{% endfor %}
{% elif analysis %}
  // Scoreboards
{% for sb in analysis.scoreboards %}
{% set sbcls = (dut.name ~ '_' ~ sb.name ~ '_scoreboard') if sb_multi else (dut.name ~ '_scoreboard') %}
  {{ sbcls }} {{ sb.name }};
{% endfor %}

  // Functional coverage (per agent)
{# handle is `<agent>_cov_h`, NOT `<agent>_cov`: naming the member the same as its
   TYPE shadows it, and the subsequent `<agent>_cov::type_id` fails at elaboration. #}
{% for ag in analysis.coverage %}
  {{ ag }}_cov {{ ag }}_cov_h;
{% endfor %}
{% else %}
  // Scoreboard (wired to primary agent: {{ pa.name }})
  {{ dut.name }}_scoreboard sbd;

  // Functional coverage (wired to primary agent: {{ pa.name }})
  {{ pa.name }}_cov{{ pa.param_args_values }} cov;
{% endif %}

  // Environment configuration
  {{ dut.name }}_env_cfg env_cfg;
{% if register_model %}

  // Register model front-door adapter{% if register_model.use_predictor %} + predictor{% endif %}

  {{ register_model.adapter }} bus_adapter;
{% if register_model.use_predictor %}
  uvm_reg_predictor #({{ reg_bus_agent.sequence_item }}) reg_predictor;
{% endif %}
{% if register_model.coverage %}
  {{ dut.name }}_reg_cov reg_cov_h;   // V2 — register access coverage from the RAL
{% endif %}
{% endif %}
{% if cover_probes %}

  // K2 — passive whitebox probe monitor (covers observed internal signals)
  {{ dut.name }}_probe_monitor probe_mon;
{% endif %}

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#({{ dut.name }}_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No {{ dut.name }}_env_cfg set for: ", get_full_name()})
{% if has_instances %}
{% for inst in instances %}
    uvm_config_db#({{ inst.agent.name }}_cfg{{ inst.pav }})::set(this, "{{ inst.handle }}", "cfg", env_cfg.{{ inst.cfg_field }});
    {{ inst.handle }} = {{ inst.agent.name }}_agent{{ inst.pav }}::type_id::create("{{ inst.handle }}", this);
{% endfor %}
{% else %}
{% for agent in agents %}
    uvm_config_db#({{ agent.name }}_cfg{{ agent.param_args_values }})::set(this, "{{ agent.name }}_agnt", "cfg", env_cfg.{{ agent.name }}_cfg);
    {{ agent.name }}_agnt = {{ agent.name }}_agent{{ agent.param_args_values }}::type_id::create("{{ agent.name }}_agnt", this);
{% endfor %}
{% endif %}
{% if virtual_sequences %}
    vsqr = {{ dut.name }}_virtual_sequencer::type_id::create("vsqr", this);
{% endif %}
{% if has_instances %}
{% for inst in instances %}
    {{ inst.sb_handle }} = {{ dut.name }}_{{ inst.name }}_scoreboard::type_id::create("{{ inst.sb_handle }}", this);
{% endfor %}
{% elif analysis %}
{% for sb in analysis.scoreboards %}
{% set sbcls = (dut.name ~ '_' ~ sb.name ~ '_scoreboard') if sb_multi else (dut.name ~ '_scoreboard') %}
    {{ sb.name }} = {{ sbcls }}::type_id::create("{{ sb.name }}", this);
{% endfor %}
{% for ag in analysis.coverage %}
    {{ ag }}_cov_h = {{ ag }}_cov::type_id::create("{{ ag }}_cov_h", this);
{% endfor %}
{% else %}
    sbd  = {{ dut.name }}_scoreboard::type_id::create("sbd",  this);
    cov  = {{ pa.name }}_cov{{ pa.param_args_values }}::type_id::create("cov",  this);
{% endif %}
{% if register_model %}
    bus_adapter = {{ register_model.adapter }}::type_id::create("bus_adapter");
{% if register_model.use_predictor %}
    reg_predictor = uvm_reg_predictor#({{ reg_bus_agent.sequence_item }})::type_id::create("reg_predictor", this);
{% endif %}
{% if register_model.coverage %}
    reg_cov_h = {{ dut.name }}_reg_cov::type_id::create("reg_cov_h", this);
{% endif %}
{% endif %}
{% if cover_probes %}
    probe_mon = {{ dut.name }}_probe_monitor::type_id::create("probe_mon", this);
{% endif %}
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
{% if has_instances %}
    // Each instance's agent → its own scoreboard
{% for inst in instances %}
    {{ inst.handle }}.ap.connect({{ inst.sb_handle }}.axp);
{% endfor %}
{% elif analysis %}
    // Declared analysis connectivity (per analysis: block)
{% for sb in analysis.scoreboards %}
{% if sb.monitor %}
    {{ sb.source }}_agnt.ap.connect({{ sb.name }}.src_axp);
    {{ sb.monitor }}_agnt.ap.connect({{ sb.name }}.mon_axp);
{% else %}
    {{ sb.source }}_agnt.ap.connect({{ sb.name }}.axp);
{% endif %}
{% endfor %}
{% for ag in analysis.coverage %}
    {{ ag }}_agnt.ap.connect({{ ag }}_cov_h.analysis_export);
{% endfor %}
{% else %}
    // Primary agent → scoreboard + coverage
    {{ pa.name }}_agnt.ap.connect(sbd.axp);
    {{ pa.name }}_agnt.ap.connect(cov.analysis_export);
{% endif %}
{% if register_model %}
    // Register model front-door: bind the map to the bus agent's sequencer
    env_cfg.reg_model.{{ register_model.map }}.set_sequencer({{ register_model.bus_agent }}_agnt.sqr, bus_adapter);
{% if register_model.use_predictor %}
    reg_predictor.map     = env_cfg.reg_model.{{ register_model.map }};
    reg_predictor.adapter = bus_adapter;
    {{ register_model.bus_agent }}_agnt.ap.connect(reg_predictor.bus_in);
    env_cfg.reg_model.{{ register_model.map }}.set_auto_predict(0);
{% else %}
    env_cfg.reg_model.{{ register_model.map }}.set_auto_predict(1);
{% endif %}
{% if register_model.coverage %}
    // V2 — install the register-coverage callbacks now the reg model is built.
    reg_cov_h.install(env_cfg.reg_model);
{% endif %}
{% endif %}
{% if virtual_sequences %}
    // Virtual sequencer: hand each active agent's sequencer to the vsqr (C2)
{% for agent in agents if agent.active %}
    vsqr.{{ agent.name }}_sqr = {{ agent.name }}_agnt.sqr;
{% endfor %}
{% endif %}
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction
{% if unchecked_agents %}

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    // Checking has not scaled with stimulus: the auto virtual sequence drives EVERY
    // stimulus agent in parallel, but the default wiring scoreboards only the primary
    // agent — these agents' streams are driven and never checked (a green bench with
    // an unverified agent). Declare an `analysis:` block routing them (or, to keep
    // primary-only checking deliberately, declare that routing explicitly) to
    // silence this.
{% for ag in unchecked_agents %}
    `uvm_warning("UNCHECKED_AGENT",
                 {"agent '{{ ag }}' is driven by the auto virtual sequence ",
                  "but no scoreboard checks its stream"})
{% endfor %}
  endfunction
{% endif %}

endclass
