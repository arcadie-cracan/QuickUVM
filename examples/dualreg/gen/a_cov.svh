class a_cov extends uvm_subscriber #(a_item);
  `uvm_component_utils(a_cov)

  a_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    adout_cp : coverpoint tr.adout {bins adout_bins[8] = {[0:$]};}
    dorst   : coverpoint tr.a_rst_n {bins dorst  = {'0};}
    norst   : coverpoint tr.a_rst_n {bins norst  = {'1};}
    adin_cp : coverpoint tr.adin {bins adin_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (a_item t);
    tr = t;
    `uvm_info("a_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
