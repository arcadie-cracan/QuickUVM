class wr_monitor extends uvm_monitor;
  `uvm_component_utils(wr_monitor)

  virtual wr_if vif;

  uvm_analysis_port #(wr_item) ap;
  // Reactive agent: publish the DUT's REQUEST as soon as it is decoded, on a SECOND
  // port. The responder sequence blocks on this (via the sequencer's TLM FIFO) and
  // computes the response. The monitor already decodes the protocol for passive mode,
  // so this duplicates nothing — which is exactly why the driver does NOT decode it.
  uvm_analysis_port #(wr_item) request_ap;
  // Edge-detect state for the request qualifier (see run_phase).
  bit m_req_seen;

  // pragma quickuvm custom class_item_additional begin
  // AXI4 gives the W data no id: the k-th W burst pairs with the k-th AW BY ORDER. Hold the
  // awids of the accepted-but-not-yet-completed writes, oldest first, and pop the front when a
  // write completes (WLAST) — that is the id this B response must carry.
  bit [3:0] m_awid_q [$];
  // UVM ORACLE: SLVERR (a mis-order), id-correctness, delivery, and a real REORDER made
  // verdict-carrying — the DUT master's $error checks are invisible to the UVM-severity gate.
  bit       m_b_out [16];
  bit [3:0] m_b_issue [$];
  bit [3:0] m_b_recv  [$];
  int       m_b_got;

  function void check_phase(uvm_phase phase);
    int reorder = 0;
    super.check_phase(phase);
    foreach (m_b_recv[i])
      if (i < m_b_issue.size() && m_b_recv[i] != m_b_issue[i]) reorder++;
    if (m_b_got != m_b_issue.size())
      `uvm_error("WR_CHK", $sformatf("write channel delivered %0d of %0d",
                 m_b_got, m_b_issue.size()))
    else if (m_b_got == 0)
      `uvm_error("WR_CHK", "no B beats — vacuous")
    else if (reorder == 0)
      `uvm_error("WR_CHK", "writes returned IN ORDER — out-of-order was not exercised")
  endfunction
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
    request_ap = new("request_ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    wr_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      // The DUT issued a request -> hand it to the responder sequence.
      //
      // On the RISING EDGE of the qualifier, not its level. A request line is normally HELD
      // until it is granted, so a level-triggered publish would queue one copy per cycle and
      // the responder would answer the same request many times (over-granting, and the
      // response held for extra cycles).
      if (tr.wlast && !m_req_seen) request_ap.write(tr);
      m_req_seen = tr.wlast;
      ap.write(tr);
    end
  endtask

  task sample_dut (output wr_item tr);
    wr_item t;
    t = wr_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------
    t.bvalid = vif.bvalid;
    t.bid = vif.bid;
    t.bresp = vif.bresp;

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.awvalid = vif.cb1.awvalid;
    t.awid = vif.cb1.awid;
    t.awaddr = vif.cb1.awaddr;
    t.wvalid = vif.cb1.wvalid;
    t.wdata = vif.cb1.wdata;
    t.wlast = vif.cb1.wlast;

    // pragma quickuvm custom sample_dut_additional begin
    // Correlate the two request channels (AW address + W data) into one completed write.
    // Enqueue every AW id as it arrives; on the write's last data beat, stamp `t` with the
    // matching (oldest outstanding) id so the request published on WLAST carries the right id.
    // The pop qualifier is the SAME rising-edge-of-wlast the request-publish uses (run_phase),
    // so the correlation queue and the published-request stream can never diverge. An empty
    // queue here is a real desync (a W with no matching AW) — make it LOUD, not a stale stamp.
    // NOTE: this valid-only correlation assumes single-cycle beats; a ready-handshake bus
    // (awready/wready backpressure) would need the push/pop gated on VALID && READY (out of
    // scope this slice — see README).
    if (t.awvalid) begin
      m_awid_q.push_back(t.awid);
      m_b_out[t.awid] = 1'b1; m_b_issue.push_back(t.awid);
    end
    if (t.bvalid) begin
      if (t.bresp != 2'b00)
        `uvm_error("WR_CHK", $sformatf("B beat bid=%0d SLVERR (mis-ordered AW/W)", t.bid))
      if (!m_b_out[t.bid])
        `uvm_error("WR_CHK", $sformatf("B beat bid=%0d not outstanding", t.bid))
      m_b_out[t.bid] = 1'b0; m_b_recv.push_back(t.bid); m_b_got++;
    end
    if (t.wlast && !m_req_seen) begin           // a write completes (the publish edge)
      if (m_awid_q.size() > 0) t.awid = m_awid_q.pop_front();
      else `uvm_error("AWID_UNDERFLOW",
                      "WLAST with no outstanding AW: AW/W correlation desync")
    end
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
