    env_cfg.stg1_cfg.dbl_cfg.d_cfg = d_cfg::type_id::create("d_cfg");
    env_cfg.stg1_cfg.dbl_cfg.d_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual d_if)::get(
