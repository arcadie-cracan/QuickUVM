class rand_test extends axi_read_burst_base_test;
  `uvm_component_utils(rand_test)

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
    super.build_phase(phase);
  endfunction

  task run_phase(uvm_phase phase);
    // Reactive bench: the DUT is the INITIATOR and the responder agent(s) serve it, so
    // there is no TB-initiated stimulus. The test must NOT start a sequence on a
    // responder's sequencer — its forever responder sequence owns it, and a second
    // sequence there would clobber the computed responses with random items.
    //----------------------------------------------------
    phase.raise_objection(this);
    `uvm_info("rand_test", "reactive bench: letting the DUT run", UVM_FULL)
    // Via the virtual interface — a class in a PACKAGE may not use a hierarchical name.
    repeat (120) @(posedge env_cfg.rd_cfg.vif.clk);
    // pragma quickuvm custom run_phase_additional begin
    // pragma quickuvm custom run_phase_additional end
    phase.drop_objection(this);
  endtask

endclass
