    uvm_config_db#(inv_env_cfg)::set(this, "e.stg2.inv", "env_cfg", env_cfg.stg2_cfg.inv_cfg);

    // Block: xr (xr)
    env_cfg.stg2_cfg.xr_cfg = xr_env_cfg::type_id::create("xr_cfg");
    env_cfg.stg2_cfg.xr_cfg.x_cfg = x_cfg::type_id::create("x_cfg");
    env_cfg.stg2_cfg.xr_cfg.x_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual x_if)::get(
          this, "", "stg2_xr_x_if_vif", env_cfg.stg2_cfg.xr_cfg.x_cfg.vif))
      `uvm_fatal("NOVIF",
