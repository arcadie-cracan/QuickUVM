class stream_cov extends uvm_subscriber #(stream_seq_item);
  `uvm_component_utils(stream_cov)

  stream_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    option.goal         = 100;
    len_cp : coverpoint tr.len {
      bins legal = {[1:16]};
    }
    sum_cp : coverpoint tr.sum {
      bins in_range = {[0:4080]};
      illegal_bins impossible = {[4081:65535]};
    }

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (stream_seq_item t);
    tr = t;
    `uvm_info("stream_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
