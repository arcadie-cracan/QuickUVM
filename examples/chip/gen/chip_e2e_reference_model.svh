// Two-stream scoreboard: `t` is the observed host (request) item;
// return the EXPECTED b (response) item it should produce.
function b_seq_item chip_e2e_predictor::predict(host_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  b_seq_item extr = b_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // pragma quickuvm custom prediction_logic begin
  // end-to-end: host drives hin -> add (+1) -> inv (~) -> expected b.dout = ~(hin + 1)
