class chb_cov extends uvm_subscriber #(chb_seq_item);
  `uvm_component_utils(chb_cov)

  chb_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    b_valid_cp : coverpoint tr.b_valid {bins b_valid_bins[8] = {[0:$]};}
    b_id_cp : coverpoint tr.b_id {bins b_id_bins[8] = {[0:$]};}
    b_flag_cp : coverpoint tr.b_flag {bins b_flag_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (chb_seq_item t);
    tr = t;
    `uvm_info("chb_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
