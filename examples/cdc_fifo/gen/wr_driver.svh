class wr_driver extends uvm_driver #(wr_item);
  `uvm_component_utils(wr_driver)

  virtual wr_if vif;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  task run_phase(uvm_phase phase);
    wr_item tr;
    initialize();
    forever begin
      `uvm_info("DEBUG: wr_driver Run", "... getting next item ...", UVM_FULL)
      seq_item_port.get_next_item(tr);
      drive_item(tr);
      seq_item_port.item_done();
      `uvm_info("DEBUG: wr_driver Run", "... next item done ...", UVM_FULL)
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "wr_driver: Initialize (time @0)", UVM_HIGH)
    vif.wvalid <= '0;
    vif.wdata <= '1;
    // Reset is driven externally: hold off BEFORE advancing a clock so the parked
    // idle values are all the DUT sees during reset; wait for deassertion, then let
    // the input synchronizers settle (2 = a typical 2-stage sync; raise for deeper).
    wait (vif.wrst_n === 1'b1);
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (wr_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    vif.cb1.wvalid <= tr.wvalid;
    vif.cb1.wdata <= tr.wdata;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // Pulse wvalid: assert for one cycle (the push above), then DE-ASSERT. An initiator
    // holds its last driven value, so leaving wvalid=1 after the sequence would keep the
    // FIFO pushing stale data forever (spurious source items -> SB_LEFTOVER). Pulsing
    // makes each push a clean one-cycle request and leaves wvalid low when idle.
    vif.cb1.wvalid <= 1'b0;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional end
  endtask

endclass
