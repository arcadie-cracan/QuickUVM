//----------------------------------------------------------------------
// Top (subsystem) environment — composes the child block envs and a virtual
// sequencer that collects each block's agent sequencers so a top vseq can
// coordinate stimulus across the blocks.
//----------------------------------------------------------------------

class {{ dut.name }}_env extends uvm_env;
  `uvm_component_utils({{ dut.name }}_env)

  // Child block environments
{% for sv in subenvs %}
  {{ sv.env_class }} {{ sv.inst }};
{% endfor %}
{% if boundary_agents %}

  // H2 — boundary (top-level) agents: the subsystem's own bus/pin agents
{% for agent in boundary_agents %}
  {{ agent.name }}_agent {{ agent.name }}_agnt;
{% endfor %}
{% endif %}

  // Top virtual sequencer (coordinates the composed blocks)
  {{ dut.name }}_virtual_sequencer vsqr;
{% if subenv_scoreboards %}

  // Cross-block scoreboards (predict a monitor block's output from a source block)
{% for xsb in subenv_scoreboards %}
  {{ xsb.cls }} {{ xsb.name }};
{% endfor %}
{% endif %}

  {{ dut.name }}_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#({{ dut.name }}_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No {{ dut.name }}_env_cfg set for: ", get_full_name()})
{% for sv in subenvs %}
    {{ sv.inst }} = {{ sv.env_class }}::type_id::create("{{ sv.inst }}", this);
{% endfor %}
{% for agent in boundary_agents %}
    uvm_config_db#({{ agent.name }}_cfg)::set(this, "{{ agent.name }}_agnt", "cfg", env_cfg.{{ agent.name }}_cfg_h);
    {{ agent.name }}_agnt = {{ agent.name }}_agent::type_id::create("{{ agent.name }}_agnt", this);
{% endfor %}
    vsqr = {{ dut.name }}_virtual_sequencer::type_id::create("vsqr", this);
{% for xsb in subenv_scoreboards %}
    {{ xsb.name }} = {{ xsb.cls }}::type_id::create("{{ xsb.name }}", this);
{% endfor %}
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Collect each block's active agent sequencers into the top vsqr
{% for sv in subenvs %}
{% if sv.is_subsystem %}
    vsqr.{{ sv.name }}_vsqr = {{ sv.inst }}.vsqr;
{% else %}
{% for agent in sv.agents if agent.active %}
    vsqr.{{ sv.name }}_{{ agent.name }}_sqr = {{ sv.inst }}.{{ agent.name }}_agnt.sqr;
{% endfor %}
{% endif %}
{% endfor %}
{% for agent in boundary_agents if agent.active %}
    vsqr.{{ agent.name }}_sqr = {{ agent.name }}_agnt.sqr;
{% endfor %}
{% if subenv_scoreboards %}
    // Cross-block scoreboards: source block stream -> predictor, monitor -> comparator
{% for xsb in subenv_scoreboards %}
{% if xsb.src_handle %}
    {{ xsb.src_handle }}.{{ xsb.src_agent }}_agnt.ap.connect({{ xsb.name }}.src_axp);
{% else %}
    {{ xsb.src_agent }}_agnt.ap.connect({{ xsb.name }}.src_axp);
{% endif %}
{% if xsb.mon_handle %}
    {{ xsb.mon_handle }}.{{ xsb.mon_agent }}_agnt.ap.connect({{ xsb.name }}.mon_axp);
{% else %}
    {{ xsb.mon_agent }}_agnt.ap.connect({{ xsb.name }}.mon_axp);
{% endif %}
{% endfor %}
{% endif %}
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction
{% if unchecked_boundary %}

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    // Checking has not scaled with stimulus: these boundary agents are driven by
    // the top virtual sequence but no cross-block scoreboard references them —
    // their streams are driven and never checked. Add a `subenv_scoreboards:`
    // entry using the bare agent name as source (or monitor) to silence this.
{% for ag in unchecked_boundary %}
    `uvm_warning("UNCHECKED_AGENT",
                 {"boundary agent '{{ ag }}' is driven by the top vseq ",
                  "but no cross-block scoreboard checks its stream"})
{% endfor %}
  endfunction
{% endif %}

endclass
