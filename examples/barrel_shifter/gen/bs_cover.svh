class bs_cover extends uvm_subscriber #(bs_seq_item);
  `uvm_component_utils(bs_cover)

  bs_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    data_out_cp : coverpoint tr.data_out {bins data_out_bins[8] = {[0:$]};}
    data_in_cp : coverpoint tr.data_in {bins data_in_bins[8] = {[0:$]};}
    amt_cp : coverpoint tr.amt {bins amt_bins[8] = {[0:$]};}
    op_cp : coverpoint tr.op {bins op_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (bs_seq_item t);
    tr = t;
    `uvm_info("bs_cover", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
