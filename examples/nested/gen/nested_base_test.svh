    // Block: cB (clusterB)
    env_cfg.cB_cfg = clusterB_env_cfg::type_id::create("cB_cfg");
    uvm_config_db#(clusterB_env_cfg)::set(this, "e.cB", "env_cfg", env_cfg.cB_cfg);

    // Block: pb (b0)
    env_cfg.cB_cfg.pb_cfg = b0_env_cfg::type_id::create("pb_cfg");
    env_cfg.cB_cfg.pb_cfg.gb0_cfg = gb0_cfg::type_id::create("gb0_cfg");
    env_cfg.cB_cfg.pb_cfg.gb0_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual gb0_if)::get(
          this, "", "cB_pb_gb0_if_vif", env_cfg.cB_cfg.pb_cfg.gb0_cfg.vif))
