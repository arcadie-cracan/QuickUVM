`include "uvm_macros.svh"
module {{ top_name }};
  import uvm_pkg::*;
{% if layout == 'packaged' %}
  import {{ dut.name }}_test_pkg::*;
{% else %}
  import {{ dut.name }}_tb_pkg::*;
{% endif %}
{% if multi_domain %}

  // M1 — multiple clock/reset domains.
{% for c in clocks %}
  logic {{ c.name }};
{% endfor %}
{% for r in resets %}
  logic {{ r.name }};
{% endfor %}

  // One clock generator per domain (clkgen is parameterized by PERIOD)
{% for c in clocks %}
  clkgen #({{ clock_periods_ts[c.name] }}) ck_{{ c.name }} ({{ c.name }});
{% endfor %}
{% for r in resets %}

  // Reset generator for {{ r.name }} ({% if r.clock %}deassert synced to {{ r.clock }}{% else %}async{% endif %}).
  // pragma quickuvm custom reset_generator_{{ r.name }} begin
  initial begin
    {{ r.name }} = 1'b{% if r.active_low %}0{% else %}1{% endif %};   // assert
{% if r.clock %}
    repeat (5) @(posedge {{ r.clock }});
{% else %}
    #{{ 5 * clocks[0].period }};
{% endif %}
    // NOTE: the driver and monitor block until this deasserts — if you edit this
    // block you MUST drive {{ r.name }} to its inactive level or the TB will hang.
    {{ r.name }} = 1'b{% if r.active_low %}1{% else %}0{% endif %};   // deassert
  end
  // pragma quickuvm custom reset_generator_{{ r.name }} end
{% endfor %}

  // Instantiate each interface on its agent's clock (and reset) domain
{% for agent in agents %}
  {{ agent.interface }}{{ agent.param_args_values }} {{ agent.interface }}_inst (.clk({{ agent_clocks[agent.name] }}){% if agent_resets[agent.name] %}, .{{ agent_resets[agent.name].name }}({{ agent_resets[agent.name].name }}){% endif %});
{% endfor %}

  // pragma quickuvm custom dut_connections begin
  // Instantiate DUT — per-domain clocks/resets + interface signals. Edit for real RTL
  // (the DUT's clock/reset port names are assumed to match the domain names).
  {{ dut.name }} dut_inst (
{% for agent in agents %}
{% for kind, port in agent.all_ports %}
    .{{ port.name }}({{ agent.interface }}_inst.{{ port.name }}),
{% endfor %}
{% endfor %}
{% for c in clocks %}
    .{{ c.name }}({{ c.name }}){% if not loop.last or resets %},{% endif %}

{% endfor %}
{% for r in resets %}
    .{{ r.name }}({{ r.name }}){% if not loop.last %},{% endif %}

{% endfor %}
  );
  // pragma quickuvm custom dut_connections end
{% else %}

  logic clk;
{% if dut.external_reset %}
  logic {{ dut.reset }};
{% endif %}

  // Instantiate clock generator
  clkgen ck (clk);
{% if dut.external_reset %}

  // Reset generator (external reset). Period units follow the sim -timescale.
  // pragma quickuvm custom reset_generator begin
  initial begin
    {{ dut.reset }} = 1'b{% if dut.reset_active_low %}0{% else %}1{% endif %};   // assert
    repeat (5) @(posedge clk);
    // NOTE: the driver and monitor block until this deasserts — if you edit this
    // block you MUST drive {{ dut.reset }} to its inactive level or the TB will hang.
    {{ dut.reset }} = 1'b{% if dut.reset_active_low %}1{% else %}0{% endif %};   // deassert
  end
  // pragma quickuvm custom reset_generator end
{% endif %}

  // Instantiate interfaces
{% if has_instances %}
{% for inst in instances %}
  {{ inst.agent.interface }}{{ inst.pav }} {{ inst.if_inst }} ({% if dut.external_reset %}.clk(clk), .{{ dut.reset }}({{ dut.reset }}){% else %}clk{% endif %});
{% endfor %}
{% else %}
{% for agent in agents %}
  {{ agent.interface }}{{ agent.param_args_values }} {{ agent.interface }}_inst ({% if dut.external_reset %}.clk(clk), .{{ dut.reset }}({{ dut.reset }}){% else %}clk{% endif %});
{% endfor %}
{% endif %}

  // pragma quickuvm custom dut_connections begin
{% if has_instances %}
  // Instantiate one DUT per instance, each at its own width
{% for inst in instances %}
  {{ dut.name }}{{ inst.pav }} {{ inst.dut_inst }} (
{% if dut.combinational %}
{% for kind, port in inst.agent.all_ports %}
    .{{ port.name }}({{ inst.if_inst }}.{{ port.name }}){{ "," if not loop.last else "" }}
{% endfor %}
{% else %}
{% for port in inst.agent.output_ports %}
    .{{ port.name }}({{ inst.if_inst }}.{{ port.name }}),
{% endfor %}
{% for port in inst.agent.input_ports %}
    .{{ port.name }}({{ inst.if_inst }}.{{ port.name }}),
{% endfor %}
    .{{ dut.clock }}(clk){% if dut.reset %},
    .{{ dut.reset }}({{ inst.if_inst }}.{{ dut.reset }}){% endif %}

{% endif %}
  );
{% endfor %}
{% else %}
  // Instantiate DUT — connect to interface signals hierarchically
  {{ dut.name }} dut_inst (
{% if dut.combinational %}
{% set ns = namespace(conns=[]) %}
{% for agent in agents %}
{% for kind, port in agent.all_ports %}
{% set ns.conns = ns.conns + [(agent.interface, port.name)] %}
{% endfor %}
{% endfor %}
{% for iface, pname in ns.conns %}
    .{{ pname }}({{ iface }}_inst.{{ pname }}){{ "," if not loop.last else "" }}
{% endfor %}
{% else %}
{% set reset_port = namespace(found=false) %}
{% for agent in agents %}{% for _, p in agent.all_ports %}{% if p.name == dut.reset %}{% set reset_port.found = true %}{% endif %}{% endfor %}{% endfor %}
{% for agent in agents %}
{% for port in agent.output_ports %}
    .{{ port.name }}({{ agent.interface }}_inst.{{ port.name }}),
{% endfor %}
{% for port in agent.input_ports %}
    .{{ port.name }}({{ agent.interface }}_inst.{{ port.name }}),
{% endfor %}
{% endfor %}
    .{{ dut.clock }}(clk){% if dut.reset and not reset_port.found %},
    .{{ dut.reset }}({{ agents[0].interface }}_inst.{{ dut.reset }}){% endif %}
{% endif %}
  );
{% endif %}
  // pragma quickuvm custom dut_connections end
{% endif %}
{% if probes %}

  // K2 whitebox probes — OBSERVE-only continuous taps of internal DUT signals.
  {{ dut.name }}_probe_if probe_if (.{{ probe_clock }}({{ probe_clock }}){% if probe_reset %}, .{{ probe_reset.name }}({{ probe_reset.name }}){% endif %});
{% for p in probes %}
  assign probe_if.{{ p.name }} = dut_inst.{{ p.path }};
{% endfor %}
{% endif %}

  initial begin
{% if probes %}
    uvm_config_db#(virtual {{ dut.name }}_probe_if)::set(null, "*", "{{ dut.name }}_probe_vif", probe_if);
{% endif %}
{% if has_instances %}
{% for inst in instances %}
    uvm_config_db#(virtual {{ inst.agent.interface }}{{ inst.pav }})::set(null, "*", "{{ inst.vif_key }}", {{ inst.if_inst }});
{% endfor %}
{% else %}
{% for agent in agents %}
    uvm_config_db#(virtual {{ agent.interface }}{{ agent.param_args_values }})::set(null, "*", "{{ agent.interface }}_vif", {{ agent.interface }}_inst);
{% endfor %}
{% endif %}
    run_test();
  end
endmodule
