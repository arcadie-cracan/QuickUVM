`ifndef TB_PKG__SV
`define TB_PKG__SV

`include "uvm_macros.svh"

package tb_pkg;
  import uvm_pkg::*;
{% if register_model %}
  import {{ register_model.package }}::*;
{% endif %}
{% for pkg in project.imports %}
  import {{ pkg }}::*;
{% endfor %}
  // pragma quickuvm custom imports begin
  // pragma quickuvm custom imports end

  // Transaction classes
{% for agent in agents %}
  `include "{{ agent.transaction }}.svh"
{% endfor %}

  // Agent configuration objects
{% for agent in agents %}
  `include "{{ agent.name }}_config.svh"
{% endfor %}

  // Testbench components (per agent)
{% for agent in agents %}
  `include "{{ agent.name }}_cover.svh"
  `include "{{ agent.name }}_driver.svh"
  `include "{{ agent.name }}_sequencer.svh"
  `include "{{ agent.name }}_monitor.svh"
  `include "{{ agent.name }}_agent.svh"
{% endfor %}

  // Scoreboard
  `include "sb_predictor.svh"
  `include "sb_comparator.svh"
  `include "tb_scoreboard.svh"

  // Environment
  `include "env_config.svh"
{% if register_model %}
  `include "{{ register_model.adapter }}.svh"
{% if register_model.frontdoor %}
  `include "{{ register_model.frontdoor }}.svh"
{% endif %}
{% endif %}
{% if vsequences %}
  `include "env_vsqr.svh"
  `include "env_vseq_base.svh"
{% endif %}
  `include "env.svh"

  // Sequences (per agent)
{% for agent in agents %}
  `include "{{ agent.name }}_sequence.svh"
{% for seq in agent.sequences %}
  `include "{{ seq.name }}.svh"
{% endfor %}
{% endfor %}
{% for vseq in vsequences %}
  `include "{{ vseq.name }}.svh"
{% endfor %}
  // pragma quickuvm custom sequences_additional begin
  // pragma quickuvm custom sequences_additional end

  // Tests
  `include "test_base.svh"
{% for test in tests %}
  `include "{{ test.name }}.svh"
{% endfor %}
{% if register_model and register_model.reg_test %}
  `include "reg_test.svh"
{% endif %}

  // Scoreboard expected-value calculator (extern function body)
  `include "sb_calc_exp.svh"

endpackage

`endif
