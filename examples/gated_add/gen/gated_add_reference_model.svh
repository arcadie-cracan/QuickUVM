function src_seq_item gated_add_predictor::predict(src_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  src_seq_item extr = src_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // y = a + bias, from the SAMPLED inputs (bias is 0 unless re-enabled).
  extr.y = 9'(extr.a) + 9'(extr.bias);
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
