class spi_driver extends uvm_driver #(spi_item);
  `uvm_component_utils(spi_driver)

  virtual spi_if vif;

  // --- LIVENESS. Generated, and deliberately NOT inside a pragma. ---------------------
  // A dead responder is UNPROVABLE PER-TRANSACTION: with no response the DUT never
  // captures anything, so expected and actual are both zero and EVERY compare agrees.
  // It has reported TEST PASSED 34/34 while the device was stone dead. The only thing
  // that catches it is an end-of-test check — so a responder without one must be
  // impossible to GENERATE, not merely discouraged in a doc.
  protected int unsigned m_responses;      // responses actually driven
  protected time         m_t0;             // guards an unfilled `drive_transfer` seam

  // pragma quickuvm custom class_item_additional begin
  // What this device will send NEXT. It is a function of how many frames have gone by —
  // NOT of the bits arriving right now, which is the whole point: on a full-duplex bus our
  // bit k goes out on the same edge their bit k comes in.
  int m_frames;
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  // PREFETCH responder — a FULL-DUPLEX device (SPI, and anything else that drives its
  // response on the same edge it samples the request).
  //
  // `get_next_item` comes FIRST, before we wait for the transfer to start. It has to: the
  // DUT samples MISO bit k on the very edge that drives MOSI bit k, so the response cannot
  // be a function of the request it accompanies — it must already be in our hands when the
  // first edge arrives. Waiting for the request and THEN fetching an item (what
  // `on_request` does) is structurally one transfer too late.
  //
  // This is exactly OpenTitan's spi_device_driver::get_and_drive(): get_next_item(req)
  // first, and only then `wait (!csb)`.
  //
  // The response is computed from PREVIOUS transfers. The driver is a class — hold that
  // state in `class_item_additional`.
  task run_phase(uvm_phase phase);
    spi_item tr;
    initialize();
    forever begin
      // THE ITEM COMES FIRST. Do not move this below the wait.
      seq_item_port.get_next_item(tr);
      // THE USER SEAM. The payload is in `tr`. Wait for the transfer to begin, then drive
      // it out and sample the DUT's own bits back in, edge by edge, on the protocol's
      // clock. Nothing here is generatable: no generator emits protocol logic (OpenTitan's
      // own uvmdvgen ships an EMPTY get_and_drive()).
      //
      m_t0 = $time;
      // pragma quickuvm custom drive_transfer begin
      // The payload is ALREADY in `tr` — fetched before we got here. Now do the protocol.
      //
      // Mode 0: the host samples MISO on the RISING edge, so we must change it on the
      // FALLING edge. Bit 7 has to be on the wire before the first rising edge ever
      // happens, i.e. while csb is still going low — there is no earlier edge to hang it
      // on. That is the zero-slack obligation `prefetch` exists to meet.
      @(negedge vif.csb);              // the host opened a frame
      vif.miso = tr.miso_byte[7];      // bit 7 out BEFORE any sck edge exists
      for (int i = 6; i >= 0; i--) begin
        @(negedge vif.clk);            // ...on the edge they do NOT sample on
                                       // (this agent's clock IS sck — the DUT drives it)
        vif.miso = tr.miso_byte[i];
      end
      @(posedge vif.csb);              // frame closed
      m_frames++;
      // pragma quickuvm custom drive_transfer end
      // An unfilled seam is caught HERE, OUTSIDE the pragma — a guard placed inside the
      // region it protects is deleted along with it. A real transfer must consume time
      // (it waits for the protocol's edges); one that returns in zero time drove nothing,
      // and the forever loop would then spin at the current timestep and HANG the
      // simulation. A hung bench reports nothing at all, which is worse than a failing one.
      if ($time == m_t0)
        `uvm_fatal("EMPTY_TRANSFER",
                   {"`drive_transfer` returned in ZERO TIME — the seam is empty, so this ",
                    "responder never drove anything. A prefetch responder must drive the ",
                    "transfer itself: no generator emits protocol logic."})
      // Counted HERE, after the transfer COMPLETED — not when the item was fetched.
      // Counting the fetch would make DEAD_RESPONDER blind to the failure it exists to
      // catch: a device driver parked forever inside `drive_transfer` (waiting on a frame
      // the DUT never opens) has fetched an item but driven NOTHING, and would report
      // itself alive. m_responses must mean "transfers I actually drove".
      m_responses++;
      seq_item_port.item_done();
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "spi_driver: Initialize (time @0)", UVM_HIGH)
    vif.miso <= '0;
    // This agent's clock is DRIVEN BY THE DUT (`source: dut`), so we must not burn clock
    // edges here. Such a clock is typically GATED — an SPI sck does not tick until the DUT
    // opens a frame — so the initiator's "wait 2 edges for the synchronizers to settle"
    // would sleep through the start of the FIRST transfer and miss it entirely. There is
    // nothing to settle anyway: a responder does not push stimulus into the DUT's input
    // synchronizers, it answers on the DUT's own clock.
    wait (vif.rst_n === 1'b1);
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (spi_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    m_responses++;
    vif.cb1.miso <= tr.miso;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // pragma quickuvm custom drive_item_additional end
  endtask

  function void check_phase (uvm_phase phase);
    super.check_phase(phase);
    if (m_responses == 0)
      `uvm_error("DEAD_RESPONDER",
                 {"this responder drove ZERO responses — the DUT never got an answer. ",
                  "Every per-transaction compare 'passed' because there was nothing to ",
                  "compare: with no response the DUT captures nothing, so expected and ",
                  "actual are both zero and they agree. Check that the DUT actually ",
                  "requests, and that request_valid names the right port."})
  endfunction

endclass
