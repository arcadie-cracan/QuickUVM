  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  // CONTINUOUS responder. The DUT samples our outputs EVERY cycle (a grant/ready/valid
  // obligation), so parking on a blocking get_next_item would leave them stale or X.
  // Hence: NON-BLOCKING try_next_item, drive a defined idle value on a miss, and advance
  // a cycle either way. (OpenHW OBI `uvma_obi_memory_drv`, CESNET OFM.)
  task run_phase(uvm_phase phase);
    mem_seq_item tr;
    initialize();
    fork
      // Per-cycle protocol threads (e.g. driving a combinational grant from the DUT's
      // request) go here. NO generator emits protocol logic — this is your seam.
      // pragma quickuvm custom driver_threads begin
      // pragma quickuvm custom driver_threads end
    join_none
    forever begin
      seq_item_port.try_next_item(tr);
      if (tr != null) begin
        drive_item(tr);
        seq_item_port.item_done();
      end
      else begin
        drive_idle();
        @vif.cb1;
      end
    end
  endtask

  // What to drive when there is no item — the `idle:` block in the config.
  virtual task drive_idle ();
    vif.cb1.gnt <= 1'd0;
    vif.cb1.rdata <= 32'd0;
    // pragma quickuvm custom drive_idle_additional begin
    // pragma quickuvm custom drive_idle_additional end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "mem_driver: Initialize (time @0)", UVM_HIGH)
    vif.gnt <= 1'd0;
    vif.rdata <= 32'd0;
    // Reset is driven externally: hold off BEFORE advancing a clock so the parked
    // idle values are all the DUT sees during reset; wait for deassertion, then let
    // the input synchronizers settle (2 = a typical 2-stage sync; raise for deeper).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (mem_seq_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    vif.cb1.gnt <= tr.gnt;
    vif.cb1.rdata <= tr.rdata;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // pragma quickuvm custom drive_item_additional end
  endtask

