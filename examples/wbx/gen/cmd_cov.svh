class cmd_cov extends uvm_subscriber #(cmd_item);
  `uvm_component_utils(cmd_cov)

  cmd_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    busy_cp : coverpoint tr.busy {bins busy_bins[8] = {[0:$]};}
    push_cp : coverpoint tr.push {bins push_bins[8] = {[0:$]};}
    data_cp : coverpoint tr.data {bins data_bins[8] = {[0:$]};}
    pop_cp : coverpoint tr.pop {bins pop_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (cmd_item t);
    tr = t;
    `uvm_info("cmd_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
