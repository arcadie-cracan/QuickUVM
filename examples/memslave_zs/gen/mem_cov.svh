class mem_cov extends uvm_subscriber #(mem_seq_item);
  `uvm_component_utils(mem_cov)

  mem_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    req_cp : coverpoint tr.req {bins req_bins[8] = {[0:$]};}
    addr_cp : coverpoint tr.addr {bins addr_bins[8] = {[0:$]};}
    last_data_cp : coverpoint tr.last_data {bins last_data_bins[8] = {[0:$]};}
    fetched_cp : coverpoint tr.fetched {bins fetched_bins[8] = {[0:$]};}
    missed_cp : coverpoint tr.missed {bins missed_bins[8] = {[0:$]};}
    gnt_cp : coverpoint tr.gnt {bins gnt_bins[8] = {[0:$]};}
    rdata_cp : coverpoint tr.rdata {bins rdata_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (mem_seq_item t);
    tr = t;
    `uvm_info("mem_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
