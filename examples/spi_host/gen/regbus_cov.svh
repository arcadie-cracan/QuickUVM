class regbus_cov extends uvm_subscriber #(regbus_item);
  `uvm_component_utils(regbus_cov)

  regbus_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    rdata_cp : coverpoint tr.rdata {bins rdata_bins[8] = {[0:$]};}
    addr_cp : coverpoint tr.addr {bins addr_bins[8] = {[0:$]};}
    req_cp : coverpoint tr.req {bins req_bins[8] = {[0:$]};}
    wr_cp : coverpoint tr.wr {bins wr_bins[8] = {[0:$]};}
    be_cp : coverpoint tr.be {bins be_bins[8] = {[0:$]};}
    wdata_cp : coverpoint tr.wdata {bins wdata_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (regbus_item t);
    tr = t;
    `uvm_info("regbus_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
