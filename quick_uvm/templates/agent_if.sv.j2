interface {{ agent.interface }}{{ agent.param_decl }} (input clk{% if agent_reset %}, input {{ agent_reset.name }}{% endif %});
  // Generated signals from config
{% for port in agent.output_ports %}
  logic {{ port.sv_span }}{{ port.name }};
{% endfor %}
{% for port in agent.input_ports %}
  logic {{ port.sv_span }}{{ port.name }};
{% endfor %}
{% if agent.has_inouts %}

  // Bidirectional (`inout`) nets. The DUT and the TB share the wire, so the TB must be
  // able to RELEASE it — hence a `wire` (resolved from both sides) plus a drive value and
  // an output enable that the driver owns.
{% for port in agent.inout_ports %}
  wire  {{ port.sv_span }}{{ port.name }};        // the RESOLVED line (what everyone sees)
  logic {{ port.sv_span }}{{ port.name }}_o;      // what WE drive
  logic {{ port.sv_span }}{{ port.name }}_oe;     // ...and whether we drive at all
{% if port.bit_width == 1 %}
{% if port.open_drain %}
  // OPEN-DRAIN: a driver may only pull LOW or release — it can never drive high. So
  // driving a 1 IS releasing, which is why the wired-AND works.
  assign {{ port.name }} = ({{ port.name }}_oe && !{{ port.name }}_o) ? 1'b0 : 1'bz;
{% else %}
  assign {{ port.name }} = {{ port.name }}_oe ? {{ port.name }}_o : {{ port.bit_width }}'bz;
{% endif %}
{% else %}
  // ONE ENABLE PER LANE, resolved independently. A single enable for the whole vector
  // would make a shared bus unusable: on standard SPI the host drives sd[0] while the
  // device drives sd[1] AT THE SAME INSTANT, so the two lanes must be released and
  // driven separately. A scalar enable can only say "all" or "none".
  for (genvar i = 0; i < {{ port.bit_width }}; i++) begin : g_{{ port.name }}_lane
{% if port.open_drain %}
    assign {{ port.name }}[i] = ({{ port.name }}_oe[i] && !{{ port.name }}_o[i]) ? 1'b0 : 1'bz;
{% else %}
    assign {{ port.name }}[i] = {{ port.name }}_oe[i] ? {{ port.name }}_o[i] : 1'bz;
{% endif %}
  end
{% endif %}
{% if port.pullup %}
  // The pullup. NOT a `pullup` primitive: primitives are illegal inside an interface
  // (*E,INFINS). A weak continuous assign is the legal equivalent — it loses to any real
  // driver and wins only when everyone has released, which is exactly a pullup.
  assign (weak1, weak0) {{ port.name }} = '1;   // nobody driving => reads 1, not X
{% endif %}
{% endfor %}
{% endif %}

  // pragma quickuvm custom signals_additional begin
  // pragma quickuvm custom signals_additional end

  clocking cb1 @(posedge clk);
    default input #1step output #{{ agent_clock_skew }};
{% for port in agent.output_ports %}
    input  {{ port.name }};
{% endfor %}
{% for port in agent.input_ports %}
{% if agent.active %}
    output {{ port.name }};
{% else %}
    input  {{ port.name }};
{% endif %}
{% endfor %}
{% for port in agent.inout_ports %}
    // We drive <n>_o/<n>_oe and sample the RESOLVED <n> — never the value we drove.
{% if agent.active %}
    output {{ port.name }}_o, {{ port.name }}_oe;
{% endif %}
    input  {{ port.name }};
{% endfor %}

    // pragma quickuvm custom clocking_block_additional begin
    // pragma quickuvm custom clocking_block_additional end
  endclocking
{% if dut.combinational %}

  // Monitor clocking block: sample ALL observed signals (driven inputs AND DUT
  // outputs) race-free at #1step before posedge — one consistent snapshot/cycle.
  clocking mon_cb @(posedge clk);
    default input #1step;
{% for kind, port in agent.all_ports %}
    input {{ port.name }};
{% endfor %}
  endclocking
{% endif %}
{% if agent.assertions %}

  //----------------------------------------------------------------------
  // K1 — interface protocol checker (opt-in). A sample property + a hook for
  // your own SVA, sampling on this interface's clk/reset domain.
  //----------------------------------------------------------------------
{% set _rst = agent_reset or agent_driven_reset %}
{% if _rst and agent.output_ports %}
{% set _out = agent.output_ports[0].name %}
  // Sample: an output is never X/Z once reset is deasserted (replace/extend below).
  a_{{ _out }}_known: assert property (
      @(posedge clk) disable iff ({% if _rst.active_low %}!{% endif %}{{ _rst.name }}) !$isunknown({{ _out }}))
    else $error("{{ agent.interface }} checker: {{ _out }} X after reset");
{% endif %}
  // pragma quickuvm custom sva_properties begin
  //   Add interface protocol assertions here, e.g.:
  //   a_req_ack: assert property (@(posedge clk) req |-> ##[1:3] ack);
  // pragma quickuvm custom sva_properties end
{% endif %}
endinterface
