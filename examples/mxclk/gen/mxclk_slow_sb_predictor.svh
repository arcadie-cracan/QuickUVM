// The predictor:
//   - subscribes to the monitor's analysis port
//   - ignores sampled DUT outputs
//   - calls predict() to predict the expected output
//   - writes the predicted transaction to results_ap
//----------------------------------------------------------------------

class mxclk_slow_sb_predictor extends uvm_subscriber #(slow_item);
  `uvm_component_utils(mxclk_slow_sb_predictor)

  uvm_analysis_port #(slow_item) results_ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write(slow_item t);
    slow_item exp_tr;
    exp_tr = predict(t);
    results_ap.write(exp_tr);
  endfunction

  extern function slow_item predict(slow_item t);

endclass
