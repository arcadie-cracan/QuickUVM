// Implement regfile_predictor::predict() here.
// This function receives the sampled transaction (inputs + outputs as
// driven to/from DUT) and must return a NEW transaction with the
// EXPECTED output values filled in.
//
// Edit the "prediction_logic" user section below.
//----------------------------------------------------------------------

function host_seq_item regfile_predictor::predict(host_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  host_seq_item extr = host_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Golden model of rtl/regfile.sv: four 16-bit regs at addr[2:1], one access per
  // cycle. The monitor re-samples its inputs at the same edge as the combinational
  // rdata (see host_monitor sample_dut_additional), so each transaction is a clean
  // (addr, wr, wdata, rdata) tuple for one cycle. The DUT reads combinationally and
  // writes on the same posedge (NBA) -> rdata is the PRE-write value, then the
  // write commits: model read first, then updated.
  begin
    logic [1:0] idx = extr.addr[2:1];
    // static => the modelled register state persists across calls; initialised to
    // the DUT's reset values (monitoring starts after reset deasserts).
    static logic [15:0] model[4] = '{16'h0000, 16'h00FF, 16'hDEAD, 16'hBEEF};
    extr.rdata = model[idx];              // combinational read (pre-write)
    if (extr.wr) model[idx] = extr.wdata;  // write commits this cycle
  end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
