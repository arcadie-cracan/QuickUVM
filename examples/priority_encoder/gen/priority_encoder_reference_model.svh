function pe_seq_item priority_encoder_predictor::predict(pe_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  pe_seq_item extr = pe_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Golden model (combinational): idx = highest set bit of req; valid = |req. N=8.
  extr.idx   = '0;
  extr.valid = 1'b0;
  for (int i = 0; i < 8; i++)
    if (t.req[i]) begin
      extr.idx   = i[2:0];   // loop low->high, so highest set bit wins
      extr.valid = 1'b1;
    end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
