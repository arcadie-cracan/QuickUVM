class src_cov extends uvm_subscriber #(src_seq_item);
  `uvm_component_utils(src_cov)

  src_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    y_cp : coverpoint tr.y {bins y_bins[8] = {[0:$]};}
    a_cp : coverpoint tr.a {bins a_bins[8] = {[0:$]};}
    bias_cp : coverpoint tr.bias {bins bias_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (src_seq_item t);
    tr = t;
    `uvm_info("src_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
