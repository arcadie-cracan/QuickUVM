class sdio_item extends uvm_sequence_item;
  `uvm_object_utils(sdio_item)

  // Output fields (not randomized — sampled from DUT)
       logic csb;

  // Input fields (driven to DUT)

  // Bidirectional (inout) fields. Three per line, because a shared wire needs all three:
  //   <n>_o   what we drive        (rand)
  //   <n>_oe  whether we drive     (rand) — releasing is a first-class choice
  //   <n>     the RESOLVED line    (sampled; never what we drove)
  rand bit [3:0] sd_o;
  rand bit [3:0] sd_oe;
       logic [3:0] sd;

  // pragma quickuvm custom class_item_additional begin
  // What this device will shift out on the next frame. Not a DUT port — it is our own
  // payload, so it lives here rather than in `ports:`.
  rand bit [7:0] miso_byte;
  // pragma quickuvm custom class_item_additional end

  function new (string name="sdio_item");
    super.new(name);
  endfunction

  function void do_copy(uvm_object rhs);
    sdio_item tr;
    if(!$cast(tr, rhs)) `uvm_fatal("sdio_item", "ILLEGAL do_copy() cast")
    super.do_copy(rhs);
    csb = tr.csb;
    // All THREE, or a predictor that copies the item loses the drive state and models a
    // bus nobody was driving.
    sd    = tr.sd;
    sd_o  = tr.sd_o;
    sd_oe = tr.sd_oe;

    // pragma quickuvm custom do_copy_additional begin
    // pragma quickuvm custom do_copy_additional end
  endfunction

  function bit do_compare(uvm_object rhs, uvm_comparer comparer);
    sdio_item tr;
    bit eq;
    if(!$cast(tr, rhs)) `uvm_fatal("sdio_item", "ILLEGAL do_compare() cast")
    eq  = super.do_compare(rhs, comparer);
    eq &= (csb === tr.csb);
    // The RESOLVED shared line is an OBSERVABLE — compare it. (Not <n>_o/<n>_oe: those
    // are what WE drove, so comparing them would only prove we drove what we drove.)
    // `===` matters here: a floating tri-state resolves to X, and `==` would silently
    // return X rather than a mismatch.
    eq &= (sd === tr.sd);

    // pragma quickuvm custom do_compare_additional begin
    // pragma quickuvm custom do_compare_additional end
    return(eq);
  endfunction


  function void do_print(uvm_printer printer);
    $display("\n\n\t\t*** print()/sprint() not implemented for this transaction type ***\n\n");
  endfunction

  virtual function string input2string();
    string s = "";
    return(s);
  endfunction

  virtual function string output2string();
    string s = "";
    // Print the shared line AND who was holding it — a bare `sda=x` with no drive state
    // is unreadable, and a tri-state mismatch is exactly when you need to know.
    s = {s, $sformatf("sd=%b(o=%b,oe=%b)  ", sd, sd_o, sd_oe)};
    s = {s, $sformatf("csb=%b  ", csb)};
    return(s);
  endfunction

  virtual function string convert2string();
    // pragma quickuvm custom convert2string_additional begin
    return({input2string(), "  ", output2string()});
    // pragma quickuvm custom convert2string_additional end
  endfunction

endclass
