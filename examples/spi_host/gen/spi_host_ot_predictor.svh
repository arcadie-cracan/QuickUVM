//----------------------------------------------------------------------
// The predictor:
//   - subscribes to the monitor's analysis port
//   - ignores sampled DUT outputs
//   - calls predict() to predict the expected output
//   - writes the predicted transaction to results_ap
//----------------------------------------------------------------------

class spi_host_ot_predictor extends uvm_subscriber #(regbus_item);
  `uvm_component_utils(spi_host_ot_predictor)

  uvm_analysis_port #(regbus_item) results_ap;

  // pragma quickuvm custom class_item_additional begin
  // What the host must have RECEIVED is derived from OUR OWN model of the device — the
  // same function the responder sequence uses, written out independently. Never from
  // anything observed on the wire: predicting from the observed value would be a tautology
  // that a device sending the WRONG byte would still pass.
  int m_rx_reads;

  function bit [7:0] device_byte(int n);
    return 8'hA5 ^ 8'(n);
  endfunction

  // LIVENESS. If the DUT never drives (CONTROL.OUTPUT_EN forgotten), the bus floats to the
  // PULL-UP value and looks quiet and legal — no X, no error. Nothing per-transaction can
  // catch that: it needs an end-of-test assertion that data actually came back.
  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (m_rx_reads == 0)
      `uvm_error("NO_RXDATA",
                 {"the bench never read a single byte back from the DUT — no SPI frame ",
                  "ever completed. Check CONTROL.OUTPUT_EN and CONTROL.SPIEN."})
  endfunction
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write(regbus_item t);
    regbus_item exp_tr;
    exp_tr = predict(t);
    results_ap.write(exp_tr);
  endfunction

  extern function regbus_item predict(regbus_item t);

endclass
