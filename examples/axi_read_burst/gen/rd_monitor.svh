class rd_monitor extends uvm_monitor;
  `uvm_component_utils(rd_monitor)

  virtual rd_if vif;

  uvm_analysis_port #(rd_item) ap;
  // Reactive agent: publish the DUT's REQUEST as soon as it is decoded, on a SECOND
  // port. The responder sequence blocks on this (via the sequencer's TLM FIFO) and
  // computes the response. The monitor already decodes the protocol for passive mode,
  // so this duplicates nothing — which is exactly why the driver does NOT decode it.
  uvm_analysis_port #(rd_item) request_ap;
  // Edge-detect state for the request qualifier (see run_phase).
  bit m_req_seen;

  // pragma quickuvm custom class_item_additional begin
  // UVM-side BURST ORACLE. The automated verdict is UVM-severity based (see gen/Makefile), so a
  // DUT $error is INVISIBLE to it — the burst-correctness must be carried by a UVM_ERROR. This
  // derives the expected R-beat sequence from the observed AR (id, address, length) and flags a
  // wrong beat count, RLAST framing, or data as a UVM_ERROR. It is the verdict-carrying check;
  // the DUT's own self-check stays as human-readable corroboration (the axi_read pattern).
  bit        m_bchk_active;   // a burst is in flight (AR seen, its R beats expected)
  bit [3:0]  m_bchk_id;       // expected rid
  bit [31:0] m_bchk_addr;     // AR address: expected data[beat] = addr + beat
  int        m_bchk_len;      // ARLEN
  int        m_bchk_beat;     // next expected beat index
  int        m_bchk_done;     // completed bursts (a liveness floor)

  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (m_bchk_active)
      `uvm_error("BURST_CHK", "test ended mid-burst: a read was stranded (missing R beats)")
    if (m_bchk_done == 0)
      `uvm_error("BURST_CHK", "no burst completed — vacuous test")
  endfunction
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
    request_ap = new("request_ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    rd_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      // The DUT issued a request -> hand it to the responder sequence.
      //
      // On the RISING EDGE of the qualifier, not its level. A request line is normally HELD
      // until it is granted, so a level-triggered publish would queue one copy per cycle and
      // the responder would answer the same request many times (over-granting, and the
      // response held for extra cycles).
      if (tr.arvalid && !m_req_seen) request_ap.write(tr);
      m_req_seen = tr.arvalid;
      ap.write(tr);
    end
  endtask

  task sample_dut (output rd_item tr);
    rd_item t;
    t = rd_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------
    t.rvalid = vif.rvalid;
    t.rid = vif.rid;
    t.rdata = vif.rdata;
    t.rlast = vif.rlast;

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.arvalid = vif.cb1.arvalid;
    t.arid = vif.cb1.arid;
    t.araddr = vif.cb1.araddr;
    t.arlen = vif.cb1.arlen;

    // pragma quickuvm custom sample_dut_additional begin
    // BURST ORACLE (state declared in class_item_additional). Start a burst on the rising edge
    // of arvalid (m_req_seen holds the previous cycle's level); then check every R beat —
    // rvalid is held across the burst, so each high cycle is a distinct beat.
    if (t.arvalid && !m_req_seen) begin
      if (m_bchk_active)
        `uvm_error("BURST_CHK", "new AR while the previous burst was still incomplete")
      m_bchk_active = 1'b1;
      m_bchk_id     = t.arid;
      m_bchk_addr   = t.araddr;
      m_bchk_len    = int'(t.arlen);
      m_bchk_beat   = 0;
    end
    if (t.rvalid) begin
      if (!m_bchk_active)
        `uvm_error("BURST_CHK", "R beat with no outstanding read")
      else begin
        if (t.rid !== m_bchk_id)
          `uvm_error("BURST_CHK", $sformatf("beat %0d: rid=%0d expected %0d",
                     m_bchk_beat, t.rid, m_bchk_id))
        if (t.rdata !== (m_bchk_addr + m_bchk_beat))
          `uvm_error("BURST_CHK", $sformatf("beat %0d: rdata=0x%0h expected 0x%0h",
                     m_bchk_beat, t.rdata, m_bchk_addr + m_bchk_beat))
        if (t.rlast !== (m_bchk_beat == m_bchk_len))
          `uvm_error("BURST_CHK", $sformatf("beat %0d: rlast=%0b expected %0b",
                     m_bchk_beat, t.rlast, (m_bchk_beat == m_bchk_len)))
        if (t.rlast) begin m_bchk_active = 1'b0; m_bchk_done++; end
        else m_bchk_beat++;
      end
    end
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
