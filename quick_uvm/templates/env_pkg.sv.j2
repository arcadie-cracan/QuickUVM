//----------------------------------------------------------------------
// This File: {{ dut.name }}_env_pkg.sv
// Generated by: QuickUVM
// Project:  {{ project.name }}
// Author:   {{ project.author }}
// SPDX-License-Identifier: MIT
//----------------------------------------------------------------------
// Environment package (F2 packaged layout): the scoreboard + env, importing
// every agent VIP package. See {{ dut.name }}_env_pkg.f.
//----------------------------------------------------------------------

`ifndef {{ dut.name | upper }}_ENV_PKG__SV
`define {{ dut.name | upper }}_ENV_PKG__SV

`include "uvm_macros.svh"

package {{ dut.name }}_env_pkg;
  import uvm_pkg::*;
{% if register_model %}
  import {{ register_model.package }}::*;
{% endif %}
{% for agent in agents %}
  import {{ agent.name }}_pkg::*;
{% endfor %}
{% for pkg in project.imports %}
  import {{ pkg }}::*;
{% endfor %}
  // pragma quickuvm custom imports begin
  // pragma quickuvm custom imports end

  // Scoreboard{{ 's (one typed set per scoreboard)' if sb_multi else '' }}
{% if sb_multi %}
{% for sb in analysis.scoreboards %}
{% set p = dut.name ~ '_' ~ sb.name %}
  `include "{{ p }}_predictor.svh"
  `include "{{ p }}_comparator.svh"
  `include "{{ p }}_scoreboard.svh"
{% endfor %}
{% else %}
  `include "{{ dut.name }}_predictor.svh"
  `include "{{ dut.name }}_comparator.svh"
  `include "{{ dut.name }}_scoreboard.svh"
{% endif %}

  // Environment
  `include "{{ dut.name }}_env_cfg.svh"
{% if register_model %}
  `include "{{ register_model.adapter }}.svh"
{% if register_model.frontdoor %}
  `include "{{ register_model.frontdoor }}.svh"
{% endif %}
{% endif %}
{% if virtual_sequences %}
  `include "{{ dut.name }}_virtual_sequencer.svh"
  `include "{{ dut.name }}_base_vseq.svh"
{% endif %}
  `include "{{ dut.name }}_env.svh"
{% for vseq in virtual_sequences %}
  `include "{{ vseq.name }}.svh"
{% endfor %}
  // pragma quickuvm custom sequences_additional begin
  // pragma quickuvm custom sequences_additional end

  // Scoreboard expected-value calculator (extern function body)
{% if sb_multi %}
{% for sb in analysis.scoreboards %}
  `include "{{ dut.name }}_{{ sb.name }}_reference_model.svh"
{% endfor %}
{% else %}
  `include "{{ dut.name }}_reference_model.svh"
{% endif %}

endpackage

`endif
