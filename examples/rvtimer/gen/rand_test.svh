    super.build_phase(phase);
  endfunction

  task run_phase(uvm_phase phase);
    host_seq seq;
    seq = host_seq::type_id::create("seq");
    //----------------------------------------------------
    phase.raise_objection(this);
    `uvm_info("rand_test", "about to start seq", UVM_FULL)
    seq.start(e.host_agnt.sqr);
    // pragma quickuvm custom run_phase_additional begin
    // Directed timer-interrupt check (the rv_timer behaviour, driven via the RAL):
    // arm a short compare + enable, poll INTR_STATE until the interrupt pends, then
    // disable and confirm it clears. Exercises the golden interrupt path end-to-end.
    begin
      uvm_status_e   st;
      uvm_reg_data_t v;
      int unsigned   polls = 0;
      env_cfg.reg_model.cfg.write(st, 16'h0001);          // step = 1
      env_cfg.reg_model.mtimecmp.write(st, 16'h0008);     // small compare
      env_cfg.reg_model.intr_enable.write(st, 16'h0001);  // enable interrupt output
      env_cfg.reg_model.ctrl.write(st, 16'h0001);         // enable timer
      // each frontdoor read burns a bus cycle while the timer counts (step=1), so
      // within ~10 polls mtime reaches the compare and INTR_STATE latches.
      do begin
        env_cfg.reg_model.intr_state.read(st, v);
        polls++;
      end while (v[0] !== 1'b1 && polls < 50);
      if (v[0] !== 1'b1)
        `uvm_error("RVTIMER", "interrupt did not assert after arming the timer")
      else
        `uvm_info("RVTIMER", "timer interrupt asserted as expected", UVM_LOW)
      env_cfg.reg_model.ctrl.write(st, 16'h0000);         // disable -> clears pending
      env_cfg.reg_model.intr_state.read(st, v);
      if (v[0] !== 1'b0)
        `uvm_error("RVTIMER", "interrupt did not clear after disabling the timer")
      else
        `uvm_info("RVTIMER", "timer interrupt cleared on disable", UVM_LOW)
    end
    // pragma quickuvm custom run_phase_additional end
    phase.drop_objection(this);
  endtask

