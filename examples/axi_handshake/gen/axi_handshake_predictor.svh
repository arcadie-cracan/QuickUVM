    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write(rd_item t);
    rd_item exp_tr;
    exp_tr = predict(t);
    results_ap.write(exp_tr);
  endfunction

  extern function rd_item predict(rd_item t);

endclass
