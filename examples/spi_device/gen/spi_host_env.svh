class spi_host_env extends uvm_env;
  `uvm_component_utils(spi_host_env)

  // Agent handles
  spi_agent  spi_agnt;

  // Scoreboards
  spi_host_scoreboard sb;

  // Functional coverage (per agent)
  spi_cov spi_cov_h;

  // Environment configuration
  spi_host_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(spi_host_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No spi_host_env_cfg set for: ", get_full_name()})
    uvm_config_db#(spi_cfg)::set(this, "spi_agnt", "cfg", env_cfg.spi_cfg);
    spi_agnt = spi_agent::type_id::create("spi_agnt", this);
    sb = spi_host_scoreboard::type_id::create("sb", this);
    spi_cov_h = spi_cov::type_id::create("spi_cov_h", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Declared analysis connectivity (per analysis: block)
    spi_agnt.ap.connect(sb.axp);
    spi_agnt.ap.connect(spi_cov_h.analysis_export);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
