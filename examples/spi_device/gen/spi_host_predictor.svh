//----------------------------------------------------------------------
// The predictor:
//   - subscribes to the monitor's analysis port
//   - ignores sampled DUT outputs
//   - calls predict() to predict the expected output
//   - writes the predicted transaction to results_ap
//----------------------------------------------------------------------

class spi_host_predictor extends uvm_subscriber #(spi_item);
  `uvm_component_utils(spi_host_predictor)

  uvm_analysis_port #(spi_item) results_ap;

  // pragma quickuvm custom class_item_additional begin
  // The device's payload is a function of the FRAME INDEX — the same function the sequence
  // uses, written out independently. Expected rx_byte is derived from that, NEVER from the
  // miso we observed on the wire: predicting from the observed value would be a tautology
  // that a device sending the WRONG byte would still pass.
  bit [7:0] m_expect;
  int       m_frames;

  function bit [7:0] device_byte(int n);
    return 8'hA5 ^ 8'(n);
  endfunction

  // LIVENESS. A device that never drives leaves the host reading its idle line — and a
  // predictor that echoed the bus would happily agree. Nothing per-transaction can catch
  // "the device never spoke": it needs an end-of-test assertion that frames actually
  // completed.
  function void check_phase(uvm_phase phase);
    super.check_phase(phase);
    if (m_frames == 0)
      `uvm_error("NO_FRAMES",
                 "the host completed ZERO frames — nothing was ever transferred")
  endfunction
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write(spi_item t);
    spi_item exp_tr;
    exp_tr = predict(t);
    results_ap.write(exp_tr);
  endfunction

  extern function spi_item predict(spi_item t);

endclass
