class rd_cov extends uvm_subscriber #(rd_seq_item);
  `uvm_component_utils(rd_cov)

  rd_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    rd_data_cp : coverpoint tr.rd_data {bins rd_data_bins[8] = {[0:$]};}
    empty_cp : coverpoint tr.empty {bins empty_bins[8] = {[0:$]};}
    rd_en_cp : coverpoint tr.rd_en {bins rd_en_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (rd_seq_item t);
    tr = t;
    `uvm_info("rd_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
