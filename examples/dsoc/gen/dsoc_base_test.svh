    env_cfg = dsoc_env_cfg::type_id::create("env_cfg");

    // Block: left (left_lane)
    env_cfg.left_cfg = left_lane_env_cfg::type_id::create("left_cfg");
    uvm_config_db#(left_lane_env_cfg)::set(this, "e.left", "env_cfg", env_cfg.left_cfg);

    // Block: src (left_src)
    env_cfg.left_cfg.src_cfg = left_src_env_cfg::type_id::create("src_cfg");
    env_cfg.left_cfg.src_cfg.left_sa_cfg = left_sa_cfg::type_id::create("left_sa_cfg");
    env_cfg.left_cfg.src_cfg.left_sa_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual left_src_if)::get(
          this, "", "left_src_left_src_if_vif", env_cfg.left_cfg.src_cfg.left_sa_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'left_src_left_src_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(left_src_env_cfg)::set(this, "e.left.src", "env_cfg", env_cfg.left_cfg.src_cfg);

    // Block: snk (left_snk)
    env_cfg.left_cfg.snk_cfg = left_snk_env_cfg::type_id::create("snk_cfg");
    env_cfg.left_cfg.snk_cfg.left_ka_cfg = left_ka_cfg::type_id::create("left_ka_cfg");
    env_cfg.left_cfg.snk_cfg.left_ka_cfg.is_active = UVM_PASSIVE;
    if (!uvm_config_db#(virtual left_snk_if)::get(
          this, "", "left_snk_left_snk_if_vif", env_cfg.left_cfg.snk_cfg.left_ka_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'left_snk_left_snk_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(left_snk_env_cfg)::set(this, "e.left.snk", "env_cfg", env_cfg.left_cfg.snk_cfg);

    // Block: right (right_lane)
    env_cfg.right_cfg = right_lane_env_cfg::type_id::create("right_cfg");
    uvm_config_db#(right_lane_env_cfg)::set(this, "e.right", "env_cfg", env_cfg.right_cfg);

    // Block: src (right_src)
    env_cfg.right_cfg.src_cfg = right_src_env_cfg::type_id::create("src_cfg");
    env_cfg.right_cfg.src_cfg.right_sa_cfg = right_sa_cfg::type_id::create("right_sa_cfg");
    env_cfg.right_cfg.src_cfg.right_sa_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual right_src_if)::get(
          this, "", "right_src_right_src_if_vif", env_cfg.right_cfg.src_cfg.right_sa_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'right_src_right_src_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(right_src_env_cfg)::set(
        this, "e.right.src", "env_cfg", env_cfg.right_cfg.src_cfg);

    // Block: snk (right_snk)
    env_cfg.right_cfg.snk_cfg = right_snk_env_cfg::type_id::create("snk_cfg");
    env_cfg.right_cfg.snk_cfg.right_ka_cfg = right_ka_cfg::type_id::create("right_ka_cfg");
    env_cfg.right_cfg.snk_cfg.right_ka_cfg.is_active = UVM_PASSIVE;
    if (!uvm_config_db#(virtual right_snk_if)::get(
          this, "", "right_snk_right_snk_if_vif", env_cfg.right_cfg.snk_cfg.right_ka_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'right_snk_right_snk_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(right_snk_env_cfg)::set(
        this, "e.right.snk", "env_cfg", env_cfg.right_cfg.snk_cfg);

    uvm_config_db#(dsoc_env_cfg)::set(this, "e", "env_cfg", env_cfg);
