function vu_seq_item vec_unit_predictor::predict(vu_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  vu_seq_item extr = vu_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Typed access to the packed struct (hdr.en / hdr.tag) and packed array (lanes[i]).
  extr.sum = '0;
  if (extr.hdr.en) begin
    for (int i = 0; i < 4; i++) extr.sum = extr.sum + 10'(extr.lanes[i]);
  end
  extr.tag_out = extr.hdr.tag;
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
