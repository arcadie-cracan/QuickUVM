//----------------------------------------------------------------------
// Top (subsystem) base test — builds the top env config, populates each child
// block's env config (agent cfgs + virtual interfaces from the config DB), and
// hands each child env its config so the composed tree self-configures.
//----------------------------------------------------------------------

class chip_base_test extends uvm_test;
  `uvm_component_utils(chip_base_test)

  chip_env e;
  chip_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    env_cfg = chip_env_cfg::type_id::create("env_cfg");

    // Block: add (add)
    env_cfg.add_cfg = add_env_cfg::type_id::create("add_cfg");
    env_cfg.add_cfg.a_cfg = a_cfg::type_id::create("a_cfg");
    env_cfg.add_cfg.a_cfg.is_active = UVM_PASSIVE;
    if (!uvm_config_db#(virtual a_if)::get(
          this, "", "add_a_if_vif", env_cfg.add_cfg.a_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'add_a_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(add_env_cfg)::set(this, "e.add", "env_cfg", env_cfg.add_cfg);

    // Block: inv (inv)
    env_cfg.inv_cfg = inv_env_cfg::type_id::create("inv_cfg");
    env_cfg.inv_cfg.b_cfg = b_cfg::type_id::create("b_cfg");
    env_cfg.inv_cfg.b_cfg.is_active = UVM_PASSIVE;
    if (!uvm_config_db#(virtual b_if)::get(
          this, "", "inv_b_if_vif", env_cfg.inv_cfg.b_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'inv_b_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(inv_env_cfg)::set(this, "e.inv", "env_cfg", env_cfg.inv_cfg);


    // H2 — boundary agent: host
    env_cfg.host_cfg_h = host_cfg::type_id::create("host_cfg");
    env_cfg.host_cfg_h.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual host_if)::get(
          this, "", "host_if_vif", env_cfg.host_cfg_h.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'host_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(chip_env_cfg)::set(this, "e", "env_cfg", env_cfg);
    e = chip_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    `uvm_info("TB", "chip_base_test: end_of_elaboration", UVM_FULL)
  endfunction

endclass
