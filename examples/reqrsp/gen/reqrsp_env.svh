class reqrsp_env extends uvm_env;
  `uvm_component_utils(reqrsp_env)

  // Agent handles
  req_agent  req_agnt;
  rsp_agent  rsp_agnt;

  // Scoreboards
  reqrsp_scoreboard sbd;

  // Functional coverage (per agent)

  // Environment configuration
  reqrsp_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(reqrsp_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No reqrsp_env_cfg set for: ", get_full_name()})
    uvm_config_db#(req_cfg)::set(this, "req_agnt", "cfg", env_cfg.req_cfg);
    req_agnt = req_agent::type_id::create("req_agnt", this);
    uvm_config_db#(rsp_cfg)::set(this, "rsp_agnt", "cfg", env_cfg.rsp_cfg);
    rsp_agnt = rsp_agent::type_id::create("rsp_agnt", this);
    sbd = reqrsp_scoreboard::type_id::create("sbd", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Declared analysis connectivity (per analysis: block)
    req_agnt.ap.connect(sbd.src_axp);
    rsp_agnt.ap.connect(sbd.mon_axp);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
