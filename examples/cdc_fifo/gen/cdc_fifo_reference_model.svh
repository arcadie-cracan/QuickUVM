// Two-stream scoreboard: `t` is the observed wr (request) item;
// return the EXPECTED rd (response) item it should produce.
function rd_item cdc_fifo_predictor::predict(wr_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  rd_item extr = rd_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // pragma quickuvm custom prediction_logic begin
  // A FIFO is order-preserving and lossless: the Nth word pushed (t.wdata) is the Nth
  // word popped. So the expected popped word is identity of the pushed word, qualified as
  // a real transfer. The in-order comparator matches this against the read-domain stream
  // ACROSS the clock crossing.
  extr.rdata  = t.wdata;
  extr.rvalid = 1'b1;
  extr.rxfer  = 1'b1;
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
