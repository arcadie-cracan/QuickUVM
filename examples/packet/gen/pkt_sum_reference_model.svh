function stream_seq_item pkt_sum_predictor::predict(stream_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  stream_seq_item extr = stream_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Reference checksum: sum the first `len` bytes packed (low-byte-first) in `data`.
  extr.sum = '0;
  for (int i = 0; i < 16; i++) begin
    if (i < int'(extr.len)) extr.sum = extr.sum + 16'(extr.data[i*8+:8]);
  end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
