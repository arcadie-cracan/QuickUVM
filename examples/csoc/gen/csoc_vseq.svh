class csoc_vseq extends csoc_base_vseq;
  `uvm_object_utils(csoc_vseq)

  function new (string name = "csoc_vseq");
    super.new(name);
  endfunction

  task body;
    a_seq acc_a_seq;
    m_seq mul_m_seq;

    acc_a_seq = a_seq::type_id::create("acc_a_seq");
    mul_m_seq = m_seq::type_id::create("mul_m_seq");
    // pragma quickuvm custom vseq_body_pre begin
    // pragma quickuvm custom vseq_body_pre end
    // Run every block's stimulus concurrently
    fork
      acc_a_seq.start(p_sequencer.acc_a_sqr);
      mul_m_seq.start(p_sequencer.mul_m_sqr);
    join
    // pragma quickuvm custom vseq_body_post begin
    // pragma quickuvm custom vseq_body_post end
  endtask

endclass
