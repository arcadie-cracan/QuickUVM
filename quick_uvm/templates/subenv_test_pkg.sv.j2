//----------------------------------------------------------------------
// This File: {{ dut.name }}_test_pkg.sv
// Generated by: QuickUVM
// Project:  {{ project.name }}
// Author:   {{ project.author }}
// SPDX-License-Identifier: MIT
//----------------------------------------------------------------------
// Top (subsystem) test package: imports every composed block's env package
// (and its agent VIP packages), then adds the top env + coordination layer.
//----------------------------------------------------------------------

`include "uvm_macros.svh"
package {{ dut.name }}_test_pkg;
  import uvm_pkg::*;
{% for pkg in leaf_env_pkgs %}
  import {{ pkg }}::*;
{% endfor %}
{% for pkg in leaf_agent_pkgs %}
  import {{ pkg }}::*;
{% endfor %}
{% for agent in boundary_agents %}
  import {{ agent.name }}_pkg::*;
{% endfor %}
{% for level in composition_levels %}
{% if level.subenv_scoreboards %}

  // Cross-block scoreboards (typed on the source/monitor blocks' transactions)
{% for sb in level.subenv_scoreboards %}
  `include "{{ level.dut.name }}_{{ sb.name }}_predictor.svh"
  `include "{{ level.dut.name }}_{{ sb.name }}_comparator.svh"
  `include "{{ level.dut.name }}_{{ sb.name }}_scoreboard.svh"
{% endfor %}
{% endif %}

  // {% if loop.last %}Top{% else %}{{ level.dut.name }}{% endif %} environment + coordination
  `include "{{ level.dut.name }}_env_cfg.svh"
  `include "{{ level.dut.name }}_virtual_sequencer.svh"
  `include "{{ level.dut.name }}_env.svh"
  `include "{{ level.dut.name }}_base_vseq.svh"
  `include "{{ level.dut.name }}_vseq.svh"
{% endfor %}

  // Tests
  `include "{{ dut.name }}_base_test.svh"
{% for test in tests %}
  `include "{{ test.name }}.svh"
{% endfor %}
{% for level in composition_levels %}
{% for sb in level.subenv_scoreboards %}
  `include "{{ level.dut.name }}_{{ sb.name }}_reference_model.svh"
{% endfor %}
{% endfor %}

endpackage
