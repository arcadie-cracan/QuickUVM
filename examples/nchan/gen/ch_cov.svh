class ch_cov extends uvm_subscriber #(ch_item);
  `uvm_component_utils(ch_cov)

  ch_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    q_cp : coverpoint tr.q {bins q_bins[8] = {[0:$]};}
    d_cp : coverpoint tr.d {bins d_bins[8] = {[0:$]};}
    v_cp : coverpoint tr.v {bins v_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (ch_item t);
    tr = t;
    `uvm_info("ch_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
