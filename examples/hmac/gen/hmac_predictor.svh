//----------------------------------------------------------------------
// The predictor:
//   - subscribes to the monitor's analysis port
//   - ignores sampled DUT outputs
//   - calls predict() to predict the expected output
//   - writes the predicted transaction to results_ap
//----------------------------------------------------------------------

class hmac_predictor extends uvm_subscriber #(host_seq_item);
  `uvm_component_utils(hmac_predictor)

  uvm_analysis_port #(host_seq_item) results_ap;

  // pragma quickuvm custom class_item_additional begin
  // ---- streaming golden-model state -------------------------------------
  // THE POINT OF THIS BENCH. K0's predict() is `one item in -> one expected item out`,
  // but HMAC's model is a stateful stream: message words accumulate, a CSR write
  // triggers the hash, and the digest is served back much later across a register
  // array. That works ONLY because predict() is a METHOD ON THIS CLASS, so the stream
  // can be reconstructed from the transaction sequence and held here.
  bit [31:0] m_cfg;
  bit [31:0] m_key   [8];    // KEY_0..7 (Key_256)
  bit [7:0]  m_msg   [$];    // the accumulated message, byte-wise
  bit [31:0] m_dgst  [8];    // the expected digest, computed at hash_process
  bit        m_valid;        // has a digest been computed since the last hash_start?
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    results_ap = new("results_ap", this);
  endfunction

  function void write(host_seq_item t);
    host_seq_item exp_tr;
    exp_tr = predict(t);
    results_ap.write(exp_tr);
  endfunction

  extern function host_seq_item predict(host_seq_item t);

endclass
