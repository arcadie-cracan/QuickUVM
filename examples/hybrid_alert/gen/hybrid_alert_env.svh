class hybrid_alert_env extends uvm_env;
  `uvm_component_utils(hybrid_alert_env)

  // Agent handles
  sndr_agent  sndr_agnt;

  // Scoreboards
  hybrid_alert_scoreboard sb;

  // Functional coverage (per agent)
  sndr_cov sndr_cov_h;

  // Environment configuration
  hybrid_alert_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
