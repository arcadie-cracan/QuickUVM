//----------------------------------------------------------------------
// Register test. Front-door: built-in hw_reset + bit_bash sequences through the
// bus agent + adapter. Backdoor: hdl_path peek/poke straight to RTL storage.
//
// Note: UVM 1.1d's built-in hw_reset/bit_bash sequences hardcode front-door, so
// the backdoor path on 1.1d uses an explicit per-register UVM_BACKDOOR mirror
// check (project.uvm_version selects this). UVM 1.2+ uses set_default_door.
//----------------------------------------------------------------------

class reg_test extends rvtimer_base_test;
  `uvm_component_utils(reg_test)

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    // The register model is the checker for this test; disable the data-path
    // scoreboard so the protocol predictor isn't run on register-access traffic.
    uvm_config_db#(bit)::set(this, "*", "sb_enable", 0);
    super.build_phase(phase);
  endfunction

  task run_phase(uvm_phase phase);
    phase.raise_objection(this);
    // pragma quickuvm custom reg_test_pre begin
    // pragma quickuvm custom reg_test_pre end

    begin : run_reg_seqs
      uvm_reg_hw_reset_seq hw_reset_seq;
      uvm_reg_bit_bash_seq bit_bash_seq;
      hw_reset_seq = uvm_reg_hw_reset_seq::type_id::create("hw_reset_seq");
      hw_reset_seq.model = env_cfg.reg_model;
      hw_reset_seq.start(null);

      bit_bash_seq = uvm_reg_bit_bash_seq::type_id::create("bit_bash_seq");
      bit_bash_seq.model = env_cfg.reg_model;
      bit_bash_seq.start(null);
    end

    // pragma quickuvm custom reg_test_post begin
    // pragma quickuvm custom reg_test_post end
    phase.drop_objection(this);
  endtask

endclass
