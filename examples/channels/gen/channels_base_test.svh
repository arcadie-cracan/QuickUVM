//----------------------------------------------------------------------
// Top (subsystem) base test — builds the top env config, populates each child
// block's env config (agent cfgs + virtual interfaces from the config DB), and
// hands each child env its config so the composed tree self-configures.
//----------------------------------------------------------------------

class channels_base_test extends uvm_test;
  `uvm_component_utils(channels_base_test)

  channels_env e;
  channels_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    env_cfg = channels_env_cfg::type_id::create("env_cfg");

    // Block: lo (lo_chan)
    env_cfg.lo_cfg = lo_chan_env_cfg::type_id::create("lo_cfg");
    env_cfg.lo_cfg.lo_c_cfg = lo_c_cfg#(8)::type_id::create("lo_c_cfg");
    env_cfg.lo_cfg.lo_c_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual lo_c_if#(8))::get(
          this, "", "lo_lo_c_if_vif", env_cfg.lo_cfg.lo_c_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'lo_lo_c_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(lo_chan_env_cfg)::set(this, "e.lo", "env_cfg", env_cfg.lo_cfg);

    // Block: hi (hi_chan)
    env_cfg.hi_cfg = hi_chan_env_cfg::type_id::create("hi_cfg");
    env_cfg.hi_cfg.hi_c_cfg = hi_c_cfg#(16)::type_id::create("hi_c_cfg");
    env_cfg.hi_cfg.hi_c_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual hi_c_if#(16))::get(
          this, "", "hi_hi_c_if_vif", env_cfg.hi_cfg.hi_c_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'hi_hi_c_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(hi_chan_env_cfg)::set(this, "e.hi", "env_cfg", env_cfg.hi_cfg);

    uvm_config_db#(channels_env_cfg)::set(this, "e", "env_cfg", env_cfg);
    e = channels_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    `uvm_info("TB", "channels_base_test: end_of_elaboration", UVM_FULL)
  endfunction

endclass
