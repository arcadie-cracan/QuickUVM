class priority_encoder_env extends uvm_env;
  `uvm_component_utils(priority_encoder_env)

  // Agent handles
  pe_agent  pe_agnt;

  // Scoreboard (wired to primary agent: pe)
  priority_encoder_scoreboard sbd;

  // Functional coverage (wired to primary agent: pe)
  pe_cov cov;

  // Environment configuration
  priority_encoder_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(priority_encoder_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No priority_encoder_env_cfg set for: ", get_full_name()})
    uvm_config_db#(pe_cfg)::set(this, "pe_agnt", "cfg", env_cfg.pe_cfg);
    pe_agnt = pe_agent::type_id::create("pe_agnt", this);
    sbd  = priority_encoder_scoreboard::type_id::create("sbd",  this);
    cov  = pe_cov::type_id::create("cov",  this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Primary agent → scoreboard + coverage
    pe_agnt.ap.connect(sbd.axp);
    pe_agnt.ap.connect(cov.analysis_export);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
