    uvm_config_db#(dbl_env_cfg)::set(this, "e.stg1.dbl", "env_cfg", env_cfg.stg1_cfg.dbl_cfg);

    // Block: stg2 (stg2)
    env_cfg.stg2_cfg = stg2_env_cfg::type_id::create("stg2_cfg");
    uvm_config_db#(stg2_env_cfg)::set(this, "e.stg2", "env_cfg", env_cfg.stg2_cfg);

    // Block: inv (inv)
    env_cfg.stg2_cfg.inv_cfg = inv_env_cfg::type_id::create("inv_cfg");
    env_cfg.stg2_cfg.inv_cfg.b_cfg = b_cfg::type_id::create("b_cfg");
    env_cfg.stg2_cfg.inv_cfg.b_cfg.is_active = UVM_PASSIVE;
    if (!uvm_config_db#(virtual b_if)::get(
          this, "", "stg2_inv_b_if_vif", env_cfg.stg2_cfg.inv_cfg.b_cfg.vif))
      `uvm_fatal("NOVIF",
