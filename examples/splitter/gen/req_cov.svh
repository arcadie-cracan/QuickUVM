class req_cov extends uvm_subscriber #(req_seq_item);
  `uvm_component_utils(req_cov)

  req_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    req_valid_cp : coverpoint tr.req_valid {bins req_valid_bins[8] = {[0:$]};}
    req_id_cp : coverpoint tr.req_id {bins req_id_bins[8] = {[0:$]};}
    req_data_cp : coverpoint tr.req_data {bins req_data_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (req_seq_item t);
    tr = t;
    `uvm_info("req_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
