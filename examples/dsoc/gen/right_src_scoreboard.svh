class right_src_scoreboard extends uvm_scoreboard;
  `uvm_component_utils(right_src_scoreboard)

  uvm_analysis_export #(right_src_item) axp;
  right_src_predictor prd;
  right_src_comparator cmp;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

