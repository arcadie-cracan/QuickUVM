  // Register operation -> bus transaction
  virtual function uvm_sequence_item reg2bus(const ref uvm_reg_bus_op rw);
    host_seq_item tr = host_seq_item::type_id::create("reg2bus_tr");
    // pragma quickuvm custom reg2bus begin
    tr.addr  = rw.addr[3:0];
