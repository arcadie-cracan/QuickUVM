    env_cfg.reg_model.lock_model();
    // Backdoor root: lets uvm_reg peek/poke hit RTL storage via the model's hdl_path
    env_cfg.reg_model.add_hdl_path("tb_top.dut_inst");
    uvm_config_db#(ahb_regs_env_cfg)::set(this, "e", "env_cfg", env_cfg);

    e = ahb_regs_env::type_id::create("e", this);
