{% if multi_domain %}
module clkgen #(longint PERIOD = {{ clock_periods_ts[clocks[0].name] }}) (
  output logic clk);

  // Clock half-period = PERIOD/2 (time units set by the sim filelist's -timescale).
  // Each {{ top_name }} instance sets its own PERIOD. Customize the generator below as needed.
  // pragma quickuvm custom clock_generator begin
  initial begin
    clk <= '0;
    forever #(PERIOD / 2) clk = ~clk;
  end
  // pragma quickuvm custom clock_generator end
endmodule
{% else %}
module clkgen (
  output logic clk);

  // Clock period = {{ clock.period }} (time units set by the sim filelist's
  // -timescale, i.e. {{ clock.unit }}). Customize the generator below as needed.
  // pragma quickuvm custom clock_generator begin
  initial begin
    clk <= '0;
    forever #{{ clock.period // 2 }} clk = ~clk;
  end
  // pragma quickuvm custom clock_generator end
endmodule
{% endif %}
