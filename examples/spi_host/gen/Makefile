#----------------------------------------------------------------------
# This File: Makefile
# Generated by: QuickUVM  (R1 — regression + coverage closure)
# Project:  spi_host_tb
# Author:   QuickUVM
# SPDX-License-Identifier: MIT
#----------------------------------------------------------------------
#
# Elaborate ONCE into a snapshot, then run the (test x seed) matrix against it
# with `xrun -R` — so N*M runs cost one elaboration, not N*M.
#
#   make            # help
#   make build      # elaborate only (the cheapest simulator gate)
#   make run TEST=rand_test SEED=1
#   make regress    # every test x its seeds, + coverage merge/report
#   make cov        # re-merge + re-report without re-running
#   make clean
#
SHELL := /bin/bash

# The bench's REAL-RTL filelist. The generated run.f compiles the DUT *stub*, so a
# regression driven from it would verify nothing — this points at the real bench.
FILELIST ?= ../sim/xrun.f
SIM_DIR  := $(dir $(FILELIST))
SIM_F    := $(notdir $(FILELIST))

OUT      ?= out
ABS_OUT  := $(abspath $(OUT))
SNAPSHOT := $(ABS_OUT)/xcelium.d
ELAB_OK  := $(ABS_OUT)/.elaborated

# The snapshot must be rebuilt when any source it was built from changes — otherwise
# `make regress` silently re-runs a STALE snapshot and reports PASS for code you just
# edited. Derive the sources from the filelist: drop comments, then drop option lines
# (-uvm, -access, -top, +incdir...), leaving the .sv/.svh/.c paths, which are relative
# to the filelist's own directory. Nested `-f` files are not followed. NB whole LINES
# are dropped, not words: `-top tb_top` carries an argument that is not a source.
SRCS := $(addprefix $(SIM_DIR),$(shell sed -e 's|//.*||' $(FILELIST) 2>/dev/null \
          | grep -vE '^[[:space:]]*[-+]' | grep -vE '^[[:space:]]*$$'))

# ...but the filelist only names COMPILATION UNITS. Every UVM class — driver, monitor,
# predictor, reference model, scoreboard, sequences, tests — is a .svh pulled in by an
# `include inside the tb package, so NONE of them appear in the filelist. Track those
# too, or editing the very files a verification engineer edits most often would leave
# the snapshot stale and `make regress` would verdict PASS on code it never compiled.
# By construction the .svh files sit in the +incdir directories — that is what an
# include path is FOR — so that is where we look.
INCDIRS := $(addprefix $(SIM_DIR),$(shell sed -e 's|//.*||' $(FILELIST) 2>/dev/null \
             | grep -oE '[+]incdir[+][^[:space:]]+' | sed -e 's|^[+]incdir[+]||'))
SRCS += $(wildcard $(addsuffix /*.svh,$(INCDIRS)))

# test:seeds — the declared tests[], plus the RAL reg_test and one test per C5
# csr_tests kind. NB the basic register test's CLASS is the bare `reg_test`; only
# its FILE carries the spi_host_ot_ prefix.
JOBS      ?= rand_test:3 
# Seeds are SEED_BASE .. SEED_BASE+n-1 — explicit and recorded, never `-svseed
# random`: a regression you cannot replay is not a regression. `make regress
# SEED_BASE=$(date +%s)` for a fresh sweep.
SEED_BASE ?= 1
# Override every test's seed count: `make regress SEEDS=10` runs the whole testlist
# at 10 seeds, ignoring the per-test counts baked into JOBS. Empty => use JOBS.
SEEDS     ?=
TEST      ?= rand_test
SEED      ?= 1
JOBS_N    ?= 1          # parallel runs; raise once you trust the license count

# Coverage. `make regress COV=0` skips it for a quick pass. Instrumentation
# (-coverage) is an ELABORATE-time option; the bookkeeping (-covtest/-covoverwrite)
# is a RUN-time one — passing -coverage to a `-R` run is silently ignored.
COV       ?= 1
COVWORK   := $(ABS_OUT)/cov_work
COVSCOPE  := spi_host_ot
COVMERGE  := $(ABS_OUT)/cov/merged

ifeq ($(COV),1)
  COV_ELAB := -coverage all -covworkdir $(COVWORK) -covscope $(COVSCOPE)
  COV_RUN   = -covworkdir $(COVWORK) -covscope $(COVSCOPE) -covoverwrite \
              -covtest $(TEST).$(SEED)
endif

# pragma quickuvm custom extra_make_vars begin
# pragma quickuvm custom extra_make_vars end

.PHONY: help build run run1 regress cov summary clean

help:
	@echo "spi_host_tb — QuickUVM regression"
	@echo "  make build                     elaborate only"
	@echo "  make run TEST=<t> SEED=<n>     one run"
	@echo "  make regress                   all tests x seeds + coverage"
	@echo "  make cov                       re-merge + re-report coverage"
	@echo "  make clean"
	@echo ""
	@echo "  tests: rand_test(3)"

build: $(ELAB_OK)

$(ELAB_OK): $(FILELIST) $(SRCS)
	@mkdir -p $(ABS_OUT)
	cd $(SIM_DIR) && xrun -f $(SIM_F) -elaborate \
	    -xmlibdirname $(SNAPSHOT) $(COV_ELAB) -l $(ABS_OUT)/elab.log
	@touch $@

# One (test, seed). Runs against the snapshot, so no recompile.
#
# xrun EXITS 0 EVEN WITH UVM_ERRORs — its exit code is useless as a verdict, and
# "Number of caught UVM_ERROR reports" is the report-CATCHER count (always 0), so
# parsing that marks failing runs PASS. The only sound signal is the severity
# block, plus $finish to catch a crash that never printed one.
run1: $(ELAB_OK)
	@mkdir -p $(OUT)/runs/$(TEST).$(SEED)
	@echo "$(TEST)" > $(OUT)/runs/$(TEST).$(SEED)/test.txt
	@echo "$(SEED)" > $(OUT)/runs/$(TEST).$(SEED)/seed.txt
	@# Clear last run's artifacts FIRST. If xrun fails to launch (no licence, no
	@# snapshot, not on PATH) it writes no log, and `|| true` hides that — the verdict
	@# below would then parse the PREVIOUS run's log and report its stale PASS.
	@rm -f $(OUT)/runs/$(TEST).$(SEED)/sim.log $(OUT)/runs/$(TEST).$(SEED)/status
	@cd $(OUT)/runs/$(TEST).$(SEED) && \
	  xrun -R -xmlibdirname $(SNAPSHOT) +UVM_TESTNAME=$(TEST) -svseed $(SEED) \
	       $(COV_RUN) -l sim.log > /dev/null 2>&1 || true
	@log=$(OUT)/runs/$(TEST).$(SEED)/sim.log; \
	 sev=$$(awk '/Report counts by severity/,/Report counts by id/' "$$log" 2>/dev/null); \
	 e=$$(printf '%s\n' "$$sev" | awk '/^UVM_ERROR/{print $$3}'); \
	 f=$$(printf '%s\n' "$$sev" | awk '/^UVM_FATAL/{print $$3}'); \
	 if grep -qF 'Simulation complete via $$finish' "$$log" 2>/dev/null && \
	    [ "$$e" = 0 ] && [ "$$f" = 0 ]; then v=PASS; else v=FAIL; fi; \
	 echo "$$v" > $(OUT)/runs/$(TEST).$(SEED)/status

run: run1
	@printf "  %-4s  %s seed=%s\n" \
	  "$$(cat $(OUT)/runs/$(TEST).$(SEED)/status)" "$(TEST)" "$(SEED)"
	@echo "  log: $(OUT)/runs/$(TEST).$(SEED)/sim.log"

# Expand JOBS (test:seeds) x SEED_BASE.. into `TEST=<t> SEED=<s>` lines, then feed
# them back to make. xargs -L1 appends each line's words as make arguments.
regress: build
	@rm -rf $(OUT)/runs && mkdir -p $(OUT)/runs
	@# Drop the previous regression's per-test coverage DBs (the *dirs*), or the merge
	@# below would fold in runs from an older regression — possibly of older code — and
	@# report coverage this run never achieved. The shared .ucm model is a FILE, created
	@# at elaboration, so `*/` leaves it intact.
	@if [ "$(COV)" = 1 ]; then rm -rf $(COVWORK)/$(COVSCOPE)/*/; fi
	@for spec in $(JOBS); do \
	   t=$${spec%%:*}; n=$${spec##*:}; s=$(SEED_BASE); \
	   if [ -n "$(SEEDS)" ]; then n=$(SEEDS); fi; \
	   last=$$(( $(SEED_BASE) + n - 1 )); \
	   while [ $$s -le $$last ]; do echo "TEST=$$t SEED=$$s"; s=$$(( s + 1 )); done; \
	 done > $(OUT)/joblist
	@n=$$(wc -l < $(OUT)/joblist); \
	 if [ "$$n" -eq 0 ]; then echo "  no runs in the testlist — nothing to do"; exit 1; fi; \
	 echo "== running $$n runs =="
	@# -r: an empty joblist must run NOTHING. Without it xargs would invoke run1 once
	@# with the default TEST/SEED and a regression that ran none of its tests would
	@# report "1/1 passed".
	@xargs -r -P $(JOBS_N) -L1 $(MAKE) --no-print-directory run1 < $(OUT)/joblist
	@if [ "$(COV)" = 1 ]; then $(MAKE) --no-print-directory cov; fi
	@$(MAKE) --no-print-directory summary

# imc's -batch/-exec/-execcmd are MUTUALLY EXCLUSIVE (`-batch -exec f` silently
# does nothing), and a multi-line -execcmd breaks arg parsing — so: a command file,
# passed to `-exec` alone. The merged DB lands OUTSIDE $(COVSCOPE)/ so the run glob
# below never swallows it.
# imc is run from inside $(ABS_OUT)/cov: it drops imc.key / imc.log / mdv.log into
# its cwd, and those must not land in the generated source tree (they would show up
# as untracked files and trip the byte-identity gate).
cov:
	@mkdir -p $(ABS_OUT)/cov
	@runs=$$(ls -d $(COVWORK)/$(COVSCOPE)/*/ 2>/dev/null | tr '\n' ' '); \
	 if [ -z "$$runs" ]; then echo "  no coverage runs under $(COVWORK)"; exit 1; fi; \
	 { echo "merge $$runs -out $(COVMERGE) -overwrite"; echo exit; } > $(ABS_OUT)/cov/merge.cmd
	@cd $(ABS_OUT)/cov && imc -exec merge.cmd > merge.log 2>&1
	@rm -f $(ABS_OUT)/cov/summary.txt
	@{ echo "load -run $(COVMERGE)"; \
	   echo "report -summary -text -metrics all -out $(ABS_OUT)/cov/summary.txt"; \
	   echo exit; } > $(ABS_OUT)/cov/report.cmd
	@cd $(ABS_OUT)/cov && imc -exec report.cmd > report.log 2>&1
	@echo "== coverage (merged) =="
	@sed -n '1,12p' $(ABS_OUT)/cov/summary.txt 2>/dev/null || true

summary:
	@echo "== results =="
	@fail=0; total=0; \
	 for d in $(OUT)/runs/*/; do \
	   [ -f "$$d/status" ] || continue; \
	   st=$$(cat "$$d/status"); t=$$(cat "$$d/test.txt"); s=$$(cat "$$d/seed.txt"); \
	   total=$$(( total + 1 )); \
	   printf "  %-4s  %s seed=%s\n" "$$st" "$$t" "$$s"; \
	   if [ "$$st" != PASS ]; then \
	     fail=$$(( fail + 1 )); \
	     printf "        reproduce: make run TEST=%s SEED=%s\n" "$$t" "$$s"; \
	     printf "        log:       %ssim.log\n" "$$d"; \
	   fi; \
	 done; \
	 echo "  ---- $$(( total - fail ))/$$total passed"; \
	 if [ $$total -eq 0 ]; then echo "  NO RUNS — nothing was verdicted"; exit 1; fi; \
	 if [ $$fail -gt 0 ]; then echo "  REGRESSION FAILED"; exit 1; fi

# pragma quickuvm custom extra_make_targets begin
# pragma quickuvm custom extra_make_targets end

clean:
	rm -rf $(OUT)
