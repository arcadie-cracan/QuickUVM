class mem_driver extends uvm_driver #(mem_seq_item);
  `uvm_component_utils(mem_driver)

  virtual mem_if vif;

  // --- LIVENESS. Generated, and deliberately NOT inside a pragma. ---------------------
  // A dead responder is UNPROVABLE PER-TRANSACTION: with no response the DUT never
  // captures anything, so expected and actual are both zero and EVERY compare agrees.
  // It has reported TEST PASSED 34/34 while the device was stone dead. The only thing
  // that catches it is an end-of-test check — so a responder without one must be
  // impossible to GENERATE, not merely discouraged in a doc.
  protected int unsigned m_responses;      // responses actually driven
  protected int unsigned m_active_drives;  // ...that said anything other than `idle`

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  // ZERO-SLACK responder. The DUT samples our response on the very NEXT edge after it
  // raises its request, so there is no time for the sequencer round-trip the `on_request`
  // shape uses (monitor -> analysis fifo -> responder sequence -> sequencer -> driver:
  // at least one cycle, and no pragma runs inside it). The response is therefore computed
  // HERE, from the RAW request signals.
  //
  // Raw, not `cb1`: a clocking-block output is scheduled with an output skew, i.e. AFTER
  // the edge the DUT samples on — it would always be exactly one cycle late. `#1step`
  // puts us after the DUT's non-blocking updates for this edge, so we read the request it
  // just issued and answer it before the next one.
  task run_phase(uvm_phase phase);
    initialize();
    forever begin
      @(posedge vif.clk);
      #1step;   // after the DUT's NBA updates: its request for THIS edge is now visible
      if (vif.rst_n !== 1'b1) drive_idle();
      else if (vif.req) begin
        m_responses++;
        // THE USER SEAM. Compute the response from the RAW request signals and drive it
        // with BLOCKING assignments (vif.<port> = ...). It must be on the wires before
        // the next edge. Nothing here is generatable: no generator emits protocol logic.
        // pragma quickuvm custom response_logic begin
        // The memory model — the SAME one memslave uses, but evaluated HERE, on the raw
        // request, because the DUT samples our answer on the very next edge. Blocking
        // assignments: the value must be on the wires before that edge, and a clocking
        // block would schedule it after.
        vif.gnt   = 1'b1;
        $display("[DBG %0t] req=%b addr=%h | DUT: fetched=%0d missed=%0d last=%h", $time, vif.req, vif.addr, vif.fetched, vif.missed, vif.last_data);
        vif.rdata = {24'h0, vif.addr} ^ 32'hA5A5_A5A5;
        // pragma quickuvm custom response_logic end
        if (!driving_idle()) m_active_drives++;
      end
      else drive_idle();
    end
  endtask

  // What to drive when the DUT is not asking — the `idle:` block in the config. Raw, for
  // the same reason the response is raw.
  virtual task drive_idle ();
    vif.gnt = 1'd0;
    vif.rdata = 32'd0;
    // pragma quickuvm custom drive_idle_additional begin
    // pragma quickuvm custom drive_idle_additional end
  endtask

  // Is the response seam still parked on idle? If it never leaves idle, it never answered.
  virtual function bit driving_idle ();
    return 1'b1
      && (vif.gnt == 1'd0)
      && (vif.rdata == 32'd0)
    ;
  endfunction

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "mem_driver: Initialize (time @0)", UVM_HIGH)
    vif.gnt <= 1'd0;
    vif.rdata <= 32'd0;
    // A zero-slack responder does NOT wait for reset here, and burns no clock. It must be
    // ANSWERING from the very first cycle out of reset: the DUT issues its first request
    // on that edge and will not wait. Waiting here means the `wait` returns as reset
    // deasserts, by which time that edge has already fired — so the loop catches only the
    // NEXT one and the first request is missed (the DUT records exactly one `missed`).
    // Its run loop is live from time 0 and drives `idle` while reset is asserted, which is
    // the same thing the initiator's hold-off achieves. (An initiator can afford the
    // 2-cycle synchronizer settle: it chooses when to start driving. A responder cannot.)
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask


  function void check_phase (uvm_phase phase);
    super.check_phase(phase);
    if (m_responses == 0)
      `uvm_error("DEAD_RESPONDER", "this responder drove ZERO responses — the DUT never \
got an answer. Every per-transaction compare 'passed' because there was nothing to \
compare: with no response the DUT captures nothing, so expected and actual are both \
zero and they agree. Check that the DUT actually requests, and that request_valid \
names the right port.")
    else if (m_active_drives == 0)
      `uvm_error("SILENT_RESPONDER", $sformatf("this responder drove %0d response(s), \
but EVERY ONE of them was the idle value — so it never actually answered. The \
`response_logic` seam is almost certainly empty.", m_responses))
  endfunction

endclass
