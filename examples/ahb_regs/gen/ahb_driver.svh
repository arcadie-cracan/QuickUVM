class ahb_driver extends uvm_driver #(ahb_seq_item);
  `uvm_component_utils(ahb_driver)

  virtual ahb_if vif;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  task run_phase(uvm_phase phase);
    ahb_seq_item tr;
    initialize();
    forever begin
      `uvm_info("DEBUG: ahb_driver Run", "... getting next item ...", UVM_FULL)
      seq_item_port.get_next_item(tr);
      drive_item(tr);
      seq_item_port.item_done();
      `uvm_info("DEBUG: ahb_driver Run", "... next item done ...", UVM_FULL)
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "ahb_driver: Initialize (time @0)", UVM_HIGH)
    vif.HADDR <= '1;
    vif.HWRITE <= '0;
    vif.HTRANS <= '1;
    vif.HWDATA <= '1;
    // Reset is driven externally: hold off BEFORE advancing a clock so the parked
    // idle values are all the DUT sees during reset; wait for deassertion, then let
    // the input synchronizers settle (2 = a typical 2-stage sync; raise for deeper).
    wait (vif.HRESETn === 1'b1);
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (ahb_seq_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    vif.cb1.HADDR <= tr.HADDR;
    vif.cb1.HWRITE <= tr.HWRITE;
    vif.cb1.HTRANS <= tr.HTRANS;
    vif.cb1.HWDATA <= tr.HWDATA;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // AHB-Lite two-phase: the default drive above is the ADDRESS phase (HADDR/HWRITE/
    // HTRANS=NONSEQ/HWDATA driven at this edge). Now end the transfer (HTRANS=IDLE so no
    // second access triggers) and advance into the DATA phase, where a write commits and
    // the REGISTERED HRDATA is valid — capture it for a read.
    vif.cb1.HTRANS <= 2'b00;   // IDLE
    @vif.cb1;
    tr.HRDATA = vif.cb1.HRDATA;
    // pragma quickuvm custom drive_item_additional end
  endtask

endclass
