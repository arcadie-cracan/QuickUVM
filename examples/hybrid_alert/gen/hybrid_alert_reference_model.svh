function sndr_item hybrid_alert_predictor::predict(sndr_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  sndr_item extr = sndr_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // The PROACTIVE path's check: the DUT latches `adata` on every raised alert, so track the
  // most-recent payload and expect the DUT to hold it in `last_adata`. Everything else is
  // copy-through (extr already copies t): ping/resp_cnt/alert_cnt are the DUT's own, and
  // the reactive path's liveness is the request-FIFO drain, not this scoreboard. `alert`,
  // `adata` and `last_adata` are mutually consistent within one transaction (all reflect
  // the same driven cycle), so no re-sample is needed.
  if (t.alert) m_last = t.adata;
  extr.last_adata = m_last;
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
