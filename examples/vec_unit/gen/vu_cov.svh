class vu_cov extends uvm_subscriber #(vu_seq_item);
  `uvm_component_utils(vu_cov)

  vu_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    sum_cp : coverpoint tr.sum {bins sum_bins[8] = {[0:$]};}
    tag_out_cp : coverpoint tr.tag_out {bins tag_out_bins[8] = {[0:$]};}
    hdr_cp : coverpoint tr.hdr;
    lanes_cp : coverpoint tr.lanes;

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (vu_seq_item t);
    tr = t;
    `uvm_info("vu_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
