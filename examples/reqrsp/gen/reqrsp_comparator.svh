class reqrsp_comparator extends uvm_component;
  `uvm_component_utils(reqrsp_comparator)

  rsp_seq_item exp_tr, out_tr;
  static int VECT_CNT, PASS_CNT, ERROR_CNT;

  uvm_analysis_export   #(rsp_seq_item) exp_ap;
  uvm_analysis_export   #(rsp_seq_item) out_ap;
  uvm_tlm_analysis_fifo #(rsp_seq_item) expfifo;
  uvm_tlm_analysis_fifo #(rsp_seq_item) outfifo;

  // Data-path scoreboard enable. A register test (RAL is the checker) clears this
  // via uvm_config_db "sb_enable" so the protocol predictor isn't run on
  // register-access traffic it doesn't model.
  bit enabled = 1;

  // Number of leading transactions to flush (DUT startup: pipeline fill + sync/
  // reset frames that aren't meaningful). Set via uvm_config_db "sb_flush".
  int unsigned flush_count = 0;

  // Out-of-order matching: expected responses pending a match, queued per
  // rsp_id (request order within a key). Each actual pops its key's front.
  rsp_seq_item exp_pool [longint][$];
  // Latency window: the $realtime each pooled expected was enqueued, parallel to
  // exp_pool, so a too-late response is flagged. 8 cycles, emitted
  // as a time literal so the threshold is independent of the sim timescale:
  realtime exp_age [longint][$];
  localparam realtime MaxLatency = 80ns;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    exp_ap  = new("exp_ap",  this);
    out_ap  = new("out_ap",  this);
    expfifo = new("expfifo", this);
    outfifo = new("outfifo", this);
    void'(uvm_config_db#(bit)::get(this, "", "sb_enable", enabled));
    void'(uvm_config_db#(int)::get(this, "", "sb_flush", flush_count));
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    exp_ap.connect(expfifo.analysis_export);
    out_ap.connect(outfifo.analysis_export);
  endfunction

  task run_phase(uvm_phase phase);
    if (!enabled) begin
      `uvm_info("SB_CMP", "data-path scoreboard disabled for this test (checked by RAL)", UVM_LOW)
      return;
    end
    // Out-of-order: the response stream is reordered vs the request stream, so match
    // by tag. One process pools expected (in request order) per rsp_id;
    // the other pops each key's queue front for the matching actual.
    if (flush_count)  // order-based flush is meaningless when matching by tag
      `uvm_warning("SB_CMP",
        "sb_flush is ignored for match=out_of_order (matching is by tag)")
    fork
      forever begin
        rsp_seq_item e;
        expfifo.get(e);
        exp_pool[longint'(e.rsp_id)].push_back(e);
        exp_age[longint'(e.rsp_id)].push_back($realtime);
      end
      forever begin
        longint k;
        outfifo.get(out_tr);
        k = longint'(out_tr.rsp_id);
        if (exp_pool.exists(k) && exp_pool[k].size() != 0) begin
          exp_tr = exp_pool[k].pop_front();
          // Latency window: a too-late response fails even if its data matches, and a
          // wrong-data response is still reported (the data check is not skipped).
          begin
            bit data_ok = out_tr.compare(exp_tr);
            bit late    = ($realtime - exp_age[k].pop_front()) > MaxLatency;
            if (late)
              `uvm_error("SB_LATENCY", $sformatf(
                "rsp_id=%0d response exceeded the 8-cycle window", k))
            if (!data_ok)
              `uvm_error("ERROR", {get_vector_str(), "\n"})
            if (data_ok && !late) PASS();
            else begin VECT_CNT++; ERROR_CNT++; end
          end
        end
        else begin
          `uvm_error("SB_NOEXP", $sformatf(
            "response with rsp_id=%0d has no pending request", k))
          VECT_CNT++;
          ERROR_CNT++;
        end
      end
    join
  endtask

  function void report_phase(uvm_phase phase);
    super.report_phase(phase);
    // Pooled expected (and undrained actuals) never matched by tag — surface them
    // rather than letting an undersized drain silently pass with fewer vectors.
    if (enabled) begin
      int unmatched = outfifo.used() + expfifo.used();  // not yet drained either way
      foreach (exp_pool[k]) unmatched += exp_pool[k].size();  // pooled expected
      if (unmatched != 0)
        `uvm_warning("SB_LEFTOVER", $sformatf(
          "%0d transaction(s) never matched by tag (test ended early?)", unmatched))
    end
    if (ERROR_CNT)
      `uvm_error("FAILED",
        $sformatf("\n\n\n*** TEST FAILED - Vectors: %0d Ran / %0d Passed / %0d Failed ***\n",
                   VECT_CNT, PASS_CNT, ERROR_CNT))
    else if (!enabled)
      // Deliberately disabled (e.g. a RAL/CSR test that checks via the register
      // model). Comparing 0 transactions is expected here — not a warning.
      `uvm_info("SB_CMP",
        "data-path scoreboard disabled — checking delegated to the RAL/CSR test", UVM_LOW)
    else if (VECT_CNT == 0)
      // Enabled but nothing compared — a data-path test that drove no bus
      // traffic. Warn rather than silently pass.
      `uvm_warning("NOVEC",
        "scoreboard compared 0 transactions (no front-door bus traffic)")
    else
      `uvm_info("PASSED",
        $sformatf("\n\n\n*** TEST PASSED - Vectors: %0d Ran / %0d Passed ***\n",
                   VECT_CNT, PASS_CNT), UVM_LOW)
  endfunction

  function string get_vector_str();
    return($sformatf("Expected:%s  Actual:%s",
            exp_tr.convert2string(), out_tr.output2string()));
  endfunction

  function void PASS();
    `uvm_info ("PASS ", get_vector_str(), UVM_HIGH)
    VECT_CNT++;
    PASS_CNT++;
  endfunction

  function void ERROR();
    `uvm_error("ERROR", {get_vector_str(), "\n"})
    VECT_CNT++;
    ERROR_CNT++;
  endfunction

endclass
