//----------------------------------------------------------------------
// Top (subsystem) base test — builds the top env config, populates each child
// block's env config (agent cfgs + virtual interfaces from the config DB), and
// hands each child env its config so the composed tree self-configures.
//----------------------------------------------------------------------

class psoc_base_test extends uvm_test;
  `uvm_component_utils(psoc_base_test)

  psoc_env e;
  psoc_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    env_cfg = psoc_env_cfg::type_id::create("env_cfg");

    // Block: dp (dp)
    env_cfg.dp_cfg = dp_env_cfg::type_id::create("dp_cfg");
    env_cfg.dp_cfg.d_cfg = d_cfg#(8)::type_id::create("d_cfg");
    env_cfg.dp_cfg.d_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual d_if#(8))::get(
          this, "", "dp_d_if_vif", env_cfg.dp_cfg.d_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'dp_d_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(dp_env_cfg)::set(this, "e.dp", "env_cfg", env_cfg.dp_cfg);

    // Block: mac (mac)
    env_cfg.mac_cfg = mac_env_cfg::type_id::create("mac_cfg");
    env_cfg.mac_cfg.m_cfg = m_cfg#(16)::type_id::create("m_cfg");
    env_cfg.mac_cfg.m_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual m_if#(16))::get(
          this, "", "mac_m_if_vif", env_cfg.mac_cfg.m_cfg.vif))
      `uvm_fatal("NOVIF",
                 "No virtual interface 'mac_m_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(mac_env_cfg)::set(this, "e.mac", "env_cfg", env_cfg.mac_cfg);

    uvm_config_db#(psoc_env_cfg)::set(this, "e", "env_cfg", env_cfg);
    e = psoc_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void end_of_elaboration_phase(uvm_phase phase);
    super.end_of_elaboration_phase(phase);
    `uvm_info("TB", "psoc_base_test: end_of_elaboration", UVM_FULL)
  endfunction

endclass
