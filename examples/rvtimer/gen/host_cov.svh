class host_cov extends uvm_subscriber #(host_seq_item);
  `uvm_component_utils(host_cov)

  host_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    option.goal         = 90;
    addr_cp : coverpoint tr.addr {
      bins ctrl = {0};
      bins cfg = {2};
      bins mtimecmp = {4};
      bins intr_enable = {6};
      bins intr_state = {8};
    }
    wr_cp : coverpoint tr.wr {
      bins rd = {0};
      bins wr = {1};
    }
    reg_x_dir : cross addr_cp, wr_cp;

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (host_seq_item t);
    tr = t;
    `uvm_info("host_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
