`ifndef {{ dut.name | upper }}_TB_PKG__SV
`define {{ dut.name | upper }}_TB_PKG__SV

`include "uvm_macros.svh"

package {{ dut.name }}_tb_pkg;
  import uvm_pkg::*;
{% if register_model %}
  import {{ register_model.package }}::*;
{% endif %}
{% for pkg in project.imports %}
  import {{ pkg }}::*;
{% endfor %}
  // pragma quickuvm custom imports begin
  // pragma quickuvm custom imports end

  // Transaction classes
{% for agent in agents %}
  `include "{{ agent.sequence_item }}.svh"
{% endfor %}

  // Agent configuration objects
{% for agent in agents %}
  `include "{{ agent.name }}_cfg.svh"
{% endfor %}

  // Testbench components (per agent)
{% for agent in agents %}
  `include "{{ agent.name }}_cov.svh"
  `include "{{ agent.name }}_driver.svh"
  `include "{{ agent.name }}_sequencer.svh"
  `include "{{ agent.name }}_monitor.svh"
  `include "{{ agent.name }}_agent.svh"
{% endfor %}

{% if has_instances %}
  // Scoreboards (one typed set per instance)
{% for inst in instances %}
{% set p = dut.name ~ '_' ~ inst.name %}
  `include "{{ p }}_predictor.svh"
  `include "{{ p }}_comparator.svh"
  `include "{{ p }}_scoreboard.svh"
{% endfor %}
{% else %}
  // Scoreboard{{ 's (one typed set per scoreboard)' if sb_multi else '' }}
{% if sb_multi %}
{% for sb in analysis.scoreboards %}
{% set p = dut.name ~ '_' ~ sb.name %}
  `include "{{ p }}_predictor.svh"
  `include "{{ p }}_comparator.svh"
  `include "{{ p }}_scoreboard.svh"
{% endfor %}
{% else %}
  `include "{{ dut.name }}_predictor.svh"
  `include "{{ dut.name }}_comparator.svh"
  `include "{{ dut.name }}_scoreboard.svh"
{% endif %}
{% endif %}

  // Environment
  `include "{{ dut.name }}_env_cfg.svh"
{% if register_model %}
  `include "{{ register_model.adapter }}.svh"
{% if register_model.frontdoor %}
  `include "{{ register_model.frontdoor }}.svh"
{% endif %}
{% endif %}
{% if virtual_sequences %}
  `include "{{ dut.name }}_virtual_sequencer.svh"
  `include "{{ dut.name }}_base_vseq.svh"
{% endif %}
{% if cover_probes %}
  `include "{{ dut.name }}_probe_monitor.svh"
{% endif %}
  `include "{{ dut.name }}_env.svh"

  // Sequences (per agent)
{% for agent in agents %}
  `include "{{ agent.default_seq_name }}.svh"
{% for seq in agent.sequences %}
  `include "{{ seq.name }}.svh"
{% endfor %}
{% endfor %}
{% for vseq in virtual_sequences %}
  `include "{{ vseq.name }}.svh"
{% endfor %}
  // pragma quickuvm custom sequences_additional begin
  // pragma quickuvm custom sequences_additional end

  // Tests
  `include "{{ dut.name }}_base_test.svh"
{% for test in tests %}
  `include "{{ test.name }}.svh"
{% endfor %}
{% if register_model and register_model.reg_test %}
  `include "{{ dut.name }}_reg_test.svh"
{% endif %}
{% if register_model %}
{% for csr in register_model.csr_test_specs %}
  `include "{{ dut.name }}_csr_{{ csr.kind }}_test.svh"
{% endfor %}
{% endif %}

  // Scoreboard expected-value calculator (extern function body)
{% if has_instances %}
{% for inst in instances %}
  `include "{{ dut.name }}_{{ inst.name }}_reference_model.svh"
{% endfor %}
{% elif sb_multi %}
{% for sb in analysis.scoreboards %}
  `include "{{ dut.name }}_{{ sb.name }}_reference_model.svh"
{% endfor %}
{% else %}
  `include "{{ dut.name }}_reference_model.svh"
{% endif %}

endpackage

`endif
