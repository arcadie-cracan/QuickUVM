class b_cov extends uvm_subscriber #(b_seq_item);
  `uvm_component_utils(b_cov)

  b_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    dout_cp : coverpoint tr.dout {bins dout_bins[8] = {[0:$]};}
    din_cp : coverpoint tr.din {bins din_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (b_seq_item t);
    tr = t;
    `uvm_info("b_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
