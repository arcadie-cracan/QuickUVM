    // pragma quickuvm custom bus2reg begin
    rw.kind   = tr.wr ? UVM_WRITE : UVM_READ;
    rw.addr   = tr.addr;
    rw.data   = tr.wr ? tr.wdata : tr.rdata;   // a read returns the sampled rdata
    rw.status = UVM_IS_OK;
