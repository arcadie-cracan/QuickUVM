function bus_seq_item odbus_predictor::predict(bus_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  bus_seq_item extr = bus_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // THE WIRED-AND CONTRACT, checked directly:
  //   the shared line is LOW iff SOMEBODY pulls it low, and reads 1 (never X) when
  //   everyone has released.
  //
  // We pull low when we drive a 0 (`sda_oe && !sda_o`). On an open-drain line, driving a
  // 1 IS releasing — the line can never be driven high, which is exactly why two devices
  // may pull low at the same instant with no contention.
  //
  // If the pullup were missing, the released case would resolve to X and this compare
  // would fail — which is the point of making `pullup` mandatory rather than advisory.
  begin
    bit tb_low  = extr.sda_oe && !extr.sda_o;
    bit any_low = tb_low || extr.dut_low;
    extr.sda = any_low ? 1'b0 : 1'b1;
  end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
