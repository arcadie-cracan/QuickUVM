class pe_seq extends uvm_sequence #(pe_seq_item);
  `uvm_object_utils(pe_seq)

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name = "pe_seq");
    super.new(name);
  endfunction

  task body;
    pe_seq_item tr = pe_seq_item::type_id::create("tr");
    `uvm_info("body", "pe_seq: about to start do_item loop", UVM_FULL)
    repeat(500) do_item(tr);
  endtask

  task do_item (pe_seq_item tr);
    `uvm_info("do_item", "executing", UVM_FULL)
    start_item(tr);
    if (!(tr.randomize() with {

      // pragma quickuvm custom do_item_constraints begin
      tr.req dist { 8'h00 := 5, 8'hFF := 5, [8'h01:8'hFE] :/ 90 };
      // pragma quickuvm custom do_item_constraints end
    })) `uvm_fatal("PE_SEQ", "pe_seq randomization failed")
    `uvm_info("do_item", tr.input2string(), UVM_FULL)
    finish_item(tr);
  endtask

endclass
