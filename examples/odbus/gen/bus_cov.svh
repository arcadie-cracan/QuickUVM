class bus_cov extends uvm_subscriber #(bus_seq_item);
  `uvm_component_utils(bus_cov)

  bus_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    sda_oe_cp : coverpoint tr.sda_oe {
      bins released = {0};
      bins driving = {1};
    }
    dut_low_cp : coverpoint tr.dut_low {
      bins dut_released = {0};
      bins dut_low = {1};
    }
    contention : cross sda_oe_cp, dut_low_cp;

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (bus_seq_item t);
    tr = t;
    `uvm_info("bus_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
