// Implement rvtimer_predictor::predict() here.
// This function receives the sampled transaction (inputs + outputs as
// driven to/from DUT) and must return a NEW transaction with the
// EXPECTED output values filled in.
//
// Edit the "prediction_logic" user section below.
//----------------------------------------------------------------------

function host_seq_item rvtimer_predictor::predict(host_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  host_seq_item extr = host_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // Copy all sampled inputs & outputs
  extr.copy(t);

  // pragma quickuvm custom prediction_logic begin
  // Golden model of rtl/rvtimer.sv's register READ path. The monitor emits one
  // (addr, wr, wdata, rdata) tuple per cycle; the DUT reads combinationally (rdata =
  // <reg>[idx], the PRE-write value) and commits the write on the same posedge.
  // The 4 config registers (CTRL/CFG/MTIMECMP/INTR_ENABLE, idx 0..3) are a pure
  // function of the write history -> checked here against a shadow. MTIME/INTR_STATE
  // (idx 4) are hardware-driven (a function of elapsed time, not the bus), so their
  // reads are ECHOED (not checked here) — the timer/interrupt behaviour is checked by
  // the directed RAL sequence in rand_test + the irq-interface SVA.
  begin
    logic [2:0] idx = extr.addr[3:1];
    // static => modelled config state persists across calls; initialised to the DUT
    // reset values (monitoring starts after reset deasserts).
    static logic [15:0] model[4] = '{16'h0000, 16'h0001, 16'hFFFF, 16'h0000};
    if (idx <= 3'd3) extr.rdata = model[idx];         // config read (pre-write)
    // else INTR_STATE / unmapped: keep the observed rdata (echo, not checked here)
    if (extr.wr && idx <= 3'd3) model[idx] = extr.wdata;  // config write commits
  end
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
