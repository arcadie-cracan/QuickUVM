class cha_cov extends uvm_subscriber #(cha_seq_item);
  `uvm_component_utils(cha_cov)

  cha_seq_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    a_valid_cp : coverpoint tr.a_valid {bins a_valid_bins[8] = {[0:$]};}
    a_id_cp : coverpoint tr.a_id {bins a_id_bins[8] = {[0:$]};}
    a_sum_cp : coverpoint tr.a_sum {bins a_sum_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (cha_seq_item t);
    tr = t;
    `uvm_info("cha_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
