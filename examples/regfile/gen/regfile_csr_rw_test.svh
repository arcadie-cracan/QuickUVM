// C5 — CSR test 'rw': runs the UVM built-in uvm_reg_access_seq against
// the register model. The data-path scoreboard is disabled — the RAL is the
// checker for register-access traffic. Run via +UVM_TESTNAME.
//
// Door: each built-in CSR sequence uses its own natural access door (hw_reset /
// bit_bash are front-door; the rw/access seq does front-door vs back-door). This
// is independent of register_model.reg_test_door, which governs only the basic
// reg_test. The rw/access and mem_walk seqs require a backdoor (backdoor_root);
// mem_walk needs a uvm_mem and shared needs >=2 maps, else they no-op.
//----------------------------------------------------------------------

class regfile_csr_rw_test extends regfile_base_test;
  `uvm_component_utils(regfile_csr_rw_test)

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    // RAL is the checker for this test; disable the data-path scoreboard.
    uvm_config_db#(bit)::set(this, "*", "sb_enable", 0);
    super.build_phase(phase);
  endfunction

  task run_phase(uvm_phase phase);
    uvm_reg_access_seq seq;
    seq = uvm_reg_access_seq::type_id::create("seq");
    phase.raise_objection(this);
    // pragma quickuvm custom csr_test_pre begin
    // pragma quickuvm custom csr_test_pre end
    seq.model = env_cfg.reg_model;
    seq.start(null);
    // pragma quickuvm custom csr_test_post begin
    // pragma quickuvm custom csr_test_post end
    phase.drop_objection(this);
  endtask

endclass
