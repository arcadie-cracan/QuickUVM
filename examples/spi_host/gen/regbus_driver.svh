class regbus_driver extends uvm_driver #(regbus_item);
  `uvm_component_utils(regbus_driver)

  virtual regbus_if vif;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  task run_phase(uvm_phase phase);
    regbus_item tr;
    initialize();
    forever begin
      `uvm_info("DEBUG: regbus_driver Run", "... getting next item ...", UVM_FULL)
      seq_item_port.get_next_item(tr);
      drive_item(tr);
      seq_item_port.item_done();
      `uvm_info("DEBUG: regbus_driver Run", "... next item done ...", UVM_FULL)
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "regbus_driver: Initialize (time @0)", UVM_HIGH)
    vif.addr <= '1;
    vif.req <= '0;
    vif.wr <= '0;
    vif.be <= '1;
    vif.wdata <= '1;
    // Reset is driven externally: hold off BEFORE advancing a clock so the parked
    // idle values are all the DUT sees during reset; wait for deassertion, then let
    // the input synchronizers settle (2 = a typical 2-stage sync; raise for deeper).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (regbus_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    vif.cb1.addr <= tr.addr;
    vif.cb1.req <= tr.req;
    vif.cb1.wr <= tr.wr;
    vif.cb1.be <= tr.be;
    vif.cb1.wdata <= tr.wdata;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // Deassert the request after ONE FULL CYCLE, so the bus sees a one-beat pulse.
    //
    // The `@vif.cb1` below is load-bearing, and its absence is a trap worth naming: a
    // clocking-block drive issued the instant `@vif.cb1` returns lands on the SAME
    // clocking event as the drive that preceded it, so `req <= 1'b0` simply OVERWRITES
    // the `req <= tr.req` from drive_item and the pulse never reaches the wire at all.
    // Every register beat then vanishes: addr and wdata change (nothing deasserts them),
    // but `req` stays low, so the DUT sees no access — and the bench happily "passes",
    // comparing idle beats against idle beats.
    @vif.cb1;
    vif.cb1.req <= 1'b0;
    vif.cb1.wr  <= 1'b0;
    // ...and one idle cycle before the next item, for the same reason: without it the NEXT
    // item's `req <= 1` lands on the same clocking event as this deassert and overwrites
    // it, so `req` never falls between back-to-back beats and the DUT sees one long access
    // instead of two.
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional end
  endtask

endclass
