// The predictor:
//   - subscribes to the monitor's analysis port
//   - ignores sampled DUT outputs
//   - calls predict() to predict the expected output
//   - writes the predicted transaction to results_ap
//----------------------------------------------------------------------

class alert_array_sndr_2_predictor extends uvm_subscriber #(sndr_item);
  `uvm_component_utils(alert_array_sndr_2_predictor)

  uvm_analysis_port #(sndr_item) results_ap;

