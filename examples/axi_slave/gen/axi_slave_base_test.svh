      `uvm_fatal("NOVIF", "No virtual interface 'wr_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(axi_slave_env_cfg)::set(this, "e", "env_cfg", env_cfg);

    e = axi_slave_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
