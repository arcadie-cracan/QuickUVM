class bus_driver extends uvm_driver #(bus_seq_item);
  `uvm_component_utils(bus_driver)

  virtual bus_if vif;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  task run_phase(uvm_phase phase);
    bus_seq_item tr;
    initialize();
    forever begin
      `uvm_info("DEBUG: bus_driver Run", "... getting next item ...", UVM_FULL)
      seq_item_port.get_next_item(tr);
      drive_item(tr);
      seq_item_port.item_done();
      `uvm_info("DEBUG: bus_driver Run", "... next item done ...", UVM_FULL)
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "bus_driver: Initialize (time @0)", UVM_HIGH)
    // Release every shared line at time 0 — a TB that drives an inout before it has
    // anything to say fights the DUT and both ends read X.
    vif.sda_oe <= 1'b0;
    vif.sda_o  <= '0;
    // Reset is driven externally: hold off BEFORE advancing a clock so the parked
    // idle values are all the DUT sees during reset; wait for deassertion, then let
    // the input synchronizers settle (2 = a typical 2-stage sync; raise for deeper).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (bus_seq_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    vif.cb1.sda_o  <= tr.sda_o;
    vif.cb1.sda_oe <= tr.sda_oe;   // 0 = release the line
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // pragma quickuvm custom drive_item_additional end
  endtask

endclass
