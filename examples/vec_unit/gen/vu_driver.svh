class vu_driver extends uvm_driver #(vu_seq_item);
  `uvm_component_utils(vu_driver)

  virtual vu_if vif;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  task run_phase(uvm_phase phase);
    vu_seq_item tr;
    initialize();
    forever begin
      `uvm_info("DEBUG: vu_driver Run", "... getting next item ...", UVM_FULL)
      seq_item_port.get_next_item(tr);
      drive_item(tr);
      seq_item_port.item_done();
      `uvm_info("DEBUG: vu_driver Run", "... next item done ...", UVM_FULL)
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "vu_driver: Initialize (time @0)", UVM_HIGH)
    vif.hdr <= '1;
    vif.lanes <= '1;
    @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (vu_seq_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    vif.cb1.hdr <= tr.hdr;
    vif.cb1.lanes <= tr.lanes;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // pragma quickuvm custom drive_item_additional end
  endtask

endclass
