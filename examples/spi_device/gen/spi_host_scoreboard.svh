class spi_host_scoreboard extends uvm_scoreboard;
  `uvm_component_utils(spi_host_scoreboard)

  uvm_analysis_export #(spi_item) axp;
  spi_host_predictor prd;
  spi_host_comparator cmp;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    axp = new("axp", this);
    prd = spi_host_predictor::type_id::create("prd", this);
    cmp = spi_host_comparator::type_id::create("cmp", this);
  endfunction

  function void connect_phase(uvm_phase phase);
    // Connect predictor & comparator to respective analysis exports
    axp.connect(prd.analysis_export);
    axp.connect(cmp.out_ap);
    // Connect predictor output to comparator expected input
    prd.results_ap.connect(cmp.exp_ap);
  endfunction

endclass
