      drv = irq_driver::type_id::create("drv", this);
      sqr = irq_sequencer::type_id::create("sqr", this);
    end
    mon = irq_monitor::type_id::create("mon", this);
    ap  = new("ap", this);
    // pragma quickuvm custom build_phase_additional begin
