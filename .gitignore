# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environment
.venv/

# pytest / coverage / type & lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Distribution / packaging
*.whl
*.tar.gz

# Editor / IDE
.dvt/
*.swp
*.swo
.DS_Store
Thumbs.db
dvt_build.log

# Generated testbench output (keep examples, ignore scratch)
/tb/
/tb_out/

# Pragma-merger backups (<file>.bak.<n>, written on regeneration)
*.bak.*

# Simulator working dirs / logs (keep the xrun.f filelists)
**/sim/xcelium.d/
**/sim/*.log
**/sim/*.history
**/sim/*.shm/
**/sim/.simvision/
**/sim/INCA_libs/
**/sim/waves.shm/
**/sim/cov_work/
**/sim/*.key

# Xcelium artifacts can also land in gen/ (the F2 packaged example compiles the
# per-package .f filelists from there) — keep the generated .sv/.svh/.f.
**/gen/xcelium.d/
**/gen/INCA_libs/
**/gen/*.log
**/gen/*.history
**/gen/*.shm/
**/gen/.simvision/
**/gen/*.key

# R1 — `make regress` output: the snapshot, per-(test,seed) run dirs + logs, and the
# coverage DBs/reports. All reproducible; keep the generated Makefile itself.
**/gen/out/
**/sim/.xrun_gate.log
