class odbus_env extends uvm_env;
  `uvm_component_utils(odbus_env)

  // Agent handles
  bus_agent  bus_agnt;

  // Scoreboards
  odbus_scoreboard sb;

  // Functional coverage (per agent)
  bus_cov bus_cov_h;

  // Environment configuration
  odbus_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(odbus_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No odbus_env_cfg set for: ", get_full_name()})
    uvm_config_db#(bus_cfg)::set(this, "bus_agnt", "cfg", env_cfg.bus_cfg);
    bus_agnt = bus_agent::type_id::create("bus_agnt", this);
    sb = odbus_scoreboard::type_id::create("sb", this);
    bus_cov_h = bus_cov::type_id::create("bus_cov_h", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Declared analysis connectivity (per analysis: block)
    bus_agnt.ap.connect(sb.axp);
    bus_agnt.ap.connect(bus_cov_h.analysis_export);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
