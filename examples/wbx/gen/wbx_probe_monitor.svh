//----------------------------------------------------------------------
// K2 — passive whitebox probe monitor: samples the observed internal signals off
// the probe interface and covers them. OBSERVE-only (no driving). Symbolic coverage
// of an enum probe comes from $cast-ing the raw bits to the enum typedef below.
//----------------------------------------------------------------------

class wbx_probe_monitor extends uvm_monitor;
  `uvm_component_utils(wbx_probe_monitor)

  virtual wbx_probe_if vif;

  typedef enum logic [1:0] {
    IDLE = 0,    BUSY = 1,    FULL = 2  } fsm_state_e;

  // Typed sampled values (the covergroup coverpoints these).
  logic [2:0] s_fifo_lvl;
  fsm_state_e s_fsm_state;

  covergroup wbx_probe_cg;
    option.per_instance = 1;
    cp_fifo_lvl: coverpoint s_fifo_lvl;
    cp_fsm_state: coverpoint s_fsm_state;
    // pragma quickuvm custom probe_cover_additional begin
    // pragma quickuvm custom probe_cover_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    wbx_probe_cg = new();
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(virtual wbx_probe_if)::get(this, "", "wbx_probe_vif", vif))
      `uvm_fatal("NOVIF", "No wbx_probe_vif in config DB (see tb_top.sv)")
  endfunction

  task run_phase(uvm_phase phase);
    wait (vif.rst_n === 1'b1);
    forever begin
      @vif.mon_cb;
      s_fifo_lvl = vif.mon_cb.fifo_lvl;
      void'($cast(s_fsm_state, vif.mon_cb.fsm_state));
      wbx_probe_cg.sample();
      // pragma quickuvm custom probe_sample_additional begin
      // pragma quickuvm custom probe_sample_additional end
    end
  endtask

endclass
