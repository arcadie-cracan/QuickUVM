// Two-stream scoreboard: `t` is the observed req (request) item;
// return the EXPECTED rsp (response) item it should produce.
function rsp_seq_item reqrsp_predictor::predict(req_seq_item t);
  // Declare static state variables needed between calls
  // static logic [W-1:0] ex_prev;

  rsp_seq_item extr = rsp_seq_item::type_id::create("extr");

  `uvm_info("CALC #1", t.convert2string(), UVM_FULL)

  // pragma quickuvm custom prediction_logic begin
  // rtl/reqrsp.sv: each valid request yields one valid response carrying the same
  // tag (rsp_id = req_id), with rsp_data = req_data + req_id. Stateless — the
  // comparator matches responses to requests by tag (match: out_of_order), so the
  // two lanes' reordering and latency need no modelling here.
  extr.rsp_valid = 1'b1;
  extr.rsp_id    = t.req_id;
  extr.rsp_data  = t.req_data + {4'b0, t.req_id};
  // pragma quickuvm custom prediction_logic end

  `uvm_info("CALC #2", extr.convert2string(), UVM_FULL)
  return(extr);
endfunction
