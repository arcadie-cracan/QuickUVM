//----------------------------------------------------------------------
// Top (subsystem) environment — composes the child block envs and a virtual
// sequencer that collects each block's agent sequencers so a top vseq can
// coordinate stimulus across the blocks.
//----------------------------------------------------------------------

class clusterB_env extends uvm_env;
  `uvm_component_utils(clusterB_env)

  // Child block environments
  b0_env pb;
  b1_env qb;

  // Top virtual sequencer (coordinates the composed blocks)
  clusterB_virtual_sequencer vsqr;

  clusterB_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(clusterB_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No clusterB_env_cfg set for: ", get_full_name()})
    pb = b0_env::type_id::create("pb", this);
    qb = b1_env::type_id::create("qb", this);
    vsqr = clusterB_virtual_sequencer::type_id::create("vsqr", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Collect each block's active agent sequencers into the top vsqr
    vsqr.pb_gb0_sqr = pb.gb0_agnt.sqr;
    vsqr.qb_gb1_sqr = qb.gb1_agnt.sqr;
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
