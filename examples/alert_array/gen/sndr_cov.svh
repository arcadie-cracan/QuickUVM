class sndr_cov extends uvm_subscriber #(sndr_item);
  `uvm_component_utils(sndr_cov)

  sndr_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    ping_cp : coverpoint tr.ping {bins ping_bins[8] = {[0:$]};}
    last_adata_cp : coverpoint tr.last_adata {bins last_adata_bins[8] = {[0:$]};}
    resp_cp : coverpoint tr.resp {bins resp_bins[8] = {[0:$]};}
    alert_cp : coverpoint tr.alert {bins alert_bins[8] = {[0:$]};}
    adata_cp : coverpoint tr.adata {bins adata_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (sndr_item t);
    tr = t;
    `uvm_info("sndr_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
