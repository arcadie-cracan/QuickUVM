class rd_driver extends uvm_driver #(rd_item);
  `uvm_component_utils(rd_driver)

  virtual rd_if vif;

  // --- LIVENESS. Generated, and deliberately NOT inside a pragma. ---------------------
  // A dead responder is UNPROVABLE PER-TRANSACTION: with no response the DUT never
  // captures anything, so expected and actual are both zero and EVERY compare agrees.
  // It has reported TEST PASSED 34/34 while the device was stone dead. The only thing
  // that catches it is an end-of-test check — so a responder without one must be
  // impossible to GENERATE, not merely discouraged in a doc.
  protected int unsigned m_responses;      // responses actually driven

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  task run_phase(uvm_phase phase);
    rd_item tr;
    initialize();
    forever begin
      `uvm_info("DEBUG: rd_driver Run", "... getting next item ...", UVM_FULL)
      seq_item_port.get_next_item(tr);
      drive_item(tr);
      seq_item_port.item_done();
      `uvm_info("DEBUG: rd_driver Run", "... next item done ...", UVM_FULL)
    end
  endtask

  virtual task initialize (); // @0 - Does not use clocking block
    `uvm_info("INIT", "rd_driver: Initialize (time @0)", UVM_HIGH)
    vif.rvalid <= '0;
    vif.rid <= '1;
    vif.rdata <= '1;
    vif.rlast <= '0;
    // Reset is driven externally: hold off BEFORE advancing a clock so the parked
    // idle values are all the DUT sees during reset; wait for deassertion, then let
    // the input synchronizers settle (2 = a typical 2-stage sync; raise for deeper).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom initialize_additional begin
    // pragma quickuvm custom initialize_additional end
  endtask

  virtual task drive_item (rd_item tr);
    `uvm_info("drive_item", tr.input2string(), UVM_FULL)
    m_responses++;
    vif.cb1.rvalid <= tr.rvalid;
    vif.cb1.rid <= tr.rid;
    vif.cb1.rdata <= tr.rdata;
    vif.cb1.rlast <= tr.rlast;
    @vif.cb1;
    // pragma quickuvm custom drive_item_additional begin
    // The generated code above drove beat 0 (from the response item). Drive the REMAINING
    // arlen beats of the burst here — this is the multi-beat capability the single-beat
    // examples/axi_read did not exercise. rvalid stays high across the burst (back-to-back
    // beats); rid is constant; data follows the memory model araddr + beat_index; RLAST is
    // asserted only on the final beat (i == arlen).
    for (int i = 1; i <= int'(tr.arlen); i++) begin
      vif.cb1.rvalid <= 1'b1;
      vif.cb1.rid    <= tr.rid;
      vif.cb1.rdata  <= tr.araddr + i;
      vif.cb1.rlast  <= (i == int'(tr.arlen));
      @vif.cb1;
    end
    // Burst done: drop rvalid, then a modeled slave latency before the next read.
    vif.cb1.rvalid <= 1'b0;
    vif.cb1.rlast  <= 1'b0;
    @vif.cb1;
    repeat (2) @vif.cb1;
    // pragma quickuvm custom drive_item_additional end
  endtask

  function void check_phase (uvm_phase phase);
    super.check_phase(phase);
    if (m_responses == 0)
      `uvm_error("DEAD_RESPONDER",
                 {"this responder drove ZERO responses — the DUT never got an answer. ",
                  "Every per-transaction compare 'passed' because there was nothing to ",
                  "compare: with no response the DUT captures nothing, so expected and ",
                  "actual are both zero and they agree. Check that the DUT actually ",
                  "requests, and that request_valid names the right port."})
  endfunction

endclass
