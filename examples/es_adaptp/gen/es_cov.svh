class es_cov extends uvm_subscriber #(es_item);
  `uvm_component_utils(es_cov)

  es_item tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
    window_done_cp : coverpoint tr.window_done {bins window_done_bins[8] = {[0:$]};}
    ones_cnt_cp : coverpoint tr.ones_cnt {bins ones_cnt_bins[8] = {[0:$]};}
    test_fail_cp : coverpoint tr.test_fail {bins test_fail_bins[8] = {[0:$]};}
    alert_cp : coverpoint tr.alert {bins alert_bins[8] = {[0:$]};}
    sample_cp : coverpoint tr.sample {bins sample_bins[8] = {[0:$]};}
    valid_cp : coverpoint tr.valid {bins valid_bins[8] = {[0:$]};}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write (es_item t);
    tr = t;
    `uvm_info("es_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
