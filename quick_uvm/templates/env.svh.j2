{% set pa = agents[0] %}

class env extends uvm_env;
  `uvm_component_utils(env)

  // Agent handles
{% for agent in agents %}
  {{ agent.name }}_agent  {{ agent.name }}_agnt;
{% endfor %}

{% if analysis %}
  // Scoreboards
{% for sb in analysis.scoreboards %}
  tb_scoreboard {{ sb.name }};
{% endfor %}

  // Functional coverage (per agent)
{% for ag in analysis.coverage %}
  {{ ag }}_cover {{ ag }}_cov;
{% endfor %}
{% else %}
  // Scoreboard (wired to primary agent: {{ pa.name }})
  tb_scoreboard sbd;

  // Functional coverage (wired to primary agent: {{ pa.name }})
  {{ pa.name }}_cover cov;
{% endif %}

  // Environment configuration
  env_config env_cfg;
{% if register_model %}

  // Register model front-door adapter{% if register_model.use_predictor %} + predictor{% endif %}

  {{ register_model.adapter }} reg_adapter;
{% if register_model.use_predictor %}
  uvm_reg_predictor #({{ reg_bus_agent.transaction }}) reg_predictor;
{% endif %}
{% endif %}

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(env_config)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No env_config set for: ", get_full_name()})
{% for agent in agents %}
    uvm_config_db#({{ agent.name }}_config)::set(this, "{{ agent.name }}_agnt", "cfg", env_cfg.{{ agent.name }}_cfg);
    {{ agent.name }}_agnt = {{ agent.name }}_agent::type_id::create("{{ agent.name }}_agnt", this);
{% endfor %}
{% if analysis %}
{% for sb in analysis.scoreboards %}
    {{ sb.name }} = tb_scoreboard::type_id::create("{{ sb.name }}", this);
{% endfor %}
{% for ag in analysis.coverage %}
    {{ ag }}_cov = {{ ag }}_cover::type_id::create("{{ ag }}_cov", this);
{% endfor %}
{% else %}
    sbd  = tb_scoreboard::type_id::create("sbd",  this);
    cov  = {{ pa.name }}_cover::type_id::create("cov",  this);
{% endif %}
{% if register_model %}
    reg_adapter = {{ register_model.adapter }}::type_id::create("reg_adapter");
{% if register_model.use_predictor %}
    reg_predictor = uvm_reg_predictor#({{ reg_bus_agent.transaction }})::type_id::create("reg_predictor", this);
{% endif %}
{% endif %}
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
{% if analysis %}
    // Declared analysis connectivity (per analysis: block)
{% for sb in analysis.scoreboards %}
    {{ sb.source }}_agnt.ap.connect({{ sb.name }}.axp);
{% endfor %}
{% for ag in analysis.coverage %}
    {{ ag }}_agnt.ap.connect({{ ag }}_cov.analysis_export);
{% endfor %}
{% else %}
    // Primary agent → scoreboard + coverage
    {{ pa.name }}_agnt.ap.connect(sbd.axp);
    {{ pa.name }}_agnt.ap.connect(cov.analysis_export);
{% endif %}
{% if register_model %}
    // Register model front-door: bind the map to the bus agent's sequencer
    env_cfg.reg_model.{{ register_model.map }}.set_sequencer({{ register_model.bus_agent }}_agnt.sqr, reg_adapter);
{% if register_model.use_predictor %}
    reg_predictor.map     = env_cfg.reg_model.{{ register_model.map }};
    reg_predictor.adapter = reg_adapter;
    {{ register_model.bus_agent }}_agnt.ap.connect(reg_predictor.bus_in);
    env_cfg.reg_model.{{ register_model.map }}.set_auto_predict(0);
{% else %}
    env_cfg.reg_model.{{ register_model.map }}.set_auto_predict(1);
{% endif %}
{% endif %}
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
