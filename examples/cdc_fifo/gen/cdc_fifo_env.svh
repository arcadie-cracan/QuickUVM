  `uvm_component_utils(cdc_fifo_env)

  // Agent handles
  wr_agent  wr_agnt;
  rd_agent  rd_agnt;

  // Virtual sequencer (C2) — collects the active agents' sequencers
  cdc_fifo_virtual_sequencer vsqr;

  // Scoreboards
  cdc_fifo_scoreboard cdc;

  // Functional coverage (per agent)

  // Environment configuration
  cdc_fifo_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(cdc_fifo_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No cdc_fifo_env_cfg set for: ", get_full_name()})
    uvm_config_db#(wr_cfg)::set(this, "wr_agnt", "cfg", env_cfg.wr_cfg);
    wr_agnt = wr_agent::type_id::create("wr_agnt", this);
    uvm_config_db#(rd_cfg)::set(this, "rd_agnt", "cfg", env_cfg.rd_cfg);
    rd_agnt = rd_agent::type_id::create("rd_agnt", this);
    vsqr = cdc_fifo_virtual_sequencer::type_id::create("vsqr", this);
