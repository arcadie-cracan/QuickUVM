class {{ agent.name }}_cov extends uvm_subscriber #({{ agent.sequence_item }});
  `uvm_component_utils({{ agent.name }}_cov)

  {{ agent.sequence_item }} tr;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  // Modify the covergroup to sample desired signals
  covergroup cg;
    option.per_instance = 1;
    option.at_least     = 10;
{% if coverage_model %}
{% for cp in coverage_model.coverpoints %}
{% if cp.bins or cp.at_least %}
    {{ cp.field }}_cp : coverpoint tr.{{ cp.field }} {
{% if cp.at_least %}
      option.at_least = {{ cp.at_least }};
{% endif %}
{% for b in cp.bins %}
      bins {{ b.name }} = {{ b.sv_bin }};
{% endfor %}
    }
{% else %}
    {{ cp.field }}_cp : coverpoint tr.{{ cp.field }};
{% endif %}
{% endfor %}
{% for cr in coverage_model.crosses %}
    {{ cr | join('_x_') }} : cross {{ cr | join('_cp, ') }}_cp;
{% endfor %}
{% else %}
{% for port in agent.output_ports %}
{% if port.enum %}
    {{ port.name }}_cp : coverpoint tr.{{ port.name }};
{% else %}
    {{ port.name }}_cp : coverpoint tr.{{ port.name }} {bins {{ port.name }}_bins[8] = {[0:$]};}
{% endif %}
{% endfor %}
{% for port in agent.input_ports %}
{% if port.name == dut.reset %}
    dorst   : coverpoint tr.{{ port.name }} {bins dorst  = {'0};}
    norst   : coverpoint tr.{{ port.name }} {bins norst  = {'1};}
{% elif port.enum %}
    {{ port.name }}_cp : coverpoint tr.{{ port.name }};
{% else %}
    {{ port.name }}_cp : coverpoint tr.{{ port.name }} {bins {{ port.name }}_bins[8] = {[0:$]};}
{% endif %}
{% endfor %}
{% endif %}

    // pragma quickuvm custom coverpoints_additional begin
    // pragma quickuvm custom coverpoints_additional end
  endgroup

  function new (string name, uvm_component parent);
    super.new(name, parent);
    cg = new();
  endfunction

  function void write ({{ agent.sequence_item }} t);
    tr = t;
    `uvm_info("{{ agent.name }}_cov", "Taking covergroup sample ...", UVM_FULL)
    cg.sample();
  endfunction

endclass
