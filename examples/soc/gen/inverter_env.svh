class inverter_env extends uvm_env;
  `uvm_component_utils(inverter_env)

  // Agent handles
  b_agent  b_agnt;

  // Scoreboard (wired to primary agent: b)
  inverter_scoreboard sbd;

  // Functional coverage (wired to primary agent: b)
  b_cov cov;

  // Environment configuration
  inverter_env_cfg env_cfg;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    if (!uvm_config_db#(inverter_env_cfg)::get(this, "", "env_cfg", env_cfg))
      `uvm_fatal("NOCFG", {"No inverter_env_cfg set for: ", get_full_name()})
    uvm_config_db#(b_cfg)::set(this, "b_agnt", "cfg", env_cfg.b_cfg);
    b_agnt = b_agent::type_id::create("b_agnt", this);
    sbd  = inverter_scoreboard::type_id::create("sbd",  this);
    cov  = b_cov::type_id::create("cov",  this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

  function void connect_phase(uvm_phase phase);
    super.connect_phase(phase);
    // Primary agent → scoreboard + coverage
    b_agnt.ap.connect(sbd.axp);
    b_agnt.ap.connect(cov.analysis_export);
    // pragma quickuvm custom connect_phase_additional begin
    // pragma quickuvm custom connect_phase_additional end
  endfunction

endclass
