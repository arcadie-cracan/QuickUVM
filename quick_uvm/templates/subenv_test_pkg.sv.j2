//----------------------------------------------------------------------
// This File: {{ dut.name }}_test_pkg.sv
// Generated by: QuickUVM
// Project:  {{ project.name }}
// Author:   {{ project.author }}
// SPDX-License-Identifier: MIT
//----------------------------------------------------------------------
// Top (subsystem) test package: imports every composed block's env package
// (and its agent VIP packages), then adds the top env + coordination layer.
//----------------------------------------------------------------------

`include "uvm_macros.svh"
package {{ dut.name }}_test_pkg;
  import uvm_pkg::*;
{% for sv in subenvs %}
  import {{ sv.env_pkg }}::*;
{% endfor %}
{% for sv in subenvs %}
{% for agent in sv.agents %}
  import {{ agent.name }}_pkg::*;
{% endfor %}
{% endfor %}
{% if subenv_scoreboards %}

  // Cross-block scoreboards (typed on the source/monitor blocks' transactions)
{% for xsb in subenv_scoreboards %}
  `include "{{ dut.name }}_{{ xsb.name }}_predictor.svh"
  `include "{{ dut.name }}_{{ xsb.name }}_comparator.svh"
  `include "{{ dut.name }}_{{ xsb.name }}_scoreboard.svh"
{% endfor %}
{% endif %}

  // Top environment + coordination
  `include "{{ dut.name }}_env_cfg.svh"
  `include "{{ dut.name }}_virtual_sequencer.svh"
  `include "{{ dut.name }}_env.svh"
  `include "{{ dut.name }}_base_vseq.svh"
  `include "{{ dut.name }}_vseq.svh"

  // Tests
  `include "{{ dut.name }}_base_test.svh"
{% for test in tests %}
  `include "{{ test.name }}.svh"
{% endfor %}
{% for xsb in subenv_scoreboards %}
  `include "{{ dut.name }}_{{ xsb.name }}_reference_model.svh"
{% endfor %}

endpackage
