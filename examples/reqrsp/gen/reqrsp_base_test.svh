  function void build_phase(uvm_phase phase);
    super.build_phase(phase);

    // Build and populate the environment configuration
    env_cfg = reqrsp_env_cfg::type_id::create("env_cfg");
    env_cfg.req_cfg = req_cfg::type_id::create("req_cfg");
    env_cfg.req_cfg.is_active = UVM_ACTIVE;
    if (!uvm_config_db#(virtual req_if)::get(this, "", "req_if_vif", env_cfg.req_cfg.vif))
      `uvm_fatal("NOVIF", "No virtual interface 'req_if_vif' in config DB (see tb_top.sv)")
    env_cfg.rsp_cfg = rsp_cfg::type_id::create("rsp_cfg");
    env_cfg.rsp_cfg.is_active = UVM_PASSIVE;
    if (!uvm_config_db#(virtual rsp_if)::get(this, "", "rsp_if_vif", env_cfg.rsp_cfg.vif))
      `uvm_fatal("NOVIF", "No virtual interface 'rsp_if_vif' in config DB (see tb_top.sv)")
    uvm_config_db#(reqrsp_env_cfg)::set(this, "e", "env_cfg", env_cfg);

    e = reqrsp_env::type_id::create("e", this);
    // pragma quickuvm custom build_phase_additional begin
    // pragma quickuvm custom build_phase_additional end
  endfunction

