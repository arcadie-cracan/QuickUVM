class psoc_vseq extends psoc_base_vseq;
  `uvm_object_utils(psoc_vseq)

  function new (string name = "psoc_vseq");
    super.new(name);
  endfunction

  task body;
    d_seq#(8) dp_d_seq;
    m_seq#(16) mac_m_seq;

    dp_d_seq = d_seq#(8)::type_id::create("dp_d_seq");
    mac_m_seq = m_seq#(16)::type_id::create("mac_m_seq");
    // pragma quickuvm custom vseq_body_pre begin
    // pragma quickuvm custom vseq_body_pre end
    // Run every block's stimulus concurrently
    fork
      dp_d_seq.start(p_sequencer.dp_d_sqr);
      mac_m_seq.start(p_sequencer.mac_m_sqr);
    join
    // pragma quickuvm custom vseq_body_post begin
    // pragma quickuvm custom vseq_body_post end
  endtask

endclass
