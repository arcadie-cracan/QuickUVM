class host_monitor extends uvm_monitor;
  `uvm_component_utils(host_monitor)

  virtual host_if vif;

  uvm_analysis_port #(host_seq_item) ap;

  // pragma quickuvm custom class_item_additional begin
  // pragma quickuvm custom class_item_additional end

  function new (string name, uvm_component parent);
    super.new(name, parent);
  endfunction

  function void build_phase(uvm_phase phase);
    super.build_phase(phase);
    ap = new("ap", this);
  endfunction

  task run_phase(uvm_phase phase);
    host_seq_item tr;
    // Reset is driven externally: do not emit transactions until it deasserts, then
    // resync to the clock grid (sample_dut() assumes it starts at a posedge clk).
    wait (vif.rst_n === 1'b1);
    @vif.cb1;
    forever begin
      sample_dut(tr);
      ap.write(tr);
    end
  endtask

  task sample_dut (output host_seq_item tr);
    host_seq_item t;
    t = host_seq_item::type_id::create("t");
    //---------------------------------------------
    // Assumption: sample_dut() is already sync-ed to posedge clk
    // Sample DUT inputs now (on posedge clk)
    //---------------------------------------------
    t.addr = vif.addr;
    t.wdata = vif.wdata;
    t.wr = vif.wr;

    @vif.cb1;
    //---------------------------------------------
    // Re-test async reset and re-assign if asserted
    //---------------------------------------------
    //---------------------------------------------
    // Sample DUT outputs #1step before posedge clk
    // Uses clocking block timing
    //---------------------------------------------
    t.rdata = vif.cb1.rdata;

    // pragma quickuvm custom sample_dut_additional begin
    // rtl/rvtimer.sv reads COMBINATIONALLY (rdata = <reg>[idx]); the default split-
    // edge sampling above (inputs at posedge T, rdata at T+1) assumes a registered
    // 1-cycle-latency output and would mis-pair them by one cycle. Re-sample the
    // inputs at this same edge so (addr, wr, wdata) line up with the rdata just read.
    t.addr  = vif.addr;
    t.wdata = vif.wdata;
    t.wr    = vif.wr;
    // pragma quickuvm custom sample_dut_additional end

    tr = t;
    `uvm_info("sample_dut", tr.convert2string(), UVM_FULL)
  endtask

endclass
